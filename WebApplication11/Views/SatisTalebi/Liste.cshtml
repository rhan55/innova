@model System.Data.DataTable
@{
    string Modul = "";
    switch (Request.QueryString["Tip"])
    {
        case "STL":
            Modul = "Satış Talebi";
            break;
        default:
            break;
    }
    ViewBag.Title = Modul + " Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row mt-4">
        <div style="margin:3px;" class="scroll-x">
            <div class="text-end">
                <a href="@Url.Action("Detay","SatisTalebi",new { Tip = Request.QueryString["Tip"], KayitID = "" })" class="btn btn-sm btn-primary " style="width:100px;">Yeni Talep</a>
            </div>

            <style>
                .max-w-500 {
                    max-width: 250px !important;
                }

                .max-w-500 {
                    max-width: 360px !important;
                }
            </style>
            <table class="table p-4 align-middle border rounded table-row-dashed fs-6 g-5 mt-4">
                <thead>

                    <!--begin::Table row-->
                    <tr>
                        <th><strong>Tarih</strong></th>
                        <th><strong>Belge No</strong></th>
                        @if (Request.QueryString["Tip"] == "STL")
                        {
                            <th class="max-w-500"><strong>Cari</strong></th>
                        }
                        else if (Request.QueryString["Tip"] == "DT")
                        {
                            <th><strong>Çıkış Depo</strong></th>
                            <th><strong>Giriş Depo</strong></th>
                        }
                        <th style="text-align:right;"><strong>Tutar</strong></th>
                        <th class="text-end"><strong>İşlemler</strong></th>
                    </tr>
                    <!--end::Table row-->
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        for (var i = 0; i < Model.Rows.Count; i++)
                        {
                            <tr>
                                <td class="text-gray-600 fw-semibold" style="vertical-align: middle;">
                                    @(Convert.ToDateTime(Model.Rows[i]["Tarih"]).ToString("dd-MM-yyyy"))
                                </td>
                                <td style="vertical-align: middle;">
                                    <span style="color:blue;">@(Convert.ToString(Model.Rows[i]["BelgeNo"]))</span>
                                </td>
                                @if (Request.QueryString["Tip"] == "STL")
                                {
                                    <td class="text-wrap max-w-500 d-block text-gray-600 fw-semibold" style="vertical-align: middle;">
                                        @(Convert.ToString(Model.Rows[i]["CariIsim"]))
                                    </td>
                                }
                                else if (Request.QueryString["Tip"] == "DT")
                                {
                                    <td class="text-gray-600 fw-semibold" style="vertical-align: middle;">
                                        @(Convert.ToString(Model.Rows[i]["DepoCikis"]))
                                    </td>
                                    <td class="text-gray-600 fw-semibold" style="vertical-align: middle;">
                                        @(Convert.ToString(Model.Rows[i]["DepoGiris"]))
                                    </td>
                                }
                                <td class="text-gray-600 fw-semibold" style="text-align:right;vertical-align:middle;">
                                    @(String.Format("{0:N2}",Convert.ToDecimal(Model.Rows[i]["Tutar"]))) @(Convert.ToString(Model.Rows[i]["DovizBirimi"]))
                                </td>
                                <td class="text-end" style="vertical-align: middle;">
                                    <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm  fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        İşlemler
                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                    </a>
                                    <!--begin::Menu-->
                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-0 py-0">
                                            <a href="/SatisTalebi/Duzenle?id=@(Convert.ToString(Model.Rows[i]["ID"]))&Tip=@(Request.QueryString["Tip"])" class="menu-link rounded-0 py-0  px-2">Düzenle</a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-0 py-0">
                                            <a href="/SatisTalebi/Sil?id=@(Convert.ToString(Model.Rows[i]["ID"]))&Tip=@(Request.QueryString["Tip"])" class="menu-link rounded-0 py-0  px-2" onclick="return confirm('Silmek istediğinizden emin misiniz?')">Sil</a>
                                        </div>
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script>



    </script>
}

@model YKPortal.Models.Dto.PersonelDto
@{
    ViewBag.Title = "Personel Ekle";
    Layout = "~/Views/Shared/_LayoutTab.cshtml";
}

<div class="container mt-10">
    <form id="kt_modal_add_user_form" class="form container" action="@Url.Action("Ekle","Personel",null)" method="post">
        <div class="d-flex flex-column scroll-y px-5 px-lg-10">
            <!--begin::Row Input group-->
            <div class="row mb-7 mt-4">

                <!--begin::Input group-->
                <div class="col-lg-6"> 
                    <!--begin::Label-->
                    <label for="Isim" class="required fw-semibold fs-6 mb-2">İsim</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="Isim" id="Isim" class="form-control p-2 mb-3 mb-lg-0" value="" required />

                    <!--end::Input-->
                </div>
                <!--end::Input group-->
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Email" class=" fw-semibold fs-6 mb-2">Email</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="Email" id="Email" class="form-control p-2 mb-3 mb-lg-0" />
                    <!--end::Input-->
                </div>
                <!--end::Input group-->
            </div>
            <div class="row">
                <!--begin::Input group-->
                <div class="col-lg-12">
                    <!--begin::Label-->
                    <label for="Telefon" class="required fw-semibold fs-6 mb-2">Telefon</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="Telefon" id="Telefon" class="form-control p-2 mb-3 mb-lg-0" value="" />

                    <!--end::Input-->
                </div>
                <!--end::Input group-->
            </div>
            <!--begin::Actions-->
            <div class="pt-10">
                <a onclick="history.back()" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Geri</a>
                <button type="submit" class="btn btn-primary" data-kt-users-modal-action="Kaydet">
                    <span class="indicator-label">Kaydet</span>
                    <span class="indicator-progress">
                        Lütfen Bekleyin...
                        <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                </button>
            </div>
        </div>
        <!--end::Actions-->
    </form>
</div>



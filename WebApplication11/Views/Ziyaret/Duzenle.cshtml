
@{
    ViewBag.Title = "Duzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <form id="kt_modal_add_user_form" class="form container" action="@Url.Action("Ekle","Ziyaret",null)" method="post">
        <div class="d-flex flex-column scroll-y px-5 px-lg-10 mt-10">
            <input type="hidden" name="CariID" value="@ViewBag.CariID" />
            <input type="hidden" name="ID" />
            <!--begin::Row Input group-->
            <div class="row mb-7">
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Tarih" class="fw-semibold fs-6 mb-2">Tarih</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="Tarih" class="form-control  mb-3 mb-lg-0" />

                    <!--end::Input-->
                </div>
                <!--end::Input group-->
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="ZiyaretTipi" class="fw-semibold fs-6 mb-2">ZiyaretTipi</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="ZiyaretTipi" class="form-control  mb-3 mb-lg-0" autofocus />
                    <!--end::Input-->
                </div>
                <!--end::Input group-->
            </div>
            <!--end::Row Input group-->
            <!--begin::Row Input group-->
            <div class="row mb-7">
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Aciklama " class="fw-semibold fs-6 mb-2">Aciklama</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <textarea type="text" name="Aciklama" class="form-control p-2 rounded-1" id="Aciklama"></textarea>
                    <input type="text" name="Aciklama" class="form-control  mb-3 mb-lg-0" />

                    <!--end::Input-->
                </div>
                <!--end::Input group-->
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="TamamlamaAciklamasi" class="fw-semibold fs-6 mb-2">TamamlamaAciklamasi</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="TamamlamaAciklamasi" class="form-control  mb-3 mb-lg-0" autofocus />
                    <!--end::Input-->
                </div>
                <!--end::Input group-->
            </div>
            <!--end::Row Input group-->
            <!--begin::Row Input group-->
            <div class="row mb-7">
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="TamamlamaTarihi" class="fw-semibold fs-6 mb-2">TamamlamaTarihi </label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="TamamlamaTarihi" class="form-control  mb-3 mb-lg-0" />

                    <!--end::Input-->
                </div>
                <!--end::Input group-->
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="TamamlayanKullaniciID" class="fw-semibold fs-6 mb-2">TamamlayanKullaniciID</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" name="TamamlayanKullaniciID" class="form-control  mb-3 mb-lg-0" autofocus />
                    <!--end::Input-->
                </div>
                <!--end::Input group-->
            </div>
            <!--end::Row Input group-->
        </div>
        <!--begin::Actions-->
        <div class="text-center pt-10">
            <a href="/Depo/Liste" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Geri</a>
            <button type="submit" class="btn btn-primary" data-kt-users-modal-action="Kaydet">
                <span class="indicator-label">Kaydet</span>
                <span class="indicator-progress">
                    Lütfen Bekleyin...
                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                </span>
            </button>
        </div>
        <!--end::Actions-->
    </form>
</div>



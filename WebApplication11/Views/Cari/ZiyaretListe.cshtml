@using YKPortal.Models.Dto
@{
    ViewBag.Title = "ZiyaretListe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12 d-flex align-items-center justify-content-end py-12">
            <a href="/Cari/ZiyaretEkle?CariID=@ViewBag.CariID" class="btn btn-primary">Ziyaret Ekle</a>
        </div>
    </div>
    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })
        <div class="col-lg-10">
            <div class="timeline timeline-border-dashed">
                @foreach (ZiyaretDto ziyaret in ViewBag.Ziyaretler)
                {
                    <div class="timeline-item ">
                        <div class="timeline-line"></div>
                        <div class="timeline-icon">
                            <i class="ki-duotone ki-people fs-2">
                                <span class="path1"></span>
                                <span class="path2"></span>
                                <span class="path3"></span>
                                <span class="path4"></span>
                                <span class="path5"></span>
                            </i>
                        </div>
                        <div class="timeline-content mb-10 mt-n1">
                            <div class="card p-4">
                                <div class="card-title">
                                    <div>@ziyaret.CariIsim</div>

                                </div>
                                <div class="card-body">
                                    <div class="fs-5 fw-semibold mb-2">@ziyaret.ZiyaretTipi </div>
                                    <div class="fs-5 fw-semibold mb-2 d-flex">
                                        <div><p>Açıklama: </p></div>
                                        <div>  @ziyaret.Aciklama</div>
                                    </div>
                                    <div class="fs-5 fw-semibold mb-2 d-flex">
                                        <div><p>Gerçekleşen: </p></div>
                                        <div>  @ziyaret.TamamlamaAciklamasi</div>
                                    </div>
                                    <div class="fs-5 fw-semibold mb-2 d-flex">
                                        <div><p>Tarih: </p></div>
                                        <div>  @ziyaret.Tarih</div>
                                    </div>
                                    <div class="d-flex align-items-center mt-1 fs-6">
                                        <!--begin::Info-->
                                        <div class="text-muted me-2 fs-7">Added at 4:23 PM by</div>
                                        <!--end::Info-->
                                        <!--begin::User-->
                                        <!--end::User-->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>



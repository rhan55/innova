@using YKPortal.Models.Dto
@{
    ViewBag.Title = "ZiyaretListe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-2">
            @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })
        </div>
        <div class="col-10">
            <div class="d-flex align-items-center justify-content-end py-4">
                <a href="/Cari/ZiyaretEkle?CariID=@ViewBag.CariID" class="btn btn-primary">Ziyaret Ekle</a>
            </div>
            <div class="timeline timeline-border-dashed">
                @foreach (ZiyaretDto ziyaret in ViewBag.Ziyaretler)
                {
                    <div class="timeline-item ">
                        <div class="timeline-line"></div>
                        <div class="timeline-icon">
                            <i class="ki-duotone ki-people fs-2">
                                <span class="path1"></span>
                                <span class="path2"></span>
                                <span class="path3"></span>
                                <span class="path4"></span>
                                <span class="path5"></span>
                            </i>
                        </div>
                        <div class="timeline-content">
                            <div class="card p-6">
                                <div class="card-title">
                                    <div class="fw-bold fs-3 text-gray-700">@ziyaret.CariIsim</div>

                                </div>
                                <div class="card-body">
                                    <div class="fs-5 fw-semibold">@ziyaret.ZiyaretTipi </div>
                                    <div class="fs-5 d-flex">
                                        <div><p class=" fw-semibold text-gray-700">Açıklama: </p></div>
                                        <div class="fw-semibold text-gray-600">  @ziyaret.Aciklama</div>
                                    </div>
                                    <div class="fs-5 fw-semibold d-flex">
                                        <div><p class=" fw-semibold text-gray-700">Gerçekleşen: </p></div>
                                        <div class="fw-semibold text-gray-600">  @ziyaret.TamamlamaAciklamasi</div>
                                    </div>
                                    <div class="fs-5 fw-semibold d-flex">
                                        <div><p class="fw-semibold text-gray-700">Tarih: </p></div>
                                        <div class="fw-semibold text-gray-600">  @ziyaret.Tarih</div>
                                    </div>
                                    <div class="d-flex mt-1 fs-6 w-full">
                                        <!--begin::Info-->
                                        <div class="text-muted align-items-end me-2 fs-7">Added at 4:23 PM by</div>
                                        <!--end::Info-->
                                        <!--begin::User-->
                                        <!--end::User-->
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>



@using YKPortal.Models.Dto
@model YKPortal.Models.Dto.CariNotListeViewModel
@{
    ViewBag.Title = "Aktivite Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })
        <div class="col-10 p-4">
            <div class="d-flex align-items-center justify-content-end mt-6">
                <a href="/Cari/ZiyaretEkle?CariID=@ViewBag.CariID" class="btn btn-primary btn-sm">Aktivite Ekle</a>
            </div>
            <div>
                <div class="timeline timeline-border-dashed">
                    @foreach (ZiyaretDto ziyaret in ViewBag.Ziyaretler)
                    {
                        <div class="timeline-item ">
                            <div class="timeline-line"></div>
                            <div class="timeline-icon">
                                <span class="menu-icon">
                                    <i class="ki-duotone ki-profile-user fs-3">
                                        <span class="path1"></span>
                                        <span class="path2"></span>
                                        <span class="path3"></span>
                                        <span class="path4"></span>
                                    </i>
                                </span>
                            </div>
                            <div class="timeline-content mt-6">
                                <div class="card card-flush p-6">
                                    <div class="card-header">
                                        <div class="card-title">
                                            <div class="fw-bold fs-3 text-gray-700">@ziyaret.CariIsim</div>
                                        </div>
                                        <div class="card-toolbar">
                                            <button type="button" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                İşlemler
                                                <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                            </button>
                                            <!--begin::Menu-->
                                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                                <!--begin::Menu item-->
                                                <div class="menu-item p-0">
                                                    <a href="/Cari/ZiyaretDuzenle?CariID=@ziyaret.CariID&ID=@ziyaret.ID" class="menu-link rounded-0 px-2 py-0">Düzenle</a>
                                                </div>
                                                <!--end::Menu item-->
                                                <div class="menu-item p-0">
                                                    <a href="/Cari/ZiyaretiKapat?CariID=@ziyaret.CariID&ID=@ziyaret.ID" class="menu-link rounded-0 px-2 py-0">Aktiviteyi Kapat</a>
                                                </div>
                                                <!--begin::Menu item-->
                                                <div class="menu-item p-0">
                                                    <button type="button" data-id="@ziyaret.ID" class="btn btn-sm w-100 menu-link rounded-0 px-2 py-0 btn-sil Ziyaret-silme" data-bs-toggle="modal" data-bs-target="#Ziyaret-silme">
                                                        Sil
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-lg-12">

                                                <div class="fs-5 d-flex">
                                                    <div><p class=" fw-semibold text-gray-700">Planlanan: </p></div>
                                                    <div class="fw-semibold text-gray-600">  @ziyaret.Aciklama</div>
                                                </div>
                                                @if (ziyaret.TamamlamaAciklamasi.Length > 0)
                                                {
                                                    <div class="fs-5 fw-semibold d-flex">
                                                        <div><p class=" fw-semibold text-gray-700">Gerçekleşen: </p></div>
                                                        <div class="fw-semibold text-gray-600">  @ziyaret.TamamlamaAciklamasi</div>
                                                    </div>
                                                }
                                                <div class="d-flex align-items-start justify-content-between">
                                                    <div>
                                                        <div class="text-muted">Tarih: @ziyaret.Tarih</div>
                                                        @if (ziyaret.TamamlamaTarihi.Length > 0)
                                                        {
                                                            <div class="text-muted">Tamamlanma Tarihi: @ziyaret.TamamlamaTarihi</div>
                                                        }

                                                    </div>
                                                    <div>
                                                        <div>
                                                            <span>Kaydı Açan Kullanıcı: </span> <span>@ziyaret.KaydiAcanIsim</span>
                                                        </div>
                                                        @if (ziyaret.TamamlayanIsim.Length > 0)
                                                        {
                                                            <div>
                                                                <span>Tamamlayan Kullanıcı: </span> <span>@ziyaret.TamamlayanIsim</span>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>

                                            </div>

                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="Ziyaret-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Aktivite Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Aktiviteyi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("ZiyaretSil","Cari",null)">
                    <input type="hidden" name="id" value="" />
                    <input type="hidden" name="CariID" value="@ViewBag.CariID" />
                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                })
            })
        });
    </script>
}



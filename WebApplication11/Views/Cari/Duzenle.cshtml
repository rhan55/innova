                                                <label for="KullaniciAdi" class=" form-label"> Kullanıcı Adı</label>
                                                <input id="KullaniciAdi" type="text" name="KullaniciAdi" class="form-control p-2 rounded-1" placeholder="" value="@(Convert.ToString(Model.Rows[0]["KullaniciAdi"]))"  />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="Parola" class=" form-label">Parola</label>
                                                <input id="Parola" type="password" name="Parola" class="form-control p-2 rounded-1" placeholder="" value="@(Convert.ToString(Model.Rows[0]["Parola"]))"  />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="EMail" class="form-label ">Email</label>
                                                <input type="text" name="EMail" class="form-control p-2 rounded-1" id="EMail" value="@(Convert.ToString(Model.Rows[0]["EMail"]))" />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">

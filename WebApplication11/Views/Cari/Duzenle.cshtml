@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {

            Inputmask({
                "mask": "(999) 999-9999"
            }).mask("#CepTelefonu").mask("#Faks").mask("Telefon1").mask("Telefon2");

            const VergiNumarasi = document.getElementById('VergiNumarasi')
            const TCKimlikNo = document.getElementById('TCKimlikNo')
            const form = document.getElementById('cariDuzenleFormu')

            const onlyNumbers = /^\d+$/;

            form.addEventListener('submit', (e) => {
                e.preventDefault();

                let isValidated = true;
                const message = {
                    VergiNumarasi: [],
                    TCKimlikNo: []
                };

                //if (!VergiNumarasi.value) {
                //    isValidated = false;
                //    message.VergiNumarasi.push("Vergi numarası boş olamaz.")
                //}

                if (!(VergiNumarasi.value.length == 10) && VergiNumarasi.value.length > 0) {
                    isValidated = false;
                    message.VergiNumarasi.push("Vergi numarasi 10 haneli olmalıdır.")
                }

                if (!(onlyNumbers.test(VergiNumarasi.value)) && VergiNumarasi.value.length > 0) {
                    isValidated = false;
                    message.VergiNumarasi.push("Vergi numarasında sadece rakamlar kullanılabilir.");
                }

                //if (!TCKimlikNo.value) {
                //    isValidated = false;
                //    message.TCKimlikNo.push("TC Kimlik numarası boş olamaz.")
                //}

                if (!(TCKimlikNo.value.length == 11) && TCKimlikNo.value.length > 0) {
                    isValidated = false;
                    message.TCKimlikNo.push("TC Kimlik numarası 11 haneli olmalıdır.")
                }

                if (isValidated) {
                    form.submit();
                } else {
                    document.querySelector('[data-error="VergiNumarasi"]').innerHTML = message.VergiNumarasi.map(error => `<div class="text-danger">${error}</div>`).join("");
                    document.querySelector('[data-error="TCKimlikNo"]').innerHTML = message.TCKimlikNo.map(error => `<div class="text-danger">${error}</div>`).join("");
                }
            });

            const anaCariIdSelect = $('#AnaCariID').select2({
                ajax: {
                    url: "/Cari/SelectListe",
                    data: function (params) {
                        var query = {
                            search: params.term,
                        }

                        // Query parameters will be ?search=[term]&type=public
                        return query;
                    },
                    processResults: function (data) {
                        var results = [];
                        if (data && data.length > 0) {
                            data.forEach(function (item) {
                                results.push({ id: item.ID, text: item.Isim })
                            });
                        }

                        return {
                            results: results
                        };
                    },

                },
                delay: 250,
                minimumInputLength: 3,
                language: {
                    placeholder: function () {
                        return "Arama yapmak için en az 3 karakter girin";
                    },
                    inputTooShort: function () {
                        return "Lütfen en az 3 karakter girin";
                    }
                }
            });


        });
        $(function () {

            const teslimCariIdSelect = $('#TeslimCariID').select2({
                ajax: {
                    url: "/Cari/SelectListe",
                    data: function (params) {
                        var query = {

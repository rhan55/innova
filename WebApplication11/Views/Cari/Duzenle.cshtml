                                                    Alıcı
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-lg-2 d-flex align-items-center mt-4 mt-lg-0">
                                            <div class="form-check">
                                                <input class="form-check-input" name="Satici" type="checkbox" value="true" id="Satici" @(Convert.ToBoolean(Model.Rows[0]["Satici"]) ? "checked" : "") />
                                                <label class="form-check-label user-select-none cursor-pointer" for="Satici">
                                                    Satıcı
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-lg-2 d-flex align-items-center mt-4 mt-lg-0">
                                            <div class="form-check">
                                                <input class="form-check-input" name="Personel" type="checkbox" value="true" id="Personel" @(Convert.ToBoolean(Model.Rows[0]["Personel"]) ? "checked" : "") />
                                                <label class="form-check-label user-select-none cursor-pointer" for="Personel">
                                                    Personel
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-lg-2 d-flex align-items-center mt-4 mt-lg-0">
                                            <div class="form-check">
                                                <input class="form-check-input" name="ServisPersoneli" type="checkbox" value="true" id="ServisPersoneli" @(Convert.ToBoolean(Model.Rows[0]["ServisPersoneli"]) ? "checked" : "") />
                                                <label class="form-check-label user-select-none cursor-pointer" for="ServisPersoneli">
                                                    Servis Personeli
                                                </label>
                                            </div>
                                        </div>
                                        <div class="col-lg-2 d-flex align-items-center mt-4 mt-lg-0">
                                            <div class="form-group w-100">

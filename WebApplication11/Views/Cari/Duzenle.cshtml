        </div>
        <form class="col-lg-10 row" method="post" action="@Url.Action("Duzenle","Cari",null)">

            <div class="col-lg-6">
                <input type="hidden" name="ID" value="@(Convert.ToString(Model.Rows[0]["ID"]))" />
                <h4>Genel Bilgiler</h4>
                <div class="d-flex align-items-center justify-content-between mt-5">
                    <div class="form-check">
                        <input class="form-check-input" name="Aktif" type="checkbox" value="true" id="Aktif" checked />
                        <label class="form-check-label user-select-none cursor-pointer" for="Aktif">
                            Aktif
                        </label>
                    </div>
                    <div class="form-group">
                        <label for="exampleFormControlInput1" class="required form-label">Kayıt Tarihi</label>
                        @* Varsayilan gun tarihini cagirdik ve toString ile formatladik. bu format sayesinde input value degerini de atamis olduk, readonly ile sadece okunabilir duzenlenemez yaptik *@
                        <input type="date" value="@(DateTime.Parse(Convert.ToString(Model.Rows[0]["KayitTarihi"])).ToString("yyyy-MM-dd"))" name="KayitTarihi" class="form-control form-control-solid" placeholder="" readonly />
                    </div>

                </div>
                <div class="d-flex mt-5">

                    <div class="col-6  pe-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label"> Kullanıcı Adı</label>
                            <input type="text" name="KullaniciAdi" value="@(Convert.ToString(Model.Rows[0]["KullaniciAdi"]))" class="form-control form-control-solid" placeholder="" required />
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">Parola</label>
                            <input type="password" name="Parola" value="@(Convert.ToString(Model.Rows[0]["Parola"]))" class="form-control form-control-solid" placeholder="" required />
                        </div>
                    </div>
                </div>
                <div class="form-group mt-5">
                    <label for="exampleFormControlInput1" class="required form-label">Cari Kodu</label>
                    <input type="text" name="Kod" value="@(Convert.ToString(Model.Rows[0]["Kod"]))" class="form-control form-control-solid" placeholder="" />
                </div>
                <div class="form-group mt-5">
                    <label for="exampleFormControlInput1" class="required form-label">Cari İsmi</label>
                    <input type="text" name="Isim" value="@(Convert.ToString(Model.Rows[0]["Isim"]))" class="form-control form-control-solid" placeholder="" required />
                </div>
                <div class="form-group mt-5">
                    <label for="exampleFormControlInput1" class="required form-label">Cari Unvan</label>
                    <textarea type="text" name="Unvan" class="form-control form-control-solid" placeholder="" required>@(Convert.ToString(Model.Rows[0]["Unvan"]))</textarea>
                </div>
                <div class="form-group mt-5">
                    <label for="exampleFormControlInput1" class="required form-label">Adres</label>
                    <textarea type="text" name="Adres" class="form-control form-control-solid" placeholder="" required>@(Convert.ToString(Model.Rows[0]["Adres"]))</textarea>
                </div>

                <div class="d-flex mt-5">
                    <div class="col-6 pe-3">
                        <div class="">
                            <label for="floatingSelect" class="required form-label">İl</label>
                            <select class="form-select form-select-solid" name="Il" id="floatingSelect"
                                    aria-label="Floating label select example">
                                <option value="">Lütfen Seçim Yapınız</option>
                                @foreach (var il in ViewBag.Iller)
                                {
                                    <option @(Convert.ToString(Model.Rows[0]["Il"]) == il ? "selected" : "") value="@il">@il</option>
                                }

                            </select>
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">İlçe</label>
                            <input type="text" name="Ilce" value="@(Convert.ToString(Model.Rows[0]["Ilce"]))" class="form-control form-control-solid" placeholder="" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">
                    <div class="col-6 pe-3">
                        <div class="">
                            <label for="floatingSelect" class="required form-label">Ülke</label>
                            <select class="form-select form-select-solid" name="Ulke" id="floatingSelect"
                                    aria-label="Floating label select example">
                                <option value="">Lütfen Seçim Yapınız</option>
                                @foreach (var ulke in ViewBag.Ulkeler)
                                {
                                    <option @(Convert.ToString(Model.Rows[0]["Ulke"]) == ulke ? "selected" : "") value="@ulke">@ulke</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="Bolge" class="required form-label">Bölge</label>
                            <input type="text" name="Bolge" id="Bolge" value="@(Convert.ToString(Model.Rows[0]["Bolge"]))" class="form-control form-control-solid" placeholder="" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">

                    <div class="col-6  pe-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">Posta Kodu</label>
                            <input type="text" name="PostaKodu" value="@(Convert.ToString(Model.Rows[0]["PostaKodu"]))" class="form-control form-control-solid" placeholder="" />
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">TC No</label>
                            <input type="text" name="TCKimlikNo" value="@(Convert.ToString(Model.Rows[0]["TCKimlikNo"]))" class="form-control form-control-solid" placeholder="" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">
                    <div class="col-6 pe-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">Vergi Dairesi</label>
                            <input type="text" name="VergiDairesi" value="@(Convert.ToString(Model.Rows[0]["VergiDairesi"]))" class="form-control form-control-solid" placeholder="" />
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">Vergi Numarası</label>
                            <input type="text" name="VergiNumarasi" value="@(Convert.ToString(Model.Rows[0]["VergiNumarasi"]))" class="form-control form-control-solid" placeholder="" />
                        </div>
                    </div>
                </div>

                <div class="d-flex mt-5">
                    <div class="col-6 pe-3 d-flex">
                        <div class="form-check me-5">
                            <input class="form-check-input" name="Alici" type="checkbox" value="true" id="Alici" @(Convert.ToBoolean(Model.Rows[0]["Alici"]) ? "checked" : "") />
                            <label class="form-check-label user-select-none cursor-pointer" for="Alici">
                                Alıcı
                            </label>
                        </div>
                        <div class="form-check me-5">
                            <input class="form-check-input" name="Satici" type="checkbox" value="true" id="Satici" @(Convert.ToBoolean(Model.Rows[0]["Satici"]) ? "checked" : "") />
                            <label class="form-check-label user-select-none cursor-pointer" for="Satici">
                                Satıcı
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" name="Personel" type="checkbox" value="true" id="Personel" @(Convert.ToBoolean(Model.Rows[0]["Personel"]) ? "checked" : "") />
                            <label class="form-check-label user-select-none cursor-pointer" for="Personel">
                                Personel
                            </label>
                        </div>
                    </div>
                    <div class="col-6 pe-3 ms-3">
                        <div class="form-check">
                            <input class="form-check-input" name="ServisPersoneli" type="checkbox" value="true" id="ServisPersoneli" @(Convert.ToBoolean(Model.Rows[0]["ServisPersoneli"]) ? "checked" : "") />
                            <label class="form-check-label user-select-none cursor-pointer" for="ServisPersoneli">
                                ServisPersoneli
                            </label>
                        </div>
                    </div>
                </div>

                <div class="d-flex mt-5">
                    <div class="col-6 pe-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">Döviz Id</label>
                            <input type="text" name="DovizID" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["DovizID"]))" />
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">Vade Günü</label>
                            <input type="text" name="VadeGunu" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["VadeGunu"]))" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">
                    <div class=" col-6 form-check me-5 mt-8">

                        <input class="form-check-input" name="Kilitli" type="checkbox" value="true" id="Kilitli" @(Convert.ToString(Model.Rows[0]["Kilitli"])) @(Convert.ToBoolean(Model.Rows[0]["Kilitli"]) ? "checked" : "") />
                        <label class="form-check-label user-select-none cursor-pointer" for="Kilitli ">
                            Kilitli
                        </label>
                    </div>

                    <div class="col-6 ps-3">
                        <div class="form-group me-5">
                            <label for="exampleFormControlInput1" class="required form-label">KilitAciklamasi</label>
                            <input type="text" name="KilitAciklamasi" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["KilitAciklamasi"]))" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">
                    <div class="form-check col-6 ps-0 pe-3 flex-col">
                        <label for="Iskonto1" class="required form-label">Iskonto1</label>
                        <input type="text" class="form-control form-control-solid" name="Iskonto1" id="Iskonto1" step="any" value="@(Convert.ToDecimal(Model.Rows[0]["Iskonto1"]).ToString("F2"))" />

                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">ListeFiyat</label>
                            <input type="text" name="ListeFiyat" class="form-control form-control-solid" placeholder="" step="any" value="@(Convert.ToDecimal(Model.Rows[0]["ListeFiyat"]).ToString("F2"))" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">
                    <div class="col-6 ps-3 d-flex mt-8">
                        <div class="form-check me-5">
                            <input class="form-check-input" name="LimitAsimindaUyar" type="checkbox" value="true" id="LimitAsimindaUyar" @(Convert.ToBoolean(Model.Rows[0]["LimitAsimindaUyar"]) ? "checked" : "") />
                            <label class="form-check-label user-select-none cursor-pointer" for="LimitAsimindaUyar ">
                                Limit<br />Aşımında Uyar
                            </label>
                        </div>
                        <div class="form-check me-5">
                            <input class="form-check-input" name="LimitAsimindaDurdur" type="checkbox" value="true" id="LimitAsimindaDurdur" @(Convert.ToBoolean(Model.Rows[0]["LimitAsimindaDurdur"]) ? "checked" : "") />
                            <label class="form-check-label user-select-none cursor-pointer" for="LimitAsimindaDurdur">
                                Limit<br />Aşımında Durdur
                            </label>
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="Limit" class="required form-label">Limit</label>
                            <input type="text" name="Limit" class="form-control form-control-solid" placeholder="" id="Limit" step="any" value="@(Convert.ToDecimal(Model.Rows[0]["Limit"]).ToString("F2"))" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">

                    <div class="col-12">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label"> Muhasebe Kodu </label>
                            <input type="text" name="MuhasebeKodu" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["MuhasebeKodu"]))" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">

                    <div class="col-6  pe-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label"> RiskAciklama </label>
                            <input type="text" name="RiskAciklama" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["RiskAciklama"]))" />
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">PlasiyerID </label>
                            <input type="text" name="PlasiyerID" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["PlasiyerID"]))" />
                        </div>
                    </div>
                </div>
                <div class="d-flex mt-5">

                    <div class="col-6  pe-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label"> AnaCariID </label>
                            <input type="text" name="AnaCariID" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["AnaCariID"]))" />
                        </div>
                    </div>
                    <div class="col-6 ps-3">
                        <div class="form-group">
                            <label for="exampleFormControlInput1" class="required form-label">TeslimCariID</label>
                            <input type="text" name="TeslimCariID" class="form-control form-control-solid" placeholder="" value="@(Convert.ToString(Model.Rows[0]["TeslimCariID"]))" />
                        </div>
                    </div>
                </div>
            </div>


            <div class="col-lg-6 gap-3">
                <div class="flex flex-col">
                    <h4>İletişim Bilgileri</h4>
                    <div class="d-flex mt-5">
                        <div class="col-6 pe-3">
                            <div class="form-group ">
                                <label for="floatingInput" class="form-label required">Telefon 1</label>
                                <input type="text" name="Telefon1" class="form-control form-control-solid" id="floatingInput" value="@(Convert.ToString(Model.Rows[0]["Telefon1"]))" />
                            </div>
                        </div>
                        <div class="col-6 ps-3">
                            <div class="form-group">
                                <label for="floatingInput" class="form-label">Telefon 2</label>
                                <input type="text" name="Telefon2" class="form-control form-control-solid" id="floatingInput" value="@(Convert.ToString(Model.Rows[0]["Telefon2"]))" />
                            </div>
                        </div>
                    </div>
                    <div class="d-flex mt-5">
                        <div class="col-6 pe-3">
                            <div class="form-group">
                                <label for="floatingInput" class="form-label">Faks</label>
                                <input type="text" name="Faks" class="form-control form-control-solid" id="floatingInput" value="@(Convert.ToString(Model.Rows[0]["Faks"]))" />
                            </div>
                        </div>
                        <div class="col-6 ps-3">
                            <div class="form-group">
                                <label for="floatingInput" class="form-label required">Cep Telefonu</label>
                                <input type="text" name="CepTelefonu" class="form-control form-control-solid" id="floatingInput" value="@(Convert.ToString(Model.Rows[0]["CepTelefonu"]))" />
                            </div>
                        </div>
                    </div>
                    <div class="d-flex mt-5">
                        <div class="col-6 pe-3">
                            <div class="form-group">
                                <label for="floatingInput" class="form-label required">Email</label>
                                <input type="text" name="EMail" class="form-control form-control-solid" id="floatingInput" value="@(Convert.ToString(Model.Rows[0]["EMail"]))" />
                            </div>
                        </div>
                        <div class="col-6 ps-3">
                            <div class="form-group">
                                <label for="floatingInput" class="form-label">Web Sitesi</label>
                                <input type="text" name="WebSite" class="form-control form-control-solid" id="floatingInput" value="@(Convert.ToString(Model.Rows[0]["WebSite"]))" />
                            </div>
                        </div>
                    </div>
                </div>


                <div class="flex-center flex-col mt-8">
                    <h4>Grup Kodları</h4>
                    <div class="d-flex">
                        <div class="col-6 pe-3 ">
                            <div class="form-group">
                                <label for="floatingSelect" class="form-label">Grup Kodu 1</label>
                                <select class="form-select form-select-solid" name="GrupKodu1ID" id="floatingSelect"
                                        aria-label="Floating label select example">
                                    <option value="">Lütfen Seçim Yapınız</option>
                                    @foreach (var cariGrupKodlari1 in ViewBag.CariGrupKodlari1)
                                    {
                                        <option @(Convert.ToString(Model.Rows[0]["GrupKodu1ID"]) == cariGrupKodlari1.Key ? "checked" : "") value="@cariGrupKodlari1.Key">@cariGrupKodlari1.Value</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-6 ps-3 ">
                            <div class="form-group">
                                <label for="floatingSelect" class="form-label">Grup Kodu 2</label>
                                <select class="form-select form-select-solid" name="GrupKodu2ID" id="floatingSelect"
                                        aria-label="Floating label select example">
                                    <option value="">Lütfen Seçim Yapınız</option>
                                    @foreach (var cariGrupKodlari2 in ViewBag.CariGrupKodlari2)
                                    {
                                        <option @(Convert.ToString(Model.Rows[0]["GrupKodu2ID"]) == cariGrupKodlari2.Key ? "checked" : "") value="@cariGrupKodlari2.Key">@cariGrupKodlari2.Value</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex mt-5">
                        <div class="col-6 pe-3 ">
                            <div class="form-group">
                                <label for="floatingSelect" class="form-label">Grup Kodu 3</label>
                                <select class="form-select form-select-solid" name="GrupKodu3ID" id="floatingSelect"
                                        aria-label="Floating label select example">
                                    <option value="">Lütfen Seçim Yapınız</option>

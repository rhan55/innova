                                                <input type="text" step="0.01" id="TCKimlikNo" name="TCKimlikNo" class="form-control p-2 rounded-1" value="@(Convert.ToString(Model.Rows[0]["TCKimlikNo"]))" placeholder="" />
                                                <div data-error="TCKimlikNo"></div>
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="VergiNumarasi" class=" form-label">Vergi Numarası</label>
                                                <input type="text" id="VergiNumarasi" name="VergiNumarasi" class="form-control  p-2 rounded-1" value="@(Convert.ToString(Model.Rows[0]["VergiNumarasi"]))" placeholder="" maxlength="11" />

                                            <div class="form-group">
                                                <label for="RiskAciklama" class=" form-label ">Risk Açıklama</label>
                                                <input type="text" id="RiskAciklama" name="RiskAciklama" class="form-control p-2 rounded-1" placeholder="" value="@(Convert.ToString(Model.Rows[0]["RiskAciklama"]))" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mt-4">
                                        <div class="col-lg-4  mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="PlasiyerID" class=" form-label">Plasiyer</label>
                                                <select class="form-select form-select-solid p-2 rounded-1" data-control="select2" name="PlasiyerID" id="PlasiyerID"
                                                        aria-label="Floating label select example">
                                                    <option value="">Lütfen Seçim Yapınız</option>
                                                    @foreach (SatisPersoneliDto plasiyer in ViewBag.PlasiyerID)
                                                    {
                                                        <option @(Convert.ToString(Model.Rows[0]["PlasiyerID"]) == plasiyer.ID ? "selected" : "") value="@plasiyer.ID">@plasiyer.Isim</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-lg-4 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="AnaCariID" class=" form-label">Ana Cari</label>
                                                <select class="form-select form-select-solid p-2 rounded-1" name="AnaCariID" id="AnaCariID"
                                                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                                    @if (ViewBag.AnaCari != null)
                                                    {
                                                        <option value="@ViewBag.AnaCari.ID" selected>@ViewBag.AnaCari.Isim</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-lg-4 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="exampleFormControlInput1" class=" form-label">Teslim Cari</label>
                                                <select class="form-select form-select-solid p-2 rounded-1" name="TeslimCariID" id="TeslimCariID"
                                                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                                    @if (ViewBag.TeslimCari != null)
                                                    {
                                                        <option value="@ViewBag.TeslimCari.ID" selected>@ViewBag.TeslimCari.Isim</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="row mt-4">
                                        <div class="col-lg-3">
                                            <div class="form-group ">
                                                <label for="Telefon1" class="form-label">Telefon 1</label>
                                                <input type="text" name="Telefon1" class="form-control p-2 rounded-1" id="Telefon1" value="@(Convert.ToString(Model.Rows[0]["Telefon1"]))" />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="Telefon2" class="form-label">Telefon 2</label>
                                                <input type="text" name="Telefon2" class="form-control p-2 rounded-1" id="Telefon2" value="@(Convert.ToString(Model.Rows[0]["Telefon2"]))" />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="Faks" class="form-label">Faks</label>
                                                <input type="text" name="Faks" class="form-control p-2 rounded-1" id="Faks" value="@(Convert.ToString(Model.Rows[0]["Faks"]))" />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="CepTelefonu" class="form-label">Cep Telefonu</label>
                                                <input type="text" name="CepTelefonu" class="form-control p-2 rounded-1" id="CepTelefonu" value="@(Convert.ToString(Model.Rows[0]["CepTelefonu"]))" />
                                            </div>
                                        </div>
                                    </div>

                                                <label for="DovizID" class=" form-label">Döviz</label>
                                                <input id="DovizID" type="text" name="DovizID" class="form-control  p-2 rounded-1" value="@(Convert.ToString(Model.Rows[0]["DovizID"]))" placeholder="" />
                                            </div>
                                        </div>
                                        <div class="col-lg-3 mt-4 mt-lg-0">
                                            <div class="form-group">
                                                <label for="VadeGunu" class=" form-label">Vade Günü</label>
                                                <input id="VadeGunu" type="text" name="VadeGunu" class="form-control p-2 rounded-1" value="@(Convert.ToString(Model.Rows[0]["VadeGunu"]))" placeholder="" />
                                            </div>
                                        </div>

@using YKPortal.Models.Dto
@model System.Data.DataTable
@{
    ViewBag.Title = "Kişi Düzenle";
    Layout = "~/Views/Shared/_LayoutTab.cshtml";
}

<div class="container-fluid">
    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })

        <div class="col-lg-10">
            <!--begin::Form-->
            <form id="kt_modal_add_user_form" class="form" action="@Url.Action("KisiDuzenle","Cari",null)" method="post" enctype="multipart/form-data">

                <input type="hidden" name="ID" value="@ViewBag.ID" />
                <input type="hidden" name="CariID" value="@ViewBag.CariID" />
                <!--begin::Scroll-->
                <div class="d-flex flex-column scroll-y px-5 px-lg-10 container mt-10">

                    <!--begin::Row Input group-->
                    <div class="row mb-7">
                        <!--begin::Input group-->
                        <div class="col-lg-6">
                            <!--begin::Label-->
                            <label for="Isim" class="fw-semibold fs-6 mb-2">İsim</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" id="Isim" name="Isim" class="form-control  mb-3 mb-lg-0" value="@(Convert.ToString(Model.Rows[0]["Isim"]))" />

                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6">
                            <!--begin::Label-->
                            <label for="Email " class=" fw-semibold fs-6 mb-2">Email</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="email" name="Email" id="Email" class="form-control  mb-3 mb-lg-0" placeholder="Email " value="@(Convert.ToString(Model.Rows[0]["Email"]))" />
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                    </div>
                    <!--begin::Row Input group-->
                    <!--begin::Row Input group-->
                    <div class="row mb-7">
                        <!--begin::Input group-->
                        <div class="col-lg-6">
                            <div>
                                <!--begin::Label-->
                                <label for="Gorev" class="fw-semibold fs-6 mb-2">Görev</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" name="Gorev" id="Gorev" class="form-control  mb-3 mb-lg-0" placeholder="Gorev" value="@(Convert.ToString(Model.Rows[0]["Gorev"]))" />
                                <!--end::Input-->
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div>
                                <!--begin::Label-->
                                <label for="Telefon" class="fw-semibold fs-6 mb-2">Telefon</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" name="Telefon" id="Telefon" class="form-control  mb-3 mb-lg-0" placeholder="Telefon" value="@(Convert.ToString(Model.Rows[0]["Telefon"]))" />
                                <!--end::Input-->
                            </div>
                        </div>

                    </div>
                    <!--begin::Row Input group-->
                    <!--begin::Row Input group-->
                    <div class="row mb-7">
                        <!--begin::Input group-->
                        <div class="col-lg-12">
                            <div class="form-check">
                                <input class="form-check-input" name="Aktif" type="checkbox" value="true" id="Aktif" @(Convert.ToBoolean(Model.Rows[0]["Aktif"]) ? "checked" : "") />
                                <label class="form-check-label user-select-none cursor-pointer" for="Aktif">
                                    Aktif
                                </label>
                            </div>
                        </div>
                        <!--end::Input group-->
                    </div>


                    <!--end::Scroll-->
                    <!--begin::Actions-->
                    <div class="pt-10">
                        <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                        <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Duzenle">
                            <span class="indicator-label">Düzenle</span>

                        </button>
                    </div>
                    <!--end::Actions-->
                </div>
            </form>
            <!--end::Form-->
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {

            Inputmask({
                "mask": "(999) 999-9999"
            }).mask("#Telefon");

        });

    </script>
}

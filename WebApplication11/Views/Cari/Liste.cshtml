@model System.Data.DataTable
@{
    ViewBag.Title = "Cari Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container">
    <div class="row p-0 m-0">

        <div class="col-lg-12 pl-0">
            <div class="content d-flex justify-center flex-column flex-column-fluid" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container" class="container-xxl">
                        <div class="card card-flush">
                            <div class="card-header align-items-center py-5 gap-2 gap-md-5 p-8">

                                <div class="card-title">
                                    <!--begin::Export buttons-->
                                    <div id="kt_datatable_example_1_export" class="d-none"></div>
                                    <!--end::Export buttons-->
                                </div>
                                <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                                    <!--begin::Detaylı Arama-->
                                    <!--end::Detaylı Arama-->
                                    <button type="button" class="btn btn-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        Dışarı aktar
                                    </button>
                                    <!--begin::Menu-->
                                    <a class="btn btn-primary" href="/Cari/ExcelIceAktar">
                                        Excel içe aktar
                                        
                                    </a>
                                    <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px py-4" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="copy">
                                                Panoya Kopyala
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="excel">
                                                Excel olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="csv">
                                                CSV olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="pdf">
                                                PDF olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                    <!--end::Export dropdown-->
                                    <!--begin::Hide default export buttons-->
                                    <div id="kt_datatable_example_buttons" class="d-none"></div>
                                    <!--end::Hide default export buttons-->
                                    <a href="/Cari/Ekle" class="btn btn-primary">
                                        <i class="ki-duotone ki-plus fs-2"></i>Cari Ekle
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 ">
                            <div class="card card-flush ">
                                <div class="card-body">
                                    <!--begin::Filtreleme alanı-->
                                    <form method="POST" action="" class="p-8 content" id="datatableFilters">
                                        <div><h3 class="text-active-gray-600 fw-bold mb-4">Filtreler</h3></div>

                                        <div class="row">
                                            <div class="col-lg-3">
                                                <!--begin::Label-->
                                                <label for="Kod" class="fw-semibold fs-6 mb-2">Kod</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" name="Kod" id="Kod" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" placeholder="Kod" value="@(ViewBag.Filters.Kod)" />
                                                <!--end::Input-->
                                            </div>
                                            <div class="col-lg-3">
                                                <!--begin::Label-->
                                                <label for="Isim" class="fw-semibold fs-6 mb-2">Kısa İsim</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" name="Isim" id="Isim" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.Isim)" />
                                                <!--end::Input-->
                                            </div>
                                            <div class="col-lg-3">
                                                <!--begin::Label-->
                                                <label for="Unvan" class="fw-semibold fs-6 mb-2">Ünvan</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" name="Unvan" id="Unvan" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.Unvan)" />
                                                <!--end::Input-->
                                            </div>
                                            <div class="col-lg-3">
                                                <!--begin::Label-->
                                                <label for="VergiNumarasi" class="fw-semibold fs-6 mb-2">VergiNumarasi</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" name="VergiNumarasi" id="VergiNumarasi" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.VergiNumarasi)" />
                                                <!--end::Input-->
                                            </div>

                                        </div>
                                        <div class="row mt-2">

                                            <div class="col-lg-3">
                                                <!--begin::Label-->
                                                <label for="TCKimlikNo" class="fw-semibold fs-6 mb-2">TCKimlikNo</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" name="TCKimlikNo" id="TCKimlikNo" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.TCKimlikNo)" />
                                                <!--end::Input-->
                                            </div>
                                            <div class="col-lg-3">
                                                <!--begin::Label-->
                                                <label for="GrupKodu2ID" class="fw-semibold fs-6 mb-2">Cep Telefonu</label>
                                                <!--end::Label-->
                                                <!--begin::Input-->
                                                <input type="text" name="CepTelefonu" id="CepTelefonu" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.CepTelefonu)" />
                                                <!--end::Input-->
                                            </div>
                                            <div class="col-lg-3 ">

                                            </div>
                                            <div class="col-lg-3 d-flex justify-content-end align-items-end">
                                                <button type="button" id="filtreleriTemizle" class="btn btn-light me-3 h-40px" data-kt-users-modal-action="cancel">Temizle</button>
                                                <button type="submit" class="btn btn-primary h-40px" data-kt-users-modal-action="Ara">
                                                    <span class="indicator-label">Filtrele</span>                                                 
                                                </button>
                                            </div>
                                        </div>

                                    </form>
                                    <!--end::Filtreleme alanı-->
                                </div>
                            </div>
                        </div>
                        <div class="card-body  mt-10">
                            <table class="table align-middle border rounded table-row-dashed fs-6 g-5 p-8" id="Cari-datatable">
                                <thead>
                                
                                    <!--begin::Table row-->
                                    <tr class="text-start" style="font-size:15px;">
                                        <th id="select" class="min-w-125px no-export"></th>
                                        <th class="min-w-125px no-export"><strong>İsim</strong></th>
                                        <th class="min-w-125px"><strong>Cari İsmi</strong></th>
                                        <th class="min-w-125px"><strong>Cari Kodu</strong></th>
                                        <th class="min-w-125px mt-8"><strong>Cep Telefonu</strong></th>
                                        <th class="min-w-125px mt-8"><strong>GrupKodu1</strong></th>
                                        <th class="min-w-125px"><strong>GrupKodu2</strong></th>
                                        <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                                        <th class="text-end min-w-100px no-export"><strong>ID</strong></th>
                                    </tr>
                                    <!--end::Table row-->
                                </thead>
                                <tbody class="text-gray-600 fw-semibold">
                                    @for (var i = 0; i < Model.Rows.Count; i++)
                                    {
                                        <tr>
                                            <td class="pt-4 pb-4">
                                            </td>

                                            <td class="pt-4 pb-4">
                                                @(Convert.ToString(Model.Rows[i]["Kod"])) <br />
                                                <strong> @(Convert.ToString(Model.Rows[i]["Isim"])) </strong>
                                            </td>
                                            <td class="pt-4 pb-4">
                                                @(Convert.ToString(Model.Rows[i]["Isim"]))
                                            </td>
                                            <td class="pt-4 pb-4">
                                               @(Convert.ToString(Model.Rows[i]["Kod"]))
                                            </td>
                                            <td class="pt-4 pb-4">
                                                @(Convert.ToString(Model.Rows[i]["CepTelefonu"]))
                                            </td>
                                            <td class="pt-4 pb-4">
                                                @(Convert.ToString(Model.Rows[i]["GrupKoduAdi1"]))
                                            </td>
                                            <td class="pt-4 pb-4">
                                                @(Convert.ToString(Model.Rows[i]["GrupKoduAdi2"]))
                                            </td>
                                            <td class="text-end pt-4 pb-4">
                                                <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                    İşlemler
                                                    <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                                </a>
                                                <!--begin::Menu-->
                                                <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-4" data-kt-menu="true">
                                                    <!--begin::Menu item-->
                                                    <div class="menu-item px-3">
                                                        <a href="/Cari/Duzenle/@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link px-3">Düzenle</a>
                                                    </div>
                                                    <!--end::Menu item-->
                                                    <!--begin::Menu item-->
                                                    <div class="menu-item px-3">
                                                        <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link px-3 btn-sil" id="cari-silme" data-bs-toggle="modal" data-bs-target="#Cari-silme">
                                                            Sil
                                                        </button>
                                                    </div>
                                                    <!--end::Menu item-->
                                                    <!--begin::Menu item-->
                                                    <div class="menu-item px-3">
                                                        <a href="/Cari/KisiListe?CariID=@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link px-3">Kişiler</a>
                                                    </div>
                                                    <!--end::Menu item-->
                                                    <!--begin::Menu item-->
                                                    <div class="menu-item px-3">
                                                        <a href="/Cari/NotListe?CariID=@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link px-3">Notlar</a>
                                                    </div>
                                                    <div class="menu-item px-3">
                                                        <a href="/Dosya/Liste?Modul=Cari&KayitID=@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link px-3">Dosyalar</a>
                                                    </div>
                                                    <!--end::Menu item-->

                                                </div>
                                                <!--end::Menu-->
                                            </td>
                                            <td>@(Convert.ToString(Model.Rows[i]["ID"]))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <!--end::Container-->
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="Cari-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Cari Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Cariyi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("Sil","Cari",null)">
                    <input type="hidden" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    //Toplu silme için biz seçimlerin id leerini alıp çalışan metodumuzda forech ile bu id lerğ dönüp ssilecez
    //yani 10 tane kayıt seçilmiş ise 10 id yi metodumuzds forech ile dönüpmteker teker silecez
     //Listeleme için ek birşey yapmamıza gerek yok ekrandaki otomatik sayfalama işimizi çözer
    // ben arkaplanda zaten arama sonucunun ilk 100 veya 200 tanesini döndürüyorum

        var select = document.querySelectorAll("#select")


        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                });
            });

            const filtreleriTemizle = document.querySelector("#filtreleriTemizle");

            if (filtreleriTemizle) {

                filtreleriTemizle.addEventListener("click", function (e) {
                    e.preventDefault();
                    document.querySelector("form#datatableFilters").querySelectorAll("input").forEach(input => {
                        input.value = ""
                    })
                    document.querySelector("form#datatableFilters").submit();
                });
            }
        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    "info": false,
                    caching: true,
                    select:true,
                    order: [
                        [2, "asc"],
                    ],
                    ordering: true,
                    paging: true,
                    pageLength: 10,
                    lengthMenu: [
                        [10, 20, 50, 100, -1],
                        ['10 Adet', '20 Adet', '50 Adet', '100 Adet', "Tümü"]
                    ],

                    language: { url: '//cdn.datatables.net/plug-ins/2.0.7/i18n/tr.json', },

                    columnDefs: [
                        {
                            targets: [0, 7],
                            orderable: false
                        },
                        {
                            render: DataTable.render.select(),
                            targets: 0,
                            width: "40px"
                        },
                        {
                            targets: [2, 3, 8],
                            visible: false
                        }

                    ],
                  
                    order: [[1, 'asc']]


                });


            }


            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Cari-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()


            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#Cari-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();

                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();

        });
    </script>
}

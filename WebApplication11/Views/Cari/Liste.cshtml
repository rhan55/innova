@model YKPortal.Models.Dto.CariListeViewModel
@{
    ViewBag.Title = "Cari Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container-fluid p-0">
    <div class="row p-0 m-0">
        <div class="col-lg-12 p-0">
            <div class="content d-flex justify-center flex-column flex-column-fluid p-0" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container" class="container-fluid p-0 m-0">
                        <div class="card card-flush border-0 shadow-none m-0 p-0">
                            <div class="card-header align-items-center border-0 shadow-0 gap-2 gap-md-5 p-0 m-0">

                                <div class="card-title">
                                    <!--begin::Export buttons-->
                                    <div id="kt_datatable_example_1_export" class="d-none"></div>
                                    <!--end::Export buttons-->
                                </div>
                                <div class="card-toolbar flex-row-fluid justify-content-end gap-3">
                                    <button type="button" id="topluSilButon" class="btn btn-light-primary btn-sm fw-bold" onclick="$('#DivFiltre').toggle();">
                                        <span class="indicator-label fw-bold">Filtre</span>
                                        <i class="ki-duotone ki-filter">
                                            <span class="path1"></span>
                                            <span class="path2"></span>
                                        </i>
                                    </button>
                                    <div>
                                        <button type="button" id="topluSilButon" class="btn btn-light-primary btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#Cari-toplu-silme">
                                            <span class="indicator-label fw-bold">Toplu Sil</span>
                                        </button>
                                    </div>
                                    <button type="button" class="btn btn-light-primary btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        Dışarı aktar
                                    </button>
                                    <!--begin::Menu-->
                                    <a class="btn btn-primary btn-sm fw-bold" href="/Cari/ExcelIceAktar">
                                        Excel içe aktar

                                    </a>
                                    <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link py-0  px-2" data-kt-export="copy">
                                                Panoya Kopyala
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item  p-0">
                                            <a href="#" class="menu-link py-0  px-2" data-kt-export="excel">
                                                Excel olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item  p-0">
                                            <a href="#" class="menu-link py-0  px-2" data-kt-export="csv">
                                                CSV olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item  p-0">
                                            <a href="#" class="menu-link py-0  px-2" data-kt-export="pdf">
                                                PDF olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                    <!--end::Export dropdown-->
                                    <!--begin::Hide default export buttons-->
                                    <div id="kt_datatable_example_buttons" class="d-none"></div>
                                    <!--end::Hide default export buttons-->
                                    <a href="/Cari/Ekle" class="btn btn-primary btn-sm fw-bold me-4">
                                        <i class="ki-duotone ki-plus fs-2"></i>Cari Ekle
                                    </a>
                                </div>
                            </div>
                        </div>

                        <div>
                            <div class="container-fluid" id="DivFiltre" name="DivFiltre" style="display:none;">
                                <div class="card border-0 shadow-none">
                                    <div class="card-body">
                                        <!--begin::Filtreleme alanı-->
                                        <form method="POST" action="/Cari/Liste" class="content p-0" id="datatableFilters">
                                            <div class="d-flex">
                                                <h3 class="text-gray-600 fw-bold mb-4">Filtreler</h3>
                                                <i class="ki-duotone ki-filter-search fs-2">
                                                    <span class="path1"></span>
                                                    <span class="path2"></span>
                                                    <span class="path3"></span>
                                                </i>
                                            </div>

                                            <div class="row">
                                                <div class="col-lg-3">
                                                    <!--begin::Label-->
                                                    <label for="Kod" class="fw-bold fs-6 mb-2 text-gray-600">Kod</label>
                                                    <!--end::Label-->
                                                    <!--begin::Input-->

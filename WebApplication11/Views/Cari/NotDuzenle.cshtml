
@{
    ViewBag.Title = "Not Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid" id="kt_content">
    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })

        <!--begin::Post-->
        <div class="col-lg-10" id="kt_post">
            <!--begin::Form-->
            <form id="kt_modal_add_user_form" class="form" action="@Url.Action("NotDuzenle","Cari",null)" method="post" enctype="multipart/form-data">
                <!--begin::Scroll-->
                <div class="d-flex flex-column scroll-y px-5 px-lg-10 container mt-10">
                    <input type="hidden" name="CariID" value="@ViewBag.CariID" />
                    <input type="hidden" name="ID" value="@ViewBag.ID" />
                    <!--begin::Row Input group-->
                    <div class="row mb-12">
                        <!--begin::Input group-->
                        <div class="col-lg-6">
                            <!--begin::Label-->
                            <label for="Aciklama" class="fw-bold text-gray-800 fs-6 mb-2">Not</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <textarea type="text" id="Aciklama" name="Aciklama" class="form-control" placeholder="Notunuzu Yazınız...">@(Convert.ToString(Model.Rows[0]["Aciklama"]))</textarea>
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                    </div>
                    <!--begin::Actions-->
                    <div class="pt-5">
                        <a href="/Cari/NotListe?CariID=@ViewBag.CariID" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Geri</a>
                        <button type="submit" class="btn btn-primary" data-kt-users-modal-action="Duzenle">
                            <span class="indicator-label">Düzenle</span>
                            <span class="indicator-progress">
                                Lütfen Bekleyin...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                    <!--end::Actions-->
                </div>
            </form>
            <!--end::Form-->
        </div>
    </div>
</div>
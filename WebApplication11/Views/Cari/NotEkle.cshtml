
@{
    ViewBag.Title = "Not Ekle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })


        <div class="col-lg-10">
            <!--begin::Form-->
            <form id="kt_modal_add_user_form" class="form" action="@Url.Action("NotEkle","Cari",null)" method="post" enctype="multipart/form-data">

                @if (Model != null)
                {
                    if (Model.Rows.Count > 0)
                    {
                        string ID = Convert.ToString(Model.Rows[0]["ID"]);
                        string Bilgi = Convert.ToString(Model.Rows[0]["Bilgi"]);
                        if (ID == "0")
                        {
                            <!--begin::Alert-->
                            <div class="alert alert-danger d-flex align-items-center p-5">
                                <!--begin::Icon-->
                                <i class="ki-duotone ki-shield-tick fs-2hx text-danger me-4"><span class="path1"></span><span class="path2"></span></i>
                                <!--end::Icon-->
                                <!--begin::Wrapper-->
                                <div class="d-flex flex-column">
                                    <!--begin::Content-->
                                    <span>@Bilgi</span>
                                    <!--end::Content-->
                                </div>
                                <!--end::Wrapper-->
                            </div>
                            <!--end::Alert-->
                        }
                    }
                }

                <!--begin::Scroll-->
                <div class="d-flex flex-column scroll-y px-5 px-lg-10 container mt-10">
                    <input type="hidden" name="CariID" value="@ViewBag.CariID" />
                    <input type="hidden" name="ID" value="@ViewBag.CariID" />
                    <!--begin::Row Input group-->
                    <div class="row">
                        <!--begin::Input group-->
                        <div class="col-lg-6">
                            <!--begin::Label-->
                            <label for="Aciklama" class="fw-bold text-gray-800 fs-6 mb-2">Not</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <textarea type="text" id="Aciklama" name="Aciklama" class="form-control" placeholder="Notunuzu Yazınız..."></textarea>
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                    </div>
                    <!--begin::Actions-->
                    <div class="pt-10">
                        <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                        <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Kaydet">
                            <span class="indicator-label">Kaydet</span>
                            <span class="indicator-progress">
                                Lütfen Bekleyin...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                    <!--end::Actions-->
                </div>
            </form>
            <!--end::Form-->
        </div>

    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/Tema/plugins/custom/tinymce/tinymce.bundle.js"></script>

    <script>

        $(document).ready(function () {

            var AciklamaEditorOptions = { selector: "#Aciklama", height: 200 };

            if (KTThemeMode.getMode() === "dark") {
                AciklamaEditorOptions["skin"] = "oxide-dark";
                AciklamaEditorOptions["content_css"] = "dark";
            }

            tinymce.init(AciklamaEditorOptions);

        });

    </script>

}


@{
    ViewBag.Title = "Kişi Listesi";
    Layout = "~/Views/Shared/_LayoutTab.cshtml";
}
<div class="container-fluid p-0 m-0">
    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })

        <div class="col-lg-10">
            <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid overflow-hidden" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container p-0" class="container-fluid p-0 m-0">
                        <div class="card card-flush">
                            <div class="card-header align-items-center py-5 gap-2 gap-md-5 px-4">
                                <div class="card-title">
                                    <!--begin::Search-->
                                    <div class="d-flex align-items-center position-relative my-1">
                                        <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                                            <span class="path1 text-gray-500"></span>
                                            <span class="path2 text-gray-500"></span>
                                        </i>
                                        <input type="text" data-kt-filter="search" class="form-control  w-250px py-1 ps-14" placeholder="Kişi Ara" />
                                    </div>
                                    <!--end::Search-->
                                    <!--begin::Export buttons-->
                                    <div id="kt_datatable_example_1_export" class="d-none"></div>
                                    <!--end::Export buttons-->
                                </div>
                                <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                                    <!--begin::Export dropdown-->
                                    <button type="button" class="btn btn-light-primary btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        Dışarı aktar
                                    </button>
                                    <!--begin::Menu-->
                                    <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px p-0" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link px-2 py-0" data-kt-export="copy">
                                                Panoya Kopyala
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link px-2 py-0" data-kt-export="excel">
                                                Excel olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link px-2 py-0" data-kt-export="csv">
                                                CSV olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link px-2 py-0" data-kt-export="pdf">
                                                PDF olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                    <!--end::Export dropdown-->
                                    <!--begin::Hide default export buttons-->
                                    <div id="kt_datatable_example_buttons" class="d-none"></div>
                                    <!--end::Hide default export buttons-->
                                    <a href="/Cari/KisiEkle?CariID=@(ViewBag.CariID)" class="btn btn-primary btn-sm">
                                        <i class="ki-duotone ki-plus fs-2"></i>Kişi Ekle
                                    </a>
                                </div>
                            </div>

                            <div class="card-body px-4 scroll-x">
                                <table class="table align-middle rounded-0 table-row-dashed  fs-6 g-5" id="Cari-Kisi-datatable">
                                    <thead>
                                        <!--begin::Table row-->
                                        <tr class="text-start" style="font-size:15px;">
                                            <th class="min-w-125px"><strong>İsim</strong></th>
                                            <th class="min-w-125px"><strong>Email </strong></th>
                                            <th class="min-w-125px"><strong>Görev</strong></th>
                                            <th class="min-w-125px"><strong>Telefon</strong></th>
                                            <th class="min-w-125px"><strong>Aktif</strong></th>
                                            <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>

                                        </tr>
                                        <!--end::Table row-->
                                    </thead>
                                    <tbody class="text-gray-600 fw-semibold">
                                        @for (var i = 0; i < Model.Kisiler.Rows.Count; i++)
                                        {
                                            <tr>


                                                <td>
                                                    @(Convert.ToString(Model.Kisiler.Rows[i]["Isim"]))
                                                </td>
                                                <td>
                                                    @(Convert.ToString(Model.Kisiler.Rows[i]["Email"]))
                                                </td>
                                                <td>
                                                    @(Convert.ToString(Model.Kisiler.Rows[i]["Gorev"]))
                                                </td>
                                                <td>@(Convert.ToString(Model.Kisiler.Rows[i]["Telefon"]))</td>
                                                <td>@(Convert.ToBoolean(Model.Kisiler.Rows[i]["Aktif"]) ? "Aktif" : "Pasif") </td>
                                                <td class="text-end">
                                                    <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                        İşlemler
                                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                                    </a>
                                                    <!--begin::Menu-->
                                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <a href="/Cari/KisiDuzenle?ID=@(Convert.ToString(Model.Kisiler.Rows[i]["ID"]))&CariID=@(Convert.ToString(Model.Kisiler.Rows[i]["CariID"]))" class="menu-link rounded-0 px-2 py-0">Düzenle</a>
                                                        </div>
                                                        <!--end::Menu item-->
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <button type="button" data-id="@(Convert.ToString(Model.Kisiler.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link rounded-0 px-2 py-0 btn-sil" data-bs-toggle="modal" data-bs-target="#cari-silme">
                                                                Sil
                                                            </button>

                                                        </div>
                                                        <!--end::Menu item-->
                                                    </div>
                                                    <!--end::Menu-->
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
                <!--end::Post-->
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="cari-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Kişi Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Kişiyi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("KisiSil","Cari",null)">
                    <input type="hidden" name="id" value="" />
                    <input type="hidden" name="CariID" value="@ViewBag.CariID" />
                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                })
            });


        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    "info": false,

                    'order': [],
                    paging: false,
                    columnDefs: [
                        {
                            target: 1,
                            visible: false
                        },
                        {
                            target: 2,
                            visible: false
                        }
                    ]

                });

                datatable.on('columns-reordered', function (e, settings, details) {
                    KTMenu.createInstances();
                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Cari-Kisi-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#Cari-Kisi-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}



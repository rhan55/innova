@using YKPortal.Models.Dto
@{
    ViewBag.Title = "YeniCariHareketKaydi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">

    <div class="row">
        <div class="col-lg-12">
            <form id="kt_modal_add_user_form" class="form" action="@Url.Action("YeniCariHareketKaydi","Cari",null)" method="post">
                <div class="d-flex flex-column container px-5 px-lg-10 mt-10">
                    <div class="row mb-7">
                        <div class="col-lg-6 ">
                            <div class="form-group">
                                <label for="CariID" class=" form-label">Cari İsim</label>
                                <select class="form-control p-2 rounded-1" name="CariID" id="CariID"
                                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="form-group">
                                <label for="BelgeNo" class="fw-semibold fs-6 mb-2">Belge No</label>
                                <input type="text" name="BelgeNo" id="BelgeNo" class="form-control p-2 mb-3 mb-lg-0" required" />
                            </div>
                        </div>
                  
                    </div>

                    <div class="row mb-7">

                        <div class="col-lg-3">

                            <div class="form-group">
                                <label for="HareketTipi" class="fw-semibold fs-6 mb-2">Hareket Tipi/Türü</label>
                                <select class="form-control p-2 rounded-1" data-control="select2" name="HareketTipi" id="HareketTipi"
                                        aria-label="Floating label select example">
                                    <option value="">Lütfen Seçim Yapınız</option>
                                    @foreach (GrupKoduDto cariGrupKodlari5 in ViewBag.CariHareketTipleri)
                                    {
                                        <option value="@cariGrupKodlari5.Deger">@cariGrupKodlari5.Deger</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-lg-3 mt-10">
                            <div class="flex">
                                <label class="form-label flex items-center gap-2.5 text-nowrap me-4">
                                    <input class="form-check-input" name="GC" type="radio" value="G" checked />
                                    Borç
                                </label>
                                <label class="form-label flex items-center gap-2.5 text-nowrap">
                                    <input class="form-check-input " name="GC" type="radio" value="C" />
                                    Alacak
                                </label>
                            </div>

                        </div>
                        <div class="col-lg-3">
                            <div class="form-group">
                                <label for="Tutar" class="fw-semibold fs-6 mb-2">Tutar</label>
                                <input type="text" name="Tutar" id="Tutar" class="form-control p-2 mb-3 mb-lg-0" autofocus required />
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="form-group">
                                <label for="DovizTipi" class="fw-semibold fs-6 mb-2">Döviz Birimi</label>
                                <select class="form-control p-2 rounded-1" data-control="select2" name="DovizTipi" id="DovizTipi" required
                                        aria-label="Floating label select example">
                                    <option value="">Lütfen Seçim Yapınız</option>
                                    @foreach (GrupKoduDto grupKodu in ViewBag.DovizBirimleri)
                                    {
                                        <option value="@grupKodu.Deger">@grupKodu.Deger</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row mb-7">
                        <div class="col-lg-6">
                            <div class="form-group">
                                <label for="Tarih" class="fw-semibold fs-6 mb-2">Tarih</label>
                                <input type="date" name="Tarih" class="form-control p-2 mb-3 mb-lg-0" required" />
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="form-group">
                                <label for="VadeTarihi" class="fw-semibold fs-6 mb-2">Vade Tarihi</label>
                                <input type="date" name="VadeTarihi" id="VadeTarihi" class="form-control p-2 mb-3 mb-lg-0" required" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-lg-12">
                            <div class="form-group">
                                <label for="Aciklama" class=" form-label ">Açıklama</label>
                                <textarea type="text" name="Aciklama" class="form-control p-2 rounded-1" id="Aciklama"></textarea>
                            </div>
                        </div>
                    </div>

                    <!--begin::Actions-->
                    <div class="pt-10">
                        <a href="/Cari/Liste" class="btn btn-light btn-sm fw-bold me-3" data-kt-users-modal-action="cancel">Geri</a>
                        <button type="submit" class="btn btn-primary btn-sm fw-bold" data-kt-users-modal-action="Kaydet">
                            <span class="indicator-label">Kaydet</span>
                        </button>
                        <button type="submit" class="btn btn-danger btn-sm fw-bold" data-kt-users-modal-action="Sil">
                            <span class="indicator-label">Sil</span>
                        </button>
                    </div>
                    <!--end::Actions-->
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts{
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            const cariIdSelect = $('#CariID').select2({
                ajax: {
                    url: "/Cari/SelectListe",
                    data: function (params) {
                        var query = {
                            search: params.term,
                        }

                        // Query parameters will be ?search=[term]&type=public
                        return query;
                    },
                    processResults: function (data) {
                        var results = [];
                        if (data && data.length > 0) {
                            data.forEach(function (item) {
                                results.push({ id: item.ID, text: item.Isim })
                            });
                        }

                        return {
                            results: results
                        };
                    },
                },
                delay: 250,
                minimumInputLength: 3,
                language: {
                    placeholder: function () {
                        return "Arama yapmak için en az 3 karakter girin";
                    },
                    inputTooShort: function () {
                        return "Lütfen en az 3 karakter girin";
                    }
                }
            });

            //Inputmask("999.999.999,99", {
            //    "numericInput": true
            //}).mask("#Tutar");
        });
    </script>
}

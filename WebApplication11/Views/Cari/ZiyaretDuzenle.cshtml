@using YKPortal.Models.Dto
@{
    ViewBag.Title = "Ziyaret Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">

    <div class="row">
        @Html.Partial("~/Views/Cari/_CariMenu.cshtml", new ViewDataDictionary { { "CariID", Convert.ToString(ViewBag.CariID) } })
        <div class="col-lg-10">
            <form id="kt_modal_add_user_form" class="form container" action="@Url.Action("ZiyaretDuzenle","Cari",null)" method="post">
                <div class="d-flex flex-column scroll-y px-5 px-lg-10 mt-10">
                    <input type="hidden" name="ID" value="@ViewBag.Ziyaret.ID" />
                    <input type="hidden" name="CariID" value="@ViewBag.CariID" />
                    <!--begin::Row Input group-->
                    <div class="row mb-7">
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="CariIsim" class="fw-semibold fs-6 mb-2">Cari Ismi</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" name="CariIsim" class="form-control p-2 mb-3 mb-lg-0" autofocus value="@ViewBag.Ziyaret.CariIsim" readonly />
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="Tarih" class="fw-semibold fs-6 mb-2">Tarih</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" readonly name="Tarih" class="form-control p-2 mb-3 mb-lg-0" value="@(ViewBag.Ziyaret.Tarih)" />

                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="Aciklama" class="fw-semibold fs-6 mb-2">Aciklama</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" name="Aciklama" class="form-control p-2 mb-3 mb-lg-0" autofocus value="@ViewBag.Ziyaret.Aciklama" />
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="ZiyaretTipi" class="fw-semibold fs-6 mb-2">Ziyaret Tipi</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <select type="text" name="ZiyaretTipi" class="form-select p-2 mb-3 mb-lg-0" value="@ViewBag.Ziyaret.Tarih">
                                @foreach (GrupKoduDto ziyaretTipi in ViewBag.ZiyaretTipleri)
                                {
                                    <option value="@ziyaretTipi.ID" @(ziyaretTipi.ID == ViewBag.Ziyaret.ZiyaretTipi ? "selected" : "")>@ziyaretTipi.Deger</option>
                                }
                            </select>
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="TamamlamaTarihi" class="fw-semibold fs-6 mb-2">Tamamlama Tarihi</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="datetime-local" name="TamamlamaTarihi" class="form-control p-2 mb-3 mb-lg-0" autofocus value="@(@ViewBag.Ziyaret.TamamlamaTarihi)" />

                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="TamamlamaAciklamasi" class="fw-semibold fs-6 mb-2">Tamamlama Aciklamasi</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" name="TamamlamaAciklamasi" class="form-control p-2 mb-3 mb-lg-0" autofocus value="@ViewBag.Ziyaret.TamamlamaAciklamasi" />

                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Input group-->
                        <div class="col-lg-6 mt-4">
                            <!--begin::Label-->
                            <label for="TamamlayanKullaniciID" class="fw-semibold fs-6 mb-2">Tamamlayan KullaniciID</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="text" name="TamamlayanKullaniciID" class="form-control p-2 mb-3 mb-lg-0" autofocus value="@ViewBag.Ziyaret.TamamlayanKullaniciID" />

                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <!--begin::Actions-->
                        <div class="pt-10">
                            <a href="/Cari/ZiyaretEkle" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Geri</a>
                            <button type="submit" class="btn btn-primary" data-kt-users-modal-action="ZiyaretDuzenle">
                                <span class="indicator-label">Kaydet</span>
                                <span class="indicator-progress">
                                    Lütfen Bekleyin...
                                    <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                                </span>
                            </button>
                        </div>
                        <!--end::Actions-->
                    </div>
                    <!--end::Row Input group-->

                </div>

            </form>
        </div>
    </div>
</div>




@model YKPortal.Models.Dto.KullaniciListeViewModel
@{
    ViewBag.Title = "Kullanıcı Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content container-fluid" id="kt_content">
    <!--begin::Post-->
    <div class="post" id="kt_post">
        <!--begin::Container-->
        <div id="kt_content_container" class="container-fluid">
            <div class="card">
                <div class="card-header border-0 shadow-none align-items-center gap-2 gap-md-5 px-4">
                    <div class="card-title">
                        <!--begin::Search-->
                        <div class="d-flex align-items-center position-relative my-1">
                            <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                                <span class="path1 text-gray-500"></span>
                                <span class="path2 text-gray-500"></span>
                            </i>
                            <input type="text" data-kt-filter="search" class="form-control  w-250px py-1 ps-14" placeholder="Kullanıcı Ara" />
                        </div>
                        <!--end::Search-->
                        <!--begin::Export buttons-->
                        <div id="kt_datatable_example_1_export" class="d-none"></div>
                        <!--end::Export buttons-->
                    </div>
                    <div class="card-toolbar flex-row-fluid justify-content-end gap-3">
                        <!--begin::Export dropdown-->
                        <button type="button" class="btn btn-light-primary btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                            <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                            Dışarı aktar
                        </button>
                        <!--begin::Menu-->
                        <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px" data-kt-menu="true">
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="copy">
                                    Panoya Kopyala
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="excel">
                                    Excel olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="csv">
                                    CSV olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="pdf">
                                    PDF olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                        </div>
                        <!--end::Menu-->
                        <!--end::Export dropdown-->
                        <!--begin::Hide default export buttons-->
                        <div id="kt_datatable_example_buttons" class="d-none"></div>
                        <!--end::Hide default export buttons-->
                        <a href="/Kullanici/Ekle" class="btn btn-primary btn-sm fw-bold">
                            <i class="ki-duotone ki-plus fs-2"></i>Kullanıcı Ekle
                        </a>
                    </div>
                </div>
                <div class="card-body p-0 scroll-x">
                    <table class="table align-middle table-row-dashed fs-6 p-4" id="kullanicilar-datatable">
                        <thead class="p-0">
                            <!--begin::Table row-->
                            <tr class="text-start" style="font-size:15px;">
                                <th class="min-w-125px no-export"><strong>Kullanıcı</strong></th>
                                <th class="min-w-125px"><strong>Ad Soyad</strong></th>
                                <th class="min-w-125px"><strong>Kullanıcı Adı</strong></th>
                                <th class="min-w-125px"><strong>Telefon</strong></th>
                                <th class="min-w-125px"><strong>Firma</strong></th>
                                <th class="min-w-125px"><strong>Durum</strong></th>
                                <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>

                            </tr>
                            <!--end::Table row-->
                        </thead>
                        <tbody class="text-gray-600 fw-semibold">
                            @for (var i = 0; i < Model.Kullanicilar.Rows.Count; i++)
                            {
                                <tr>

                                    <td class="d-flex align-items-center">
                                        <!--begin:: Avatar -->
                                        <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                                            <a href="/Kullanici/Duzenle/@(Convert.ToString(Model.Kullanicilar.Rows[i]["ID"]))">
                                                <div class="symbol-label">
                                                    <img src="@(Convert.ToString(Model.Kullanicilar.Rows[i]["Resim"]))" alt="@(Convert.ToString(Model.Kullanicilar.Rows[i]["KullaniciAdi"]))" class="w-100 h-100 object-fit-cover" />
                                                </div>
                                            </a>
                                        </div>
                                        <!--end::Avatar-->
                                        <!--begin::User details-->
                                        <div class="d-flex flex-column">
                                            <a href="/Kullanici/Duzenle/@(Convert.ToString(Model.Kullanicilar.Rows[i]["ID"]))" class="text-gray-800 text-hover-primary mb-1">
                                                <span>@(Convert.ToString(Model.Kullanicilar.Rows[i]["KullaniciAdi"]))</span>
                                            </a>
                                        </div>
                                        <!--begin::User details-->
                                    </td>
                                    <td>
                                        @(Convert.ToString(Model.Kullanicilar.Rows[i]["Ad"])) @(Convert.ToString(Model.Kullanicilar.Rows[i]["Soyad"]))
                                    </td>
                                    <td>
                                        @(Convert.ToString(Model.Kullanicilar.Rows[i]["KullaniciAdi"]))
                                    </td>
                                    <td>
                                        @(Convert.ToString(Model.Kullanicilar.Rows[i]["Telefon"]))
                                    </td>
                                    <td>
                                        @(Convert.ToString(Model.Kullanicilar.Rows[i]["Aciklama1"]))
                                    </td>
                                    <td>@(Convert.ToBoolean(Model.Kullanicilar.Rows[i]["Aktif"]) ? "Aktif" : "Pasif") </td>
                                    <td class="text-end">
                                        <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                            İşlemler
                                            <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                        </a>
                                        <!--begin::Menu-->
                                        <div class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                            <!--begin::Menu item-->
                                            @if (Model.Duzenle)
                                            {
                                                <div class="menu-item p-0">
                                                    <a href="/Kullanici/Duzenle?ID=@(Convert.ToString(Model.Kullanicilar.Rows[i]["ID"]))" class="menu-link px-2 py-0">Düzenle</a>
                                                </div>
                                            }
                                            <!--end::Menu item-->
                                            @if (Model.Duzenle)
                                            {
                                                <div class="menu-item p-0">
                                                    <a href="/Kullanici/Yetkiler?KullaniciID=@(Convert.ToString(Model.Kullanicilar.Rows[i]["ID"]))" class="menu-link px-2 py-0">Yetkiler</a>
                                                </div>
                                            }
                                            <!--end::Menu item-->
                                            <!--begin::Menu item-->

                                            @if (Model.Sil)
                                            {
                                                <div class="menu-item p-0">
                                                    <button type="button" data-id="@(Convert.ToString(Model.Kullanicilar.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link rounded-0 px-2 py-0 btn-sil" data-bs-toggle="modal" data-bs-target="#kullanici-silme">
                                                        Sil
                                                    </button>
                                                </div>
                                            }
                                            <!--end::Menu item-->
                                        </div>
                                      
                                        <!--end::Menu-->
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!--end::Container-->
    </div>
    <!--end::Post-->
</div>

<div class="modal fade" id="kullanici-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Kullanıcı Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Kullanıcıyı silmek istediğinize emin misiniz?</p>
            </div>


            @if (Model.Sil)
            {
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>
                    <form method="post" id="silme-formu" action="@Url.Action("Sil","Kullanici",null)">
                        <input type="hidden" name="id" value="" />
                        <button type="submit" class="btn btn-danger">Sil</button>
                    </form>
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                })
            });


        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({

                    //scrollY: true,

                    scrollCollopse: true,
                    language: { url: '//cdn.datatables.net/plug-ins/2.0.7/i18n/tr.json', },
                    paging: true,
                    pageLength: 10,

                    order: [[1, 'asc']],
                    layout: {
                        topStart: {
                            pageLength: {
                                menu: [
                                    [10, 20, 50, 100, -1],
                                    ['10 Adet', '20 Adet', '50 Adet', '100 Adet', "Tümü"]
                                ]
                            }
                        }
                    },


                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Kullanicilar-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#kullanicilar-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}

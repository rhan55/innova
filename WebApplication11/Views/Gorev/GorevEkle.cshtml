@using YKPortal.Models.Dto
@using System.Data
@{
    ViewBag.Title = "Yeni Görev";
    Layout = "~/Views/Shared/_LayoutTab.cshtml";

    DataTable dtKullanicilar = ViewBag.Kullanicilar as DataTable;
}


<div class="container">
    <div class="row">
        <div class="col-lg-12">
            <!--begin::Form-->
            <form id="kt_modal_add_user_form" class="form" action="@Url.Action("GorevEkle","Gorev",null)" method="post" enctype="multipart/form-data">
                <!--begin::Scroll-->
                <div class="d-flex flex-column scroll-y px-5 px-lg-10  mt-10">
                    <input type="hidden" name="ID" value="@ViewBag.ID" />

                    <!--begin::Row Input group-->
                    <div class="row mb-7">
                        <!--begin::Input group-->
                        <div class="col-lg-8">
                            <!--begin::Label-->
                            <label for="Aciklama" class="fw-semibold fs-6 mb-2">Açıklama</label>
                            <!--end::Label-->
                            <!--begin::texarea-->
                            <textarea type="text" id="Aciklama" name="Aciklama" class="form-control" placeholder=""></textarea>
                            <!--end::Input-->
                        </div>
                        <div class="col-lg-4">
                            <label for="GorevTipiID" class="form-label">Görev Tipi</label>
                            <select class="form-control" name="GorevTipiID" id="GorevTipiID" aria-label="Floating label select example" required>
                                <option value="">Lütfen Seçim Yapınız</option>
                                @foreach (GrupKoduDto gorevTipi in ViewBag.GorevTipleri)
                                {
                                    <option value="@gorevTipi.ID">@gorevTipi.Deger</option>
                                }
                            </select>
                        </div>
                    </div>
                    <!--end::Input group-->
                    <div class="row">
                        <!--begin::Input group-->
                        <div class="col-lg-2">
                            <!--begin::Label-->
                            <label for="BaslangicTarihi" class=" fw-semibold fs-6 mb-2">Görev Tarihi</label>
                            <!--end::Label-->
                            <!--begin::Input-->
                            <input type="datetime-local" name="BaslangicTarihi" id="BaslangicTarihi" class="form-control p-2 mb-3 mb-lg-0"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm")" />
                            <!--end::Input-->
                        </div>
                        <!--end::Input group-->
                        <div class="col-lg-6">
                            <div class="d-flex justify-content-end align-items-center mt-10">
                                <div class=" ms-16">
                                    <input class="form-check-input" type="radio" name="periyot" id="TekSeferlik" value="T" checked>
                                    <label class="form-check-label" for="TekSeferlik">
                                        Tek
                                    </label>
                                </div>
                                <div class=" ms-16">
                                    <input class="form-check-input" type="radio" name="periyot" id="periyotGunluk" value="G">
                                    <label class="form-check-label" for="periyotGunluk">
                                        Günlük
                                    </label>
                                </div>
                                <br />
                                <div class=" ms-16">
                                    <input class="form-check-input" type="radio" name="periyot" id="periyotHaftalik" value="H">
                                    <label class="form-check-label" for="periyotHaftalik">
                                        Haftalık
                                    </label>
                                </div>
                                <div class=" ms-16">
                                    <input class="form-check-input" type="radio" name="periyot" id="periyotYillik" value="A">
                                    <label class="form-check-label" for="periyotYillik">
                                        Aylık
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <br /><br />
                            <input type="file" name="file Gorev" id="file" value="" multiple />
                        </div>
                        <div class="col-lg-12">
                            <label for="Kullanicilar">Görev atanacak kullanıcılar</label>
                            <select id="Kullanicilar" name="Kullanicilar" class="form-control" style="height:200px;" multiple>
                                @foreach (DataRow drKullanici in dtKullanicilar.Rows)
                                {
                                    <option value="@drKullanici["ID"]">@drKullanici["Ad"] @drKullanici["Soyad"] - @drKullanici["Aciklama1"]</option>
                                }
                            </select>
                        </div>
                    </div>
                    <!--begin::Actions-->
                    <div class="pt-10">
                        <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                        <button type="submit" class="btn btn-primary btn-sm">
                            <span class="indicator-label">Kaydet</span>
                            <span class="indicator-progress">
                                Lütfen Bekleyin...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>

                    <!--end::Actions-->
                </div>
                <!--begin::Row Input group-->
            </form>
            <!--end::Form-->
        </div>
        <!--end::Scroll-->

    </div>

</div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/Tema/plugins/custom/tinymce/tinymce.min.js"></script>


    <script>

        $(document).ready(function () {
            var AciklamaEditorOptions = {
                selector: "#Aciklama",
                height: 200,
                promotion: false
            };

            if (typeof KTThemeMode !== 'undefined') { // KTThemeMode varsa kontrol et
                if (KTThemeMode.getMode() === "dark") {
                    AciklamaEditorOptions["skin"] = "oxide-dark";
                    AciklamaEditorOptions["content_css"] = "dark";
                }
            }

            // tinyMCE init
            tinymce.init(AciklamaEditorOptions);


        });

    </script>

}


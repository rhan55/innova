@using System.Data
@using YKPortal.Models.Dto
@model DataSet
@{
    ViewBag.Title = "Görev Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";

    DataTable dtKullanicilar = ViewBag.Kullanicilar as DataTable;
    string KullaniciID = Request.Cookies["KullaniciID"].Value;

}


<div class="container-fluid p-4 m-0">
    <div class="row">

        <div class="col-lg-12">
            <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container p-0" class="container-fluid p-0 m-0">
                        <div class="card card-flush">
                            <div class="card-header">
                                <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                                    <!--begin::Export dropdown-->
                                    <input type="button" name="name" value="Filtre" onclick="$('#FormListe').toggle();" class="btn btn-sm btn-bg-primary" style="color:white;" />

                                    <!--end::Export dropdown-->
                                    <!--begin::Hide default export buttons-->
                                    <div id="kt_datatable_example_buttons" class="d-none"></div>
                                    <!--end::Hide default export buttons-->
                                    <a href="/Gorev/GorevEkle" class="btn btn-primary btn-sm">
                                        <i class="ki-duotone ki-plus fs-2"></i>Görev Ekle
                                    </a>
                                </div>
                            </div>
                            @if (Model.Tables[1].Rows.Count > 0)
                            {
                                <div class="card-body px-4 py-0 scroll-x" align="center">
                                    @foreach (DataRow satir in Model.Tables[1].Rows)
                                    {
                                        <div style="text-align:center;float:left;padding:5px;">
                                            <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                                                <div class="symbol-label">
                                                    <img src="@(Convert.ToString(satir["Resim"]))" alt="@(Convert.ToString(satir["Isim"]))" class="w-100 h-100 object-fit-cover" />

                                                </div>
                                            </div>
                                            <br />
                                            <span>@(Convert.ToString(satir["Isim"]))</span>
                                            <br />
                                            <span style="font-size:15px;"><strong>@(Convert.ToString(satir["Miktar"]))</strong></span>
                                        </div>
                                    }
                                    <div style="clear:both;"></div>
                                </div>
                            }
                            <div class="card-header align-items-center py-5 gap-2 gap-md-5 px-4">
                                <div class="d-flex a py-0 lign-items-center position-relative my-1 w-100">

                                    <form action="@Url.Content("~/Gorev/GorevListe")" method="get" class="w-100" id="FormListe" name="FormListe" style="display: none;">
                                        <div class="row w-100">
                                            <div  class="col-12 col-lg-4 mb-4 ">
                                                <label  for="Durum" class="required form-label ">Durum</label>
                                                <select class="form-control form-control-solid p-2 rounded-1" id="Durum" name="Durum">
                                                    <option value="">Lütfen Seçim Yapınız</option>
                                                    <option value="Beklemede" @(ViewBag.Durum == "Beklemede" ? "selected" : "")>Beklemede ve Cevaplananlar</option>
                                                    <option value="Tamamlandı" @(ViewBag.Durum == "Tamamlandı" ? "selected" : "")>Tamamlandı</option>
                                                    <option value="Onaylandı" @(ViewBag.Durum == "Onaylandı" ? "selected" : "")>Onaylandı</option>
                                                </select>
                                            </div>
                                            <div class="col-12 col-lg-4 mb-4">
                                                <label style="width:100%;" for="GorevTipiID" class="border-bottom required form-label">Görev Tipi</label>
                                                <div class="row">
                                                    <div class="col-12 col-lg-8">
                                                        <select class="form-control form-control-solid p-2 rounded-1" id="GorevTipiID" name="GorevTipiID">
                                                            <option value="">Lütfen Seçim Yapınız</option>
                                                            @foreach (GrupKoduDto gorevTipi in ViewBag.GorevTipleri)
                                                            {
                                                                <option value="@gorevTipi.ID" @(gorevTipi.ID == ViewBag.GorevTipiID ? "selected" : "")>@gorevTipi.Deger</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div class="col-12 col-lg-4">
                                                        <select class="form-control form-control-solid p-2 rounded-1" id="Periyot" name="Periyot">
                                                            <option value="">Periyot</option>
                                                            <option value="T" @(ViewBag.Periyot == "T" ? "selected" : "")>Tek Seferlik</option>
                                                            <option value="G" @(ViewBag.Periyot == "G" ? "selected" : "")>Günlük</option>
                                                            <option value="H" @(ViewBag.Periyot == "H" ? "selected" : "")>Haftalık</option>
                                                            <option value="A" @(ViewBag.Periyot == "A" ? "selected" : "")>Aylık</option>
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-lg-4 mb-4">
                                                <label style="width:100%;" for="Baslangic" class="required form-label border-bottom">Kayıt Tarihi</label>
                                                <div class="row">
                                                    <div class="col-12 col-lg-6">
                                                        <input type="date" class="form-control form-control-solid p-2 rounded-1" name="Baslangic" id="Baslangic" value="@(Convert.ToDateTime(ViewBag.Baslangic).ToString("yyyy-MM-dd"))" />
                                                    </div>
                                                    <div class="col-12 col-lg-6">
                                                        <input type="date" class="form-control form-control-solid p-2 rounded-1" name="Bitis" id="Bitis" value="@(Convert.ToDateTime(ViewBag.Bitis).ToString("yyyy-MM-dd"))" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-lg-4 mb-4">
                                                <label style="width:100%;" for="Baslangic2" class="required form-label border-bottom">İşlem Tarihi</label>
                                                <div class="row">
                                                    <div class="col-12 col-lg-6">
                                                        <input type="date" class="form-control form-control-solid p-2 rounded-1" name="Baslangic2" id="Baslangic2" value="@(Convert.ToDateTime(ViewBag.Baslangic2).ToString("yyyy-MM-dd"))" />
                                                    </div>
                                                    <div class="col-12 col-lg-6">
                                                        <input type="date" class="form-control form-control-solid p-2 rounded-1" name="Bitis2" id="Bitis2" value="@(Convert.ToDateTime(ViewBag.Bitis2).ToString("yyyy-MM-dd"))" />
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-12 col-lg-4 mb-4" >
                                                <label  for="KayitYapanKullanici" class="required  form-label">Kaydı Açan</label>
                                                <select class="form-control form-control-solid p-2 rounded-1" id="KayitYapanKullanici" name="KayitYapanKullanici">
                                                    <option value="">Lütfen Seçim Yapınız</option>
                                                    @foreach (DataRow drKullanici in dtKullanicilar.Rows)
                                                    {
                                                        <option value="@drKullanici["ID"]" @(Convert.ToString(drKullanici["ID"]) == Convert.ToString(ViewBag.KayitYapanKullanici) ? "selected" : "")>@drKullanici["Ad"] @drKullanici["Soyad"] - @drKullanici["Aciklama1"]</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-12 col-lg-4 mb-4">
                                                <label for="AtananKullanici" class="required form-label">Atanan</label>
                                                <select class="form-control form-control-solid p-2 rounded-1" id="AtananKullanici" name="AtananKullanici">
                                                    <option value="">Lütfen Seçim Yapınız</option>
                                                    @foreach (DataRow drKullanici in dtKullanicilar.Rows)
                                                    {
                                                        <option value="@drKullanici["ID"]" @(Convert.ToString(drKullanici["ID"]) == Convert.ToString(ViewBag.AtananKullanici) ? "selected" : "")>@drKullanici["Ad"] @drKullanici["Soyad"] - @drKullanici["Aciklama1"]</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-12 offset-lg-8 col-lg-4 d-flex justify-content-end mb-4">
                                                <button type="submit" class="btn btn-primary btn-sm" id="btnGetir">Getir</button>
                                            </div>
                                        </div>
                                    </form>

                                </div>

                            </div>

                            <div class="card-body px-4 py-0 scroll-x">
                                <table class="table align-middle rounded-0 table-row-dashed  fs-6 g-5" id="Gorev-datatable">
                                    <thead>
                                        <!--begin::Table row-->
                                        <tr class="text-start" style="font-size:15px;">
                                            <th class="min-w-125px fw-bold text-gray-600 fs-6" style="text-align:center;">Kaydı Açan</th>
                                            <th class="min-w-125px fw-bold text-gray-600 fs-6" style="text-align:center;">Atanan</th>
                                            <th class="min-w-125px fw-bold text-gray-600 fs-6" style="text-align:center;">Tarih</th>
                                            <th class="min-w-125px fw-bold text-gray-600 fs-6"><strong>Açıklama</strong></th>
                                            <th class="text-end min-w-100px no-export fw-bold text-gray-600 fs-6"><strong>İşlemler</strong></th>
                                        </tr>
                                        <!--end::Table row-->
                                    </thead>
                                    <tbody class="text-gray-600 fw-semibold">
                                        @for (var i = 0; i < Model.Tables[0].Rows.Count; i++)
                                        {
                                            string renk = "";
                                            if (Convert.ToString(Model.Tables[0].Rows[i]["KayitYapanKullanici"]) != KullaniciID)
                                            {
                                                renk = "background-color:#FFE4C4;color:black;";
                                            }
                                            else
                                            {
                                                renk = "color:black;";
                                            }
                                            <tr style="@(renk)">
                                                <td style="padding-left:3px;width:40px;vertical-align:top;text-align:center;">
                                                    <div class="symbol symbol-circle symbol-50px overflow-hidden me-3">
                                                        <div class="symbol-label">
                                                            <img src="@(Convert.ToString(Model.Tables[0].Rows[i]["Resim"]))" alt="@(Convert.ToString(Model.Tables[0].Rows[i]["KaydiAcan"]))" class="w-100 h-100 object-fit-cover" />
                                                        </div>
                                                    </div>
                                                    <br />
                                                    @(Convert.ToString(Model.Tables[0].Rows[i]["KaydiAcan"]))
                                                </td>
                                                <td style="padding-left:3px;width:150px;vertical-align:top;text-align:center;">
                                                    @{
                                                        foreach (string item in Convert.ToString(Model.Tables[0].Rows[i]["AtananKullanicilar"]).Split('|'))
                                                        {
                                                            if (item.Trim().Length > 0)
                                                            {
                                                                <div style="float:left;text-align:center;margin-right:3px;">
                                                                    <div class="symbol symbol-circle symbol-20px overflow-hidden me-3" style="display:none;">
                                                                        <div class="symbol-label">
                                                                            <img src="@(item.Split('~')[1])" alt="@(item.Split('~')[0])" class="w-100 h-100 object-fit-cover" />
                                                                        </div>
                                                                    </div>
                                                                    <span style="font-size:13px;margin:0px;padding:0px;">@(item.Split('~')[0])</span>
                                                                </div>
                                                                <br />
                                                            }
                                                        }

                                                    }
                                                </td>
                                                <td style="vertical-align: top; width: 150px; ">
                                                    <strong>@(Convert.ToDateTime(Model.Tables[0].Rows[i]["BaslangicTarihi"]).ToString("dd-MM-yyyy HH:mm"))</strong>
                                                    <br />
                                                    @if (Convert.ToString(Model.Tables[0].Rows[i]["Periyot"]) == "T")
                                                    {
                                                        <span style="color: green;">Tek Seferlik</span>
                                                    }
                                                    else if (Convert.ToString(Model.Tables[0].Rows[i]["Periyot"]) == "G")
                                                    {
                                                        <span style="color: blue;">Günlük</span>
                                                    }
                                                    else if (Convert.ToString(Model.Tables[0].Rows[i]["Periyot"]) == "H")
                                                    {
                                                        <span style="color: orange;">Haftalık</span>
                                                    }
                                                    else if (Convert.ToString(Model.Tables[0].Rows[i]["Periyot"]) == "Y")
                                                    {
                                                        <span style="color: red;">Yıllık</span>
                                                    }
                                                    else
                                                    {
                                                        <span>Bilinmeyen</span>
                                                    }
                                                    <br>
                                                    <span style="color:green;">@Convert.ToString(Model.Tables[0].Rows[i]["Durumu"])</span>
                                                    <span>@(Convert.ToString(Model.Tables[0].Rows[i]["GorevAtamaSayisi"]))/@(Convert.ToString(Model.Tables[0].Rows[i]["GorevHareketSayisi"]))</span>

                                                </td>
                                                <td style="vertical-align: top;">
                                                    <span style="color:orange;">@(Convert.ToString(Model.Tables[0].Rows[i]["Gorev"]))</span>
                                                    <br />
                                                    @(Html.Raw(HttpUtility.HtmlDecode(Convert.ToString(Model.Tables[0].Rows[i]["Aciklama"]))))
                                                </td>

                                                <td class="text-end" style="padding-right: 3px; vertical-align: top;width:150px;">

                                                    @if (Convert.ToString(Model.Tables[0].Rows[i]["KayitYapanKullanici"]) == KullaniciID)
                                                    {

                                                        <a href="/Gorev/GorevDuzenle/@(Convert.ToString(Model.Tables[0].Rows[i]["ID"]))" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" style="background-color:dodgerblue;color:white;font-size:14px;">Detay / Düzenle</a>
                                                        <br /><br />
                                                        <button type="button" data-id="@(Convert.ToString(Model.Tables[0].Rows[i]["ID"]))" class="btn btn-sil btn-light btn-active-light-primary btn-flex btn-center btn-sm" style="background-color:red;color:white;" data-bs-toggle="modal" data-bs-target="#Gorev-silme">
                                                            Sil
                                                        </button>

                                                    }
                                                    else
                                                    {
                                                        <a href="/Gorev/GorevDuzenle/@(Convert.ToString(Model.Tables[0].Rows[i]["ID"]))" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm">Detay'a Git</a>

                                                    }
                                                    <br />
                                                    <span class="form-control form-control-solid p-2 rounded-1" style="color:gray;">@Convert.ToDateTime(Model.Tables[0].Rows[i]["KayitTarihi"]).ToString("dd-MM-yyyy HH:mm")</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
                <!--end::Post-->
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="Gorev-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Görev Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Görevi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="/Gorev/GorevSil">
                    <input type="hidden" name="id" value="" />

                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                })
            });


        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    "info": false,

                    'order': [],
                    paging: false,
                    columnDefs: [
                        {
                            target: [],
                            visible: false
                        },
                        {
                            target: [],
                            visible: false
                        }
                    ]

                });

                datatable.on('columns-reordered', function (e, settings, details) {
                    KTMenu.createInstances();
                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Gorev-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#Gorev-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}



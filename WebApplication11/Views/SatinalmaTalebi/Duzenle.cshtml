@using YKPortal.Models.ComponentDto
@using YKPortal.Models.Dto
@using System.Data
@model BelgeDto
@{

    ViewBag.Title = "Satınalma Talebi Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string Tip = Request.QueryString["Tip"];

    DataTable dtDepolar = ViewBag.Depolar as DataTable;
}


@Html.Partial("~/Views/Shared/Components/_BelgeEkleComponent.cshtml", new BelgeEkleComponent
{
    //Depo yok
    Baslik = "Satınalma Talebi",
    Tip = Request.QueryString["Tip"],
    BelgeDto = Model,
    Depolar = dtDepolar,
    SatisPersonelleri = ViewBag.Personeller,
    CikisDepoVarMi = false,
    //KalemBilgileri = new BelgeEkleKalemComponent
    //{
    //    FiyatVarMi = false
    //}
})

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>


    <script src="~/Tema/js/app/belge.js"></script>

    <script>

     var controllerName = '@ViewBag.ControllerName';
     var isMobile = '@(Request.Browser.IsMobileDevice ? "1" : "0")';
     var tip = '@ViewBag.Tip';

     $(function () {
         $('[data-kt-users-modal-action="Kaydet"]').on('click', function () {
             kaydet(controllerName, tip);
         })
         $('#btnYeniSatir').on('click', function () {
             YeniSatirAc(tip, isMobile);
         })
     })
    </script>
    @foreach (BelgeKalemDto satir in Model.Kalemler)
    {
        <script>
            $(document).ready(function () {
                 var stokID = 'StokID_@(satir.ID.Replace("-", ""))';
                 var seriID = 'Seri_@(satir.ID.Replace("-", ""))';

                 // Fonksiyonları çağırıyoruz
                 initStokSelect(stokID);
                 initStokSeriChange(stokID, seriID);

            });
        </script>
    }

}


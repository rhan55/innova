@{
    ViewBag.Title = "Dosyalar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container-fluid">
    <div class="row">
        @Html.Partial("~/Views/Dosya/_DosyaMenu.cshtml", new ViewDataDictionary { { "KayitID", Convert.ToString(ViewBag.KayitID) }, { "Modul", Convert.ToString(ViewBag.Modul) } })

        <div class="col-lg-10">
            <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container" class="container-xxl">
                        <div class="card card-flush mb-10 p-10">
                            <div class="card-body">
                                <div>
                                    <!--begin::Form-->
                                    <form class="form" action="#" method="post">
                                        <input type="hidden" name="KayitID" value="@ViewBag.KayitID" />
                                        <input type="hidden" name="Modul" value="@ViewBag.Modul" />
                                        <!--begin::Input group-->
                                        <div class="fv-row">
                                            <!--begin::Dropzone-->
                                            <div class="dropzone" id="kt_dropzonejs_example_1">
                                                <!--begin::Message-->
                                                <div class="dz-message needsclick">
                                                    <i class="ki-duotone ki-file-up fs-3x text-primary"><span class="path1"></span><span class="path2"></span></i>

                                                    <!--begin::Info-->
                                                    <div class="ms-4">
                                                        <h3 class="fs-5 fw-bold text-gray-900 mb-1">Dosyaları buraya sürükleyin ya da yüklemek için tıklayın.</h3>
                                                        <span class="fs-7 fw-semibold text-gray-500">En fazla 10 dosya Yükleyebilirsiniz.</span>
                                                    </div>
                                                    <!--end::Info-->
                                                </div>
                                            </div>
                                            <!--end::Dropzone-->
                                        </div>
                                        <!--end::Input group-->
                                    </form>
                                    <!--end::Form-->
                                </div>
                            </div>
                        </div>
                        <div class="card card-flush">

                            <div class="card-header align-items-center py-5 gap-2 gap-md-5">
                                <div class="card-title">
                                    <!--begin::Search-->
                                    <div class="d-flex align-items-center position-relative ms-6 my-1">
                                        <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                                            <span class="path1 text-gray-500"></span>
                                            <span class="path2 text-gray-500"></span>
                                        </i>
                                        <input type="text" data-kt-filter="search" class="form-control  w-250px ps-14" />
                                    </div>
                                    <!--end::Search-->
                                </div>
                                <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                                    <!--begin::Export dropdown-->
                                    <button type="button" class="btn btn-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        Dışarı aktar
                                    </button>
                                    <!--begin::Menu-->
                                    <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px py-4" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="copy">
                                                Panoya Kopyala
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="excel">
                                                Excel olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="csv">
                                                CSV olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-3">
                                            <a href="#" class="menu-link px-3" data-kt-export="pdf">
                                                PDF olarak dışarı aktar
                                            </a>
                                        </div>

                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                    <!--end::Export dropdown-->
                                </div>
                            </div>
                            <!--begin::Card body-->
                            <div class="card-body py-4">
                                <!--begin::Table-->
                                <table class="table align-middle table-row-dashed fs-6 gy-5 p-6" id="Dosya-datatable">
                                    <thead>
                                        <tr class="text-start" style="font-size:15px;">

                                            <th class="min-w-125px"><strong>Modül</strong></th>
                                            <th class="min-w-125px"><strong>Dosya</strong></th>
                                            <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-gray-600 fw-semibold">
                                        @for (var i = 0; i < Model.Rows.Count; i++)
                                        {
                                            <tr>

                                                <td class="d-flex align-items-center">
                                                    <div href="" class="text-gray-800 text-hover-primary mb-1">@(Convert.ToString(Model.Rows[i]["Modul"]))</div>
                                                </td>

                                                <td>
                                                    <span class="icon-wrapper">
                                                        <i class="ki-duotone ki-folder fs-2x text-primary me-4">
                                                            <span class="path1"></span>
                                                            <span class="path2"></span>
                                                        </i>
                                                    </span>
                                                    <div href="" class="text-gray-800 text-hover-primary mb-1">@(Convert.ToString(Model.Rows[i]["Dosya"]))</div>
                                                </td>

                                                <td class="text-end">
                                                    <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                        İşlemler
                                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                                    </a>
                                                    <!--begin::Menu-->
                                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-4" data-kt-menu="true">
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item px-3">
                                                            <a href="~/Uploads/Dosyalar/@(Convert.ToString(Model.Rows[i]["Dosya"]))" class="menu-link px-3">İndir</a>
                                                        </div>
                                                        <!--end::Menu item-->
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item px-3">
                                                            <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link px-3 btn-sil" data-bs-toggle="modal" data-bs-target="#Dosya-silme">
                                                                Sil
                                                            </button>

                                                        </div>
                                                        <!--end::Menu item-->
                                                    </div>
                                                    <!--end::Menu-->
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                <!--end::Table-->
                            </div>
                            <!--end::Card body-->
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
                <!--end::Post-->
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="Dosya-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Şube Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Dosyayı silmek istediğinize emin misiniz</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("Sil","Dosya",null)">
                    <input type="hidden" name="ID" value="" />
                    <input type="hidden" name="KayitID" value="@ViewBag.KayitID" />
                    <input type="hidden" name="Modul" value="@ViewBag.Modul" />
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {

            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="ID"]').value = silButonu.dataset.id;
                });
            });

            const KayitID = document.querySelector('[name="KayitID"]').value;
            const Modul = document.querySelector('[name="Modul"]').value;
            var myDropzone = new Dropzone("#kt_dropzonejs_example_1", {
                url: "/Dosya/Ekle", // controller ismi ve metod ismi
                paramName: "Dosya", // Dosyayı aktarmak için kullanılacak ad
                maxFiles: 10, //maximum 10 tane dosya alabilir
                maxFilesize: 10, // Dosya en fazla 10MB olabilir
                addRemoveLinks: true,
                accept: function (file, done) {
                    console.log(file, done);
                    if (file.name == "wow.jpg") {
                        done("Naha, you don't.");
                    } else {
                        done();
                    }
                }
            });
            //KayıtID ve Modulü ekliyoruz
            myDropzone.on("sending", function (file, xhr, formData) {
                formData.append("KayitID", KayitID);
                formData.append("Modul", Modul);
            })

            //ekleme işlemi yapıldıktan sonraki işlemleri
            myDropzone.on("queuecomplete", function () {
                //alert verme işlemi
                alert("Dosyalar Kaydedildi");
                //Sayfayı yenileme işlemi
                window.location.reload()
            })


            // Class definition
            var KTDatatablesExample = function () {
                // Shared variables
                var table;
                var datatable;

                // Private functions
                var initDatatable = function () {
                    // Set date data order
                    const tableRows = table.querySelectorAll('tbody tr');

                    // Init datatable --- more info on datatables: https://datatables.net/manual/
                    datatable = $(table).DataTable({
                        "info": false,
                        'order': [],
                        paging: false,
                        searching: true,
                        columnDefs: [

                        ]

                    });
                }

                // Hook export buttons
                var exportButtons = () => {
                    const documentTitle = 'Dosya-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                    var buttons = new $.fn.dataTable.Buttons(table, {
                        buttons: [
                            {
                                extend: 'copyHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            },
                            {
                                extend: 'excelHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            },
                            {
                                extend: 'csvHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            }
                        ]
                    }).container().appendTo($('#kt_datatable_example_buttons'));

                    // Hook dropdown menu click event to datatable export buttons
                    const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                    exportButtons.forEach(exportButton => {
                        exportButton.addEventListener('click', e => {
                            e.preventDefault();

                            // Get clicked export value
                            const exportValue = e.target.getAttribute('data-kt-export');
                            const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                            // Trigger click event on hidden datatable export buttons
                            target.click();
                        });
                    });
                }

                // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
                var handleSearchDatatable = () => {
                    const filterSearch = document.querySelector('[data-kt-filter="search"]');
                    filterSearch.addEventListener('keyup', function (e) {
                        datatable.search(e.target.value).draw();
                    });
                }

                // Public methods
                return {
                    init: function () {
                        table = document.querySelector('#Dosya-datatable');

                        if (!table) {
                            return;
                        }

                        initDatatable();
                        exportButtons();
                        handleSearchDatatable();
                    }
                };
            }();

            // On document ready
            KTUtil.onDOMContentLoaded(function () {
                KTDatatablesExample.init();
            });
        })
    </script>
}




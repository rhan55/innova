@model System.Data.DataTable
@{
    string Modul = "";
    switch (Request.QueryString["Tip"])
    {
        case "AI":
            Modul = "Alış İrsaliyesi";
            break;
        default:
            break;
    }
    ViewBag.Title = Modul + " Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div style="margin:3px;">
    <a href="@Url.Action("Detay","Belge",new { Tip = Request.QueryString["Tip"], KayitID = "" })" class="btn btn-sm btn-primary" style="width:100px;">Yeni Belge</a>
    <table border="1" class="table">
        <thead>

            <!--begin::Table row-->
            <tr>
                <th><strong>Tarih<br />Belge No</strong></th>
                <th><strong>Cari</strong></th>
                <th style="text-align:right;"><strong>Tutar</strong></th>
                <th><strong>İşlemler</strong></th>
            </tr>
            <!--end::Table row-->
        </thead>
        <tbody>
            @if (Model != null)
            {
                for (var i = 0; i < Model.Rows.Count; i++)
                {
                    <tr>
                        <td style="vertical-align: middle;">
                            @(Convert.ToDateTime(Model.Rows[i]["Tarih"]).ToString("dd-MM-yyyy")) <br />

                            <span style="color:blue;">@(Convert.ToString(Model.Rows[i]["BelgeNo"]))</span>
                        </td>
                        <td style="vertical-align: middle;">
                            @(Convert.ToString(Model.Rows[i]["CariIsim"]))
                        </td>
                        <td style="text-align:right;vertical-align:middle;">
                            @(String.Format("{0:N2}",Convert.ToDecimal(Model.Rows[i]["Tutar"]))) @(Convert.ToString(Model.Rows[i]["DovizBirimi"]))
                        </td>
                        <td style="vertical-align: middle;">
                            <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                İşlemler
                                <i class="ki-duotone ki-down fs-5 ms-1"></i>
                            </a>
                            <!--begin::Menu-->
                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-4" data-kt-menu="true">
                                <!--begin::Menu item-->
                                <div class="menu-item px-2">
                                    <a href="/Belge/Detay/@(Convert.ToString(Model.Rows[i]["ID"]))?Tip=@(Request.QueryString["Tip"])" class="menu-link px-3">Düzenle</a>
                                </div>
                                <!--end::Menu item-->
                                <!--begin::Menu item-->
                                <div class="menu-item px-2">
                                    <a href="/Belge/Sil/@(Convert.ToString(Model.Rows[i]["ID"]))?Tip=@(Request.QueryString["Tip"])" class="menu-link px-3">Sil</a>
                                </div>
                                <!--end::Menu item-->
                            </div>
                            <!--end::Menu-->
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

</div>


@section Scripts {
    <script>

    </script>
}

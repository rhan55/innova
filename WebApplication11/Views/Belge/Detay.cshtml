@using YKPortal.Models.Dto
@using System.Data
@model BelgeDto
@{
    ViewBag.Title = "Belge Detayı";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string Tip = Request.QueryString["Tip"];

    DataTable dtDepolar = ViewBag.Depolar as DataTable;

}

<form method="post" action="@Url.Action("Detay","Belge",new { Tip = Request.QueryString["Tip"] })">


    <div class="col-lg-12 row" style="padding-left:15px;">
        <div class="d-flex align-items-center justify-content-between mt-5">
            <input type="hidden" name="ID" id="ID" value="@(Model.ID)" />
        </div>
        <div class="col-6">
            <label for="BelgeNo" class=" form-label">Belge No</label>
            <input type="text" name="BelgeNo" id="BelgeNo" value="@(Convert.ToString(Model.BelgeNo))" class="form-control p-2 rounded-1" placeholder="" />
        </div>
        <div class="col-6">
            <label for="Tarih" class=" form-label">Tarih</label>
            <input type="date" name="Tarih" id="Tarih" value="@(Convert.ToDateTime(Model.Tarih).ToString("yyyy-MM-dd"))" class="form-control p-2 rounded-1" placeholder="" />
        </div>
        <div class="col-6" style="@(Tip == "DT" ? "display:none;" : "")">
            <div class="form-group">
                <label for="CariID" class=" form-label">Cari</label>
                <select class="form-select form-select-solid p-2 rounded-1" name="CariID" id="CariID"
                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                    @if (Model.CariID != "")
                    {
                        <option value="@Model.CariID" selected>@Model.CariAdi</option>
                    }
                </select>
            </div>
        </div>

        <div class="col-@(Tip == "DT" ? "12" : "6")">
            <label for="Aciklama" class=" form-label">Açıklama</label>
            <input type="text" name="Aciklama" id="Aciklama" value="@(Convert.ToString(Model.Aciklama))" class="form-control p-2 rounded-1" placeholder="" />
        </div>

        <div class="col-6">
            <div class="form-group">
                <label for="DepoCikisID" class=" form-label">Çıkış Depo</label>
                <select class="form-select form-select-solid p-2 rounded-1" name="DepoCikisID" id="DepoCikisID"
                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                    @foreach (DataRow drDepo in dtDepolar.Rows)
                    {
                        <option value="@drDepo["ID"]">@drDepo["Isim"]</option>
                    }
                </select>
            </div>
        </div>
        <div class="col-6">
            <div class="form-group">
                <label for="DepoGirisID" class=" form-label">Giriş Depo</label>
                <select class="form-select form-select-solid p-2 rounded-1" name="DepoGirisID" id="DepoGirisID"
                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                    @foreach (DataRow drDepo in dtDepolar.Rows)
                    {
                        <option value="@drDepo["ID"]">@drDepo["Isim"]</option>
                    }
                </select>
            </div>
        </div>



        <div style="text-align:center;vertical-align:middle;">
            <div style="clear:both;height:5px;width:100%;background-color:black;margin:5px;"></div>
            <h4>KALEMLER</h4>
            <div style="clear:both;height:5px;width:100%;background-color:black;margin:5px;"></div>
        </div>
        <br />
        <div class="row">
            <table class="table" border="1" id="TabloKalemler" name="TabloKalemler">
                <thead>
                    <tr style="padding:5px;">
                        @if (Request.Browser.IsMobileDevice)
                        {
                            <td colspan="3" style="text-align:center;"><strong>ÜRÜN</strong></td>
                            <td colspan="2" style="text-align:center;"><strong>SERİ</strong></td>
                        }
                        else
                        {
                            <td style="text-align:center;"><strong>ÜRÜN</strong></td>
                            <td style="text-align:center;"><strong>SERİ</strong></td>
                            <td style="text-align:center;"><strong>MİKTAR</strong></td>
                            <td style="text-align:center;"><strong>BİRİM</strong></td>
                            <td style="text-align:center;"><strong>FİYAT</strong></td>
                            <td style="text-align:center;"><strong>TUTAR</strong></td>
                            <td style="text-align:center;"><strong></strong></td>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (BelgeKalemDto satir in Model.Kalemler)
                    {
                        string ID = satir.ID.Replace("-", "");
                        if (Request.Browser.IsMobileDevice)
                        {

                            <tr data-ID="@satir.ID" data-ID2="@ID">
                                <td colspan="4">
                                    <table style="width:100%;margin-bottom:15px;">
                                        <tr>
                                            <td colspan="3">
                                                <select class="form-select form-select-solid p-2 rounded-1" name="StokID_@(ID)" id="StokID_@(ID)" style="width:100%;"
                                                        aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                                    <option value="@satir.StokID" selected>@satir.StokAdi</option>
                                                </select>

                                            </td>
                                            <td>
                                                @if (Tip == "AI")
                                                {
                                                    <input type="text" name="Seri_@(ID)" id="Seri_@(ID)" value="@(satir.Seri)" class="form-control" />
                                                }
                                                else if (Tip == "DT")
                                                {

                                                    <input type="text" name="Seri_@(ID)" id="Seri_@(ID)" value="@(satir.Seri)" class="form-control" />
                                                }
                                                else
                                                {
                                                    <select class="form-select form-select-solid p-2 rounded-1" name="Seri_@(ID)" id="Seri_@(ID)"
                                                            aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                                        <option value="@satir.Seri" selected>@satir.Seri</option>
                                                    </select>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td style="text-align: right;"><strong>Miktar</strong></td>
                                            <td><strong>Birim</strong></td>
                                            <td style="text-align: right;"><strong>Fiyat</strong></td>
                                            <td style="text-align: right;"><strong>Tutar</strong></td>
                                        </tr>
                                        <tr>
                                            <td><input type="text" name="Miktar_@(ID)" id="Miktar_@(ID)" value="@(String.Format("{0:N2}",satir.Miktar))" onchange="TutarHesapla('Miktar_@(ID)','Fiyat_@(ID)','Tutar_@(ID)');" class="form-control" style="text-align:right;" /></td>
                                            <td><input type="text" name="OlcuBirimi_@(ID)" id="OlcuBirimi_@(ID)" value="@(String.Format("{0:N2}",satir.OlcuBirimi))" class="form-control" readonly /></td>
                                            <td><input type="text" name="Fiyat_@(ID)" id="Fiyat_@(ID)" value="@(String.Format("{0:N2}",satir.Fiyat))" onchange="TutarHesapla('Miktar_@(ID)','Fiyat_@(ID)','Tutar_@(ID)');" class="form-control" style="text-align:right;" /></td>
                                            <td><input type="text" name="Tutar_@(ID)" id="Tutar_@(ID)" value="@(String.Format("{0:N2}",satir.Tutar))" onchange="TutarHesapla('Miktar_@(ID)','Fiyat_@(ID)','Tutar_@(ID)');" class="form-control" style="text-align:right;" readonly /></td>
                                        </tr>
                                    </table>
                                </td>
                                <td><button type='button' class="deleteBtn" data-ID2="@(ID)">Sil</button></td>
                            </tr>
                        }
                        else
                        {
                            <tr data-ID="@satir.ID" data-ID2="@ID">
                                <td>
                                    <select class="form-select form-select-solid p-2 rounded-1" name="StokID_@(ID)" id="StokID_@(ID)" style="min-width:150px;max-width:350px;"
                                            aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                        <option value="@satir.StokID" selected>@satir.StokAdi</option>
                                    </select>

                                </td>
                                <td>
                                    @if (Tip == "AI")
                                    {
                                        <input type="text" name="Seri_@(ID)" id="Seri_@(ID)" value="@(satir.Seri)" class="form-control" />
                                    }
                                    else
                                    {
                                        <select class="form-select form-select-solid p-2 rounded-1" name="Seri_@(ID)" id="Seri_@(ID)"
                                                aria-label="Floating label select example" data-control="select2" data-placeholder="Lütfen Seçim Yapınız">
                                            <option value="@satir.Seri" selected>@satir.Seri</option>
                                        </select>
                                    }
                                </td>
                                <td style="max-width:100px;"><input type="text" name="Miktar_@(ID)" id="Miktar_@(ID)" value="@(String.Format("{0:N2}",satir.Miktar))" onchange="TutarHesapla('Miktar_@(ID)','Fiyat_@(ID)','Tutar_@(ID)');" class="form-control" style="text-align:right;" /></td>
                                <td style="max-width:100px;"><input type="text" name="OlcuBirimi_@(ID)" id="OlcuBirimi_@(ID)" value="@(String.Format("{0:N2}",satir.OlcuBirimi))" class="form-control" readonly /></td>
                                <td style="max-width:150px;"><input type="text" name="Fiyat_@(ID)" id="Fiyat_@(ID)" value="@(String.Format("{0:N2}",satir.Fiyat))" onchange="TutarHesapla('Miktar_@(ID)','Fiyat_@(ID)','Tutar_@(ID)');" class="form-control" style="text-align:right;" /></td>
                                <td style="max-width:150px;"><input type="text" name="Tutar_@(ID)" id="Tutar_@(ID)" value="@(String.Format("{0:N2}",satir.Tutar))" onchange="TutarHesapla('Miktar_@(ID)','Fiyat_@(ID)','Tutar_@(ID)');" class="form-control" style="text-align:right;" readonly /></td>
                                <td><button type='button' class="deleteBtn" data-ID2="@(ID)">Sil</button></td>

                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</form>
<button name="btnYeniSatir" id="btnYeniSatir" onclick="YeniSatirAc();" class="btn btn-primary" style="width:150px;">+ Yeni Satır Aç</button>

<!--begin::Actions-->
<div class="col-12">
    <div class="pt-10">
        <a href="@Url.Content("~/Belge/Liste/?Tip="+Request.QueryString["Tip"])" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Geri</a>
        <button type="submit" class="btn btn-primary" data-kt-users-modal-action="Kaydet" onclick="Kaydet();">
            <span class="indicator-label">Kaydet</span>

        </button>
    </div>
</div>
<!--end::Actions-->



@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>

        var Tip = "@(Tip)";


        $(".deleteBtn").click(function () {
            $(this).closest("tr").remove();
        });

        function SatirSil(SatirID) {
            $("#TR_" + SatirID).remove();
        }

        function TutarHesapla(miktarid, fiyatid, tutarid) {
            $("#" + tutarid).val((parseFloat($("#" + miktarid).val().replace(",", ".")) * parseFloat($("#" + fiyatid).val().replace(",", "."))).toFixed(2));
        }

        function YeniSatirAc() {
            var IsMobile = "@(Request.Browser.IsMobileDevice == true ? "1" : "0")";
            var YeniID = IDGuidOlustur().replace(/-/g, "");

            var deger = "";
            if (IsMobile == "1") {

                deger += "<tr data-ID='' data-ID2='" + YeniID + "' id='TR_" + YeniID +"' name='TR_" + YeniID +"'>                                                                                                             ";
                           deger += "     <td colspan='4'>                                                                                                                               ";
                           deger += "         <table style='width:100%;margin-bottom:15px;'>                                                                                             ";
                           deger += "             <tr>                                                                                                                                   ";
                           deger += "                 <td colspan='3'>                                                                                                                   ";
                           deger += "                     <select class='form-select form-select-solid p-2 rounded-1' name='StokID_" + YeniID + "' id='StokID_" + YeniID + "' style='width:100%;'          ";
                           deger += "                             aria-label='Floating label select example' data-control='select2' data-placeholder='Lütfen Seçim Yapınız'>             ";
                           deger += "                                                                                   ";
                           deger += "                     </select>                                                                                                                      ";
                           deger += "                                                                                                                                                    ";
                           deger += "                 </td>                                                                                                                              ";
                           deger += "                 <td>                                                                                                                               ";
                            if (Tip == 'AI') {
                                deger += "                         <input type='text' name='Seri_" + YeniID + "' id='Seri_" + YeniID + "' value='' class='form-control' />                         ";
                            } else if (Tip == 'DT') {
                                deger += "                         <input type='text' name='Seri_" + YeniID + "' id='Seri_" + YeniID + "' value='' class='form-control' />                         ";
                            } else {
                                deger += "                         <select class='form-select form-select-solid p-2 rounded-1' name='Seri_" + YeniID + "' id='Seri_" + YeniID + ")'                              ";

                                deger += "                                 aria-label='Floating label select example' data-control='select2' data-placeholder='Lütfen Seçim Yapınız'>         ";
                                deger += "                         </select>                                                                                                                  ";
                            }
                           deger += "                 </td>                                                                                                                              ";
                           deger += "             </tr>                                                                                                                                  ";
                           deger += "             <tr>                                                                                                                                   ";
                           deger += "                 <td style='text-align: right;'><strong>Miktar</strong></td>                                                                        ";
                           deger += "                 <td><strong>Birim</strong></td>                                                                                                    ";
                           deger += "                 <td style='text-align: right;'><strong>Fiyat</strong></td>                                                                         ";
                           deger += "                 <td style='text-align: right;'><strong>Tutar</strong></td>                                                                         ";
                           deger += "             </tr>                                                                                                                                  ";
                           deger += "             <tr>                                                                                                                                   ";
                deger += "                 <td><input type='text' name='Miktar_" + YeniID + "' id='Miktar_" + YeniID + "' value='1' onchange='TutarHesapla(\"Miktar_" + YeniID + "\",\"Fiyat_" + YeniID + "\",\"Tutar_" + YeniID +"\");' class='form-control' style='text-align:right;' /></td>              ";
                           deger += "                 <td><input type='text' name='OlcuBirimi_" + YeniID + "' id='OlcuBirimi_" + YeniID + "' value='' class='form-control' readonly /></td>                   ";
                deger += "                 <td><input type='text' name='Fiyat_" + YeniID + "' id='Fiyat_" + YeniID + "' value='0' onchange='TutarHesapla(\"Miktar_" + YeniID + "\",\"Fiyat_" + YeniID + "\",\"Tutar_" + YeniID +"\");' class='form-control' style='text-align:right;' /></td>                 ";
                           deger += "                 <td><input type='text' name='Tutar_" + YeniID + "' id='Tutar_" + YeniID + "' value='0'  onchange='TutarHesapla(\"Miktar_"+YeniID+"\",\"Fiyat_"+YeniID+"\",\"Tutar_"+YeniID+"\");'  class='form-control' style='text-align:right;' readonly /></td>        ";
                           deger += "             </tr>";
                           deger += "         </table>";
                deger += "     </td><td><button type='button' class='deleteBtn' onclick='SatirSil(\"" + YeniID +"\")' data-ID2='"+YeniID+"'>Sil</button></td>";
                           deger += " </tr>";


            } else {

                deger += "<tr data-ID='' data-ID2='" + YeniID + "' id='TR_" + YeniID + "' name='TR_" + YeniID +"'>";
                deger += "      <td id='TD_" + YeniID + "' name='TD_" + YeniID + "'>";
                deger += "      </td>";
                deger += "      <td>";
                if (Tip == "AI") {
                    deger += "              <input type='text' name='Seri_" + YeniID + "' id='Seri_" + YeniID + "' value='' class='form-control' />";
                } else if (Tip == "DT") {
                    deger += "              <input type='text' name='Seri_" + YeniID + "' id='Seri_" + YeniID + "' value='' class='form-control' />";
                } else {
                    deger += "              <select class='form-select form-select-solid p-2 rounded-1' name='Seri_" + YeniID + "' id='Seri_" + YeniID + "'";
                    deger += "                      aria-label='Floating label select example' data-control='select2' data-placeholder='Lütfen Seçim Yapınız'>";
                    deger += "              </select>";
                    deger += "";
                }
                deger += "      </td>";
                deger += "      <td style='max-width:100px;'><input type='text' name='Miktar_" + YeniID + "' id='Miktar_" + YeniID + "' value='1' onchange='TutarHesapla(\"Miktar_" + YeniID + "\",\"Fiyat_" + YeniID + "\",\"Tutar_" + YeniID +"\");' class='form-control' style='text-align:right;' /></td>";
                deger += "      <td style='max-width:100px;'><input type='text' name='OlcuBirimi_" + YeniID + "' id ='OlcuBirimi_" + YeniID + "' value = '' class='form-control' readonly /></td > ";
                deger += "      <td style='max-width:150px;'><input type='text' name='Fiyat_" + YeniID + "' id = 'Fiyat_" + YeniID + "' value = '0' onchange='TutarHesapla(\"Miktar_" + YeniID + "\",\"Fiyat_" + YeniID + "\",\"Tutar_" + YeniID +"\");' class='form-control' style = 'text-align:right;' /></td > ";
                deger += "      <td style='max-width:150px;'><input type='text' name='Tutar_" + YeniID + "' id = 'Tutar_" + YeniID + "' value = '0' onchange='TutarHesapla(\"Miktar_" + YeniID + "\",\"Fiyat_" + YeniID + "\",\"Tutar_" + YeniID +"\");' class='form-control' style = 'text-align:right;' readonly /></td > ";
                deger += "      <td><button type='button' class='deleteBtn' onclick='SatirSil(\""+YeniID+"\")' data-ID2='"+YeniID+"'>Sil</button></td></tr>";
            }
            var newSelect = $("<select class='form-select form-select-solid p-2 rounded-1 ' name='StokID_" + YeniID + "' id='StokID_" + YeniID + "' style='min-width:150px;max-width:350px;' aria-label='Floating label select example' data-control='select2' data-placeholder='Lütfen Seçim Yapınız' ></select>");

            $('#TabloKalemler tbody').append(deger);
            $("#TD_" + YeniID + "").append(newSelect);

            newSelect.select2();

            StokAramaOlustur("StokID_" + YeniID + "");
        }

        function Kaydet() {

            if ($("#BelgeNo").val() == "" && Tip == "AI") {
                alert("Lütfen belge numarası yazınız.");
                return;
            }
            if (($("#CariID").val() == "" || $("#CariID").val() == null) && Tip == "AI") {
                alert("Lütfen cari seçiniz.");
                return;
            }

            var kalemler = "";
            $('#TabloKalemler tbody tr').each(function () {
                var $data = $(this).attr("data-ID2");
                var KalemID = $(this).attr("data-ID");
                if ($data != "" && $data != null) {
                    var KalemID = KalemID;
                    var StokID = $("#StokID_" + $data).val();
                    var Seri = $("#Seri_" + $data).val();
                    var Miktar = $("#Miktar_" + $data).val();
                    var Fiyat = $("#Fiyat_" + $data).val();
                    kalemler += "~"+KalemID + "|" + StokID + "|" + Seri + "|" + Miktar + "|" +Fiyat;
                }
            });

            if (kalemler == "") {
                alert("Lütfen kalem giriniz.");
                return;
            }

            var _data = {
                "Tip": Tip,
                "ID": $("#ID").val(),
                "BelgeNo": $("#BelgeNo").val(),
                "Tarih": $("#Tarih").val(),
                "CariID": $("#CariID").val(),
                "DepoCikisID": $("#DepoCikisID").val(),
                "DepoGirisID": $("#DepoGirisID").val(),
                "Aciklama": $("#Aciklama").val(),
                "Kalemler": kalemler
            };
            console.log(_data);
            $.ajax({
                    url: '/Belge/Kaydet',
                    data: _data,
                    dataType: "json",
                    type: "POST",
                    //contentType: "application/json; charset=utf-8",
                    dataFilter: function (data) { return data; },
                    success: function (data) {
                        alert("Belge Kaydedildi!");
                        window.open("@(Request.Url.Scheme+"://"+Request.Url.Authority)/Belge/Detay/" + data.Data + "?Tip=@(Request.QueryString["Tip"])","_parent");
                    },
                    error: function (msg) {
                        console.log(msg);
                    }
                });

        }


        $(function () {

            const CariIDSelect = $('#CariID').select2({
                ajax: {
                    url: "/Cari/SelectListe",
                    data: function (params) {
                        var query = {
                            search: params.term,
                        }

                        // Query parameters will be ?search=[term]&type=public
                        return query;
                    },
                    processResults: function (data) {
                        var results = [];
                        if (data && data.length > 0) {
                            data.forEach(function (item) {
                                results.push({ id: item.ID, text: item.Isim })
                            });
                        }

                        return {
                            results: results
                        };
                    }
                },
                delay: 250,
                minimumInputLength: 3,
                language: {
                    placeholder: function () {
                        return "Arama yapmak için en az 3 karakter girin";
                    },
                    inputTooShort: function () {
                        return "En az lütfen en az 3 karakter girin";
                    }
                }
            });


        });

        function StokAramaOlustur(stokid) {
            $(function () {

                const StokIDSelect = $('#' + stokid).select2({
                    ajax: {
                        url: "/Stok/SelectListe",
                        data: function (params) {
                            var query = {
                                search: params.term,
                            }

                            // Query parameters will be ?search=[term]&type=public
                            return query;
                        },
                        processResults: function (data) {
                            var results = [];
                            if (data && data.length > 0) {
                                data.forEach(function (item) {
                                    results.push({ id: item.ID, text: item.Isim })
                                });
                            }

                            return {
                                results: results
                            };
                        }
                    },
                    delay: 250,
                    minimumInputLength: 3,
                    language: {
                        placeholder: function () {
                            return "Arama yapmak için en az 3 karakter girin";
                        },
                        inputTooShort: function () {
                            return "En az lütfen en az 3 karakter girin";
                        }
                    }
                });


            });
        }
    </script>

    @foreach (BelgeKalemDto satir in Model.Kalemler)
    {
        <script>


            $(function () {



                const StokIDSelect@(satir.ID.Replace("-","")) = $('#StokID_@(satir.ID.Replace("-",""))').select2({
                    ajax: {
                        url: "/Stok/SelectListe",
                        data: function (params) {
                            var query = {
                                search: params.term,
                            }

                            // Query parameters will be ?search=[term]&type=public
                            return query;
                        },
                        processResults: function (data) {
                            var results = [];
                            if (data && data.length > 0) {
                                data.forEach(function (item) {
                                    results.push({ id: item.ID, text: item.Isim })
                                });
                            }

                            return {
                                results: results
                            };
                        }
                    },
                    delay: 250,
                    minimumInputLength: 3,
                    language: {
                        placeholder: function () {
                            return "Arama yapmak için en az 3 karakter girin";
                        },
                        inputTooShort: function () {
                            return "En az lütfen en az 3 karakter girin";
                        }
                    }
                });


            });


            $('#StokID_@(satir.ID.Replace("-",""))').on('change', function () {

                $.ajax({
                    url: '/Stok/SelectStokSeriListe',
                    data: "{ StokID: '" + this.value + "' }",
                    dataType: "json",
                    type: "POST",
                    contentType: "application/json; charset=utf-8",
                    dataFilter: function (data) { return data; },
                    success: function (data) {
                        // waitingDialog.hide();

                            $('#Seri_@(satir.ID.Replace("-","")) option').remove();
                            var deger = "";
                            for (var i = 0; i < data.length; i++) {
                                deger += "<option value='"+data[i].SeriNo+"'>" + data[i].SeriNo + "</option>";
                            }
                            $('#Seri_@(satir.ID.Replace("-",""))').append(deger);

                    },
                    error: function (msg) {
                        console.log(msg);
                    }
                });
            });

        </script>
    }
}
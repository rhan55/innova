@{
    ViewBag.Title = "Mesajlaşma";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="d-flex flex-column flex-column-fluid mt-10">
    <div>
        <div id="kt_app_content" class="app-content container flex-column-fluid pt-4 pb-0">
            <div id="kt_app_content_container" class="app-container">
                <div class="d-flex flex-column flex-lg-row">
                    <div style="min-height:40px;" class="flex-column flex-lg-row-auto w-100 w-lg-300px w-xl-450px mb-10 mb-lg-0">

                        <div class="card card-flush">
                            <div style="min-height:40px;" class="card-header px-2 mt-2" id="kt_chat_contacts_header">
                                <!-- Arama Formu -->
                                <input type="text" class="form-control form-control-solid py-2" name="aranacakKelime" value="@ViewBag.AranacakKelime" placeholder="Kullanıcı adını veya e-postasını ara...">
                            </div>

                            <div class="card-body p-2" id="kt_chat_contacts_body">
                                <div class="scroll-y me-n5 pe-5 h-200px h-lg-auto" id="kullaniciListesi">

                                </div>
                            </div>
                        </div>
                    </div>
                    <!--end::Sidebar-->
                    <!--begin::Content-->
                    <div class="flex-lg-row-fluid ms-lg-4">
                        <!--begin::Messenger-->
                        <div class="card" id="kt_chat_messenger">
                            <!--begin::Card header-->
                            <div class="card-header p-0 hidden" id="kullaniciChatHeader">
                                <!--begin::Title-->
                                <div class="card-title ps-4">
                                    <!--begin::User-->
                                    <div class="d-flex">
                                        <div>
                                            <img style="width:40px;height: 40px;" class="rounded-circle object-fit-cover" src="" id="karsiResim" />
                                        </div>
                                        <div class="ms-4">
                                            <div class="fs-4 fw-bold text-gray-900 text-hover-primary me-1 mb-2 lh-1" data-container="active-user" data-id=""></div>
                                            <!--begin::Info-->
                                            @*<div class="mb-0 lh-1">
                                                    <span class="badge badge-success badge-circle w-10px h-10px me-1"></span>
                                                    <span class="fs-7 fw-semibold text-muted">Active</span>
                                                </div>*@
                                        </div>

                                        <!--end::Info-->
                                    </div>

                                    <!--end::User-->
                                </div>
                                <!--end::Title-->
                                <!--begin::Card toolbar-->
                                <div class="card-toolbar">
                                    <!--begin::Menu-->
                                    <div class="d-flex">
                                        <div class="d-flex">
                                            <button type="button" id="TumunuSec" class=" TumunuSec btn btn-light-primary btn-sm fw-bold hidden me-2" data-status="0">
                                                <span class="indicator-label fw-bold secim-sec">Tümünü Seç</span>
                                                <span class="indicator-label fw-bold hidden secim-temizle">Seçimleri Temizle</span>
                                            </button>


                                            <button type="button" id="topluSilButon" class=" topluSilButon btn btn-primary btn-sm fw-bold me-2 hidden">
                                                <span class="indicator-label fw-bold">Seçimleri Sil</span>
                                            </button>
                                            <!--end::Info-->
                                        </div>
                                        <button class="btn btn-sm btn-icon btn-active-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                            <i class="ki-duotone ki-dots-square fs-2"><span class="path1"></span><span class="path2"></span><span class="path3"></span><span class="path4"></span></i>
                                        </button>

                                        <!--begin::Menu 3-->
                                        <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-800 menu-state-bg-light-primary fw-semibold w-200px" data-kt-menu="true">

                                            <!--begin::Heading-->
                                            <div class="menu-item p-0">
                                                <div class="menu-content text-muted fs-7 text-uppercase">
                                                    İşlemler
                                                </div>
                                            </div>
                                            <!--end::Heading-->
                                            <!--begin::Menu item-->
                                            <!--begin::Menu-->
                                            <div class="menu menu-column menu-gray-600 menu-active-primary menu-hover-light-primary menu-here-light-primary menu-show-light-primary fw-semibold" data-kt-menu="true">

                                                <!--begin::Menu item-->
                                                <div class="menu-item p-0" style="width:100%;" data-kt-menu-trigger="hover" data-kt-menu-placement="right-start">
                                                    <!--begin::Menu link-->
                                                    <button type="button" id="SilCheckboxGoster" class="menu-link rounded-1 bg-white border-0 w-100" onclick="">
                                                        Mesaj Seç

                                                    </button>
                                                    <!--end::Menu link-->

                                                </div>
                                                <!--end::Menu item-->

                                            </div>
                                            <!--end::Menu-->
                                        </div>
                                        <!--end::Menu-->
                                    </div>
                                    <!--end::Menu-->
                                </div>
                                <!--end::Card toolbar-->
                            </div>
                            <!--end::Card header-->
                            <!--begin::Card body-->
                            <!-- Kullanıcı Listesi Bölümü -->
                            <div class="card-body p-2 hidden" id="kullaniciChatEkrani">
                                <div class="scroll-y me-n5 pe-5 h-200px h-lg-auto" id="kullaniciListesi">
                                    <!-- Kullanıcılar buraya dinamik olarak eklenecek -->
                                </div>
                                <div id="mesajListesi" class="scroll-y" style="height:500px;">

                                </div>
                                <form method="POST" action="/Mesaj/Chat">
                                    <!-- Mesaj Gönderme Alanı -->
                                    <div class="input-group mt-5">
                                        <input type="hidden" id="KullaniciID" value="@ViewBag.KullaniciID">
                                        <input type="hidden" id="KarsiKullaniciID" value="@ViewBag.KarsiKullaniciID">
                                        <div style="height:1px;width:100%; background-color:#f1f1f1;"></div>
                                        <div class="d-flex flex-column" style="width:100%;">
                                            <textarea id="Mesaj" class="form-control border-0" placeholder="Mesajınızı yazın..."></textarea>
                                            <div class="d-flex justify-content-between align-items-end border-top">
                                                <div class="d-flex align-items-center me-2">
                                                    <!-- Dosya Seçme Butonu -->
                                                    <button id="btnFileSelect" class="btn btn-sm btn-icon btn-active-light-primary me-1" type="button" data-bs-toggle="tooltip" aria-label="Coming soon" data-bs-original-title="Coming soon" data-kt-initialized="1">
                                                        <i class="ki-duotone ki-paper-clip fs-3"></i>
                                                    </button>
                                                    <div id="fileDisplayArea"></div>
                                                    <!-- Gizli Dosya Seçici -->
                                                    <input type="file" name="Dosya" id="Dosya" style="display: none;" />
                                                    <button class="btn btn-sm btn-icon btn-active-light-primary me-1" type="button" data-bs-toggle="tooltip" aria-label="Coming soon" data-bs-original-title="Coming soon" data-kt-initialized="1">
                                                        <i class="ki-duotone ki-exit-up fs-3"><span class="path1"></span><span class="path2"></span></i>
                                                    </button>
                                                </div>
                                                <button type="button" id="btnSendMessage" class="btn btn-primary btn-sm rounded-1">Gönder</button>
                                            </div>
                                        </div>


                                    </div>
                                </form>

                            </div>
                            <div style="height:600px;" class="card-body p-2 d-flex align-items-center justify-content-center border-0 shadow-none" id="kullaniciBosEkan">
                                <div>
                                    <div class="d-flex align-items-center justify-content-center">

                                        <i style="font-size: 200px;" class="bi bi-chat-square-text text-primary"></i>

                                    </div>
                                    <div class="d-flex flex-column align-items-center justify-content-center">
                                        <h1 class="text-primary" style="padding-top: 16px;padding-bottom: 16px;">MERHABA!</h1>
                                        <p class="text-gray-500 fs-1 fw-semibold">Sohbet başlatmak için bir kullanıcı seçiniz!</p>
                                    </div>
                                </div>


                            </div>

                        </div>
                        <!--end::Messenger-->
                    </div>
                    <!--end::Content-->
                </div>

            </div>
            <!--end::Content container-->
        </div>
    </div>

    <!--end::Content-->

</div>



@section Scripts {
    <script>

        function scrollToBottom(select) {
            var $chatContainer = $(select); // Replace with your container's ID or class
            $chatContainer.scrollTop($chatContainer[0].scrollHeight);
        }

        function BildirimSayisiniDuzenle(element) {
            var varOlanSayi = Number($('[data-id="YeniOkunmamisMesaj"]').html());
            if (varOlanSayi != 0) {
                kullaniciMesajSayisi = Number($(element).find('.badge.badge-sm.badge-circle.badge-light-success').html());

                varOlanSayi = varOlanSayi - kullaniciMesajSayisi;
                $(element).find('.badge.badge-sm.badge-circle.badge-light-success').html("0")

                if (varOlanSayi <= 0) {
                    $('[data-id="YeniOkunmamisMesaj"]').html("0");
                    $('[data-id="YeniOkunmamisMesaj"]').addClass('hidden');

                } else {
                    $('[data-id="YeniOkunmamisMesaj"]').html(varOlanSayi);
                    $('[data-id="YeniOkunmamisMesaj"]').removeClass('hidden');
                }
            }
        }

        function KarsiKullaniMesajiniEkle(kimden, mesaj) {

        }

        $(function () {
            var chat = $.connection.mesajHub;
            var $kullaniciID = $('#KullaniciID');
            var $karsiKullaniciID = $('#KarsiKullaniciID');
            var $message = $('#Mesaj');
            var $messages = $('#mesajListesi');


            chat.client.receiveMessage = function (kimden, mesaj, tarih) {

                const template = `
                         <div class="d-flex justify-content-start mb-6">
                          <div id="select" class="min-w-40px max-w-40"></div>
                             <div class="d-flex flex-column align-items-start">
                                 <div class="d-flex align-items-center mb-2">
                                     <div class="me-3">
                                         <span class="text-muted fs-7 mb-1">${tarih}</span>
                                     </div>
                                 </div>

                                 <div class="p-5 rounded bg-light-primary text-gray-900 fw-semibold mw-lg-400px text-end">
                                    ${mesaj}
                                 </div>
                             </div>
                         </div>`;

                const aktifKullanici = $('[data-container="active-user"]').data('id');
                console.log(aktifKullanici);
                console.log(kimden);
                console.log(tarih)
                if (kimden == aktifKullanici) {
                    $('#mesajListesi').append(template);
                    scrollToBottom('#mesajListesi');
                }


                $('.kullanici-sec').each(function (index, element) {
                    console.log(element);
                    var kullaniciID = $(element).data('id');

                    if (kimden == kullaniciID) {
                        $(element).find('[data-container="sonMesajTarihi"]').html(tarih);
                        $(element).find('.son-mesaj-icerigi').html(mesaj);
                        var varOlanKullaniciMesajSayisi = Number($(element).find('.badge.badge-sm.badge-circle.badge-light-success').html());
                        $(element).find('.badge.badge-sm.badge-circle.badge-light-success').html(varOlanKullaniciMesajSayisi + 1);
                    }
                })
            }


            $.connection.hub.start({ transport: ['webSockets', 'longPolling'], connectionTimeout: 20000 }).done(function () {
                $('#btnSendMessage').click(function () {
                    var data = {
                        gonderenkullaniciID: $kullaniciID.val(),  // Mesajı gönderen kullanıcı
                        aliciKullaniciID: $karsiKullaniciID.val(),  // Mesajın gönderildiği kullanıcı
                        mesaj: $('#Mesaj').val(),
                        tarih: new Date().toLocaleString()
                    };

                    // Mesajı SignalR hub'a gönder
                    chat.server.sendMessage(data.aliciKullaniciID, data.gonderenkullaniciID, data.mesaj, data.tarih).done(function () {
                        // Başarılıysa temizle
                        $('.kullanici-sec[data-id="' + data.gonderenkullaniciID + '"]').find('[data-container="sonMesajTarihi"]').html(data.tarih);
                        $('#Mesaj').val('').focus();
                    })
                });
                chat.server.registerUser($kullaniciID.val());

            });



            // Kullanıcı seçildiğinde mesajlaşma kısmını güncelle
            $(document).on('click', '.kullanici-sec', function (event) {
                event.preventDefault();
                BildirimSayisiniDuzenle(this);
                var kullaniciID = $(this).data('id');
                var kullaniciAd = $(this).data('ad');
                var resimYolu = $(this).data('resim');

                $('#KarsiKullaniciID').val(kullaniciID);
                $('#kullaniciChatHeader .card-title [data-container="active-user"]').text(kullaniciAd);
                $('#kullaniciChatHeader .card-title [data-container="active-user"]').attr('data-id', kullaniciID);
                $('#karsiResim').attr('src', resimYolu);

                $('#kt_chat_messenger_body').html('');

                $('#kullaniciChatEkrani').removeClass('hidden');
                $('#kullaniciChatHeader').removeClass('hidden');
                $('#kullaniciBosEkan').addClass('hidden');

                mesajlarilistele().mesajListesiOlustur();


            });

            // <-----Butona tıklayınca dosya seçme penceresini aç START------->
            $('#btnFileSelect').on('click', function () {
                $('#Dosya').click();
            });


            $('#Dosya').on('change', function () {
                var selectedFile = this.files[0];

                if (selectedFile) {
                    console.log('Seçilen dosya: ', selectedFile.name);

                }
            });

            // Dosya seçildiğinde dosya adını mesaj alanına ekleniyor
            $('#Dosya').on('change', function () {
                var selectedFile = this.files[0];
                if (selectedFile) {
                    $('#selectedFileName').val(selectedFile.name);
                    var currentMessage = $('#Mesaj').val(); // Mevcut mesajı al
                    $('#Mesaj').val(currentMessage + `\nDosya: ${selectedFile.name}`);

                }
            });


            // <-----Butona tıklayınca dosya seçme penceresini aç END------->

            $("#btnSendMessage").on('click', (event) => {
                event.preventDefault();

                // FormData oluşturuyoruz, hem mesaj hem de dosya için kullanılacak
                var formData = new FormData();

                // Mesaj ve KarsiKullaniciId ekleniyor
                formData.append('KarsiKullaniciID', $('#KarsiKullaniciID').val());  // Mesajın gönderildiği kullanıcı
                formData.append('Mesaj', $('#Mesaj').val());


                // Dosya varsa FormData'ya ekle
                var dosya = $('#Dosya')[0].files[0];  // Dosya input elementinden dosyayı alıyoruz
                if (dosya) {
                    formData.append("Dosya", dosya);
                }

                const template = ` <div class="d-flex justify-content-end mb-10">

                                            <div class="d-flex flex-column align-items-end">
                                                <div class="d-flex align-items-center mb-2">
                                                    <div class="me-3">
                                                        <span class="text-muted fs-7 mb-1">Şimdi</span>
                                                        <a href="#" class="fs-5 fw-bold text-gray-900 text-hover-primary ms-1">Sen</a>
                                                    </div>
                                                </div>
                                              <div class="p-5 rounded bg-light-primary text-gray-900 fw-semibold mw-lg-400px text-end">
                                               ${$('#Mesaj').val()}
                                           </div>
                                            </div>
                                        </div>`


                $.ajax({
                    type: "POST",
                    url: '/Mesaj/Kaydet',
                    contentType: false,  // FormData olduğu için false olarak ayarlanıyor
                    processData: false,  // FormData ile JSON string'e çevrilmesini engelliyoruz
                    data: formData,  // FormData'yı doğrudan gönderiyoruz
                    dataType: 'json',
                    success: function (data) {
                        $('#Mesaj').val('').focus();  // Mesaj kutusunu temizle
                        $('#Dosya').val('');  // Dosya seçimini temizle
                        $('#mesajListesi').append(template);
                        scrollToBottom('#mesajListesi');
                    },
                    error: function (msg) {
                        console.log("Mesaj kaydedilemedi: ", msg);
                    }
                });
            });

            $(document).on('click', '.mesaj-sil', function () {
                mesajAlani = $(this).closest('[data-id]');
                var mesajID = mesajAlani.data('id');  // Silinecek mesajın ID'sini al

                if (confirm("Bu mesajı silmek istediğinizden emin misiniz?")) {
                    $.ajax({
                        type: "POST",
                        url: '/Mesaj/MesajSil',  // Mesaj silme işlemi yapılacak controller metodu
                        data: { id: mesajID },  // Silinmesi istenen mesaj ID'sini gönder
                        success: function (response) {
                            if (response.SonucKodu === 200) {
                                // Mesaj başarılı bir şekilde silindiyse, mesajı sayfadan kaldır
                                mesajAlani.remove();
                                Swal.fire({
                                    text: "Mesaj başarıyla silindi.",
                                    icon: "success",
                                    buttonsStyling: false,
                                    confirmButtonText: "Anladım!",
                                    customClass: {
                                        confirmButton: "btn btn-primary"
                                    }
                                });
                             
                            } else {
                                Swal.fire({
                                    text: "Mesaj silinemedi. Lütfen tekrar deneyin.",
                                    icon: "error",
                                    buttonsStyling: false,
                                    confirmButtonText: "Anladım!",
                                    customClass: {
                                        confirmButton: "btn btn-primary"
                                    }
                                });
                               
                            }
                        },
                        error: function () {
                            Swal.fire({
                                text: "Bir hata oluştu, mesaj silinemedi.",
                                icon: "error",
                                buttonsStyling: false,
                                confirmButtonText: "Anladım!",
                                customClass: {
                                    confirmButton: "btn btn-primary"
                                }
                            });
                           
                        }
                    });
                }
            });


            //TOPLU SİLME İŞLEMİ



            $('#SilCheckboxGoster').on('click', function () {
                $('.mesajSec').toggleClass('hidden');
                $('.topluSilButon').toggleClass('hidden');
                $('.TumunuSec').toggleClass('hidden');
                $('.TumunuTemizle').toggleClass('hidden');

            });

            $('.TumunuSec').on('click', function () {
                var status = $(this).data('status');
                if (status == 0) {
                    $('input[type="checkbox"].mesajSec').prop('checked', true);
                    $(this).data('status', '1');
                    $(this).find('span.secim-sec').addClass('hidden');
                    $(this).find('span.secim-temizle').removeClass('hidden');
                } else {
                    $('input[type="checkbox"].mesajSec').prop('checked', false);
                    $(this).data('status', '0');
                    $(this).find('span.secim-sec').removeClass('hidden');
                    $(this).find('span.secim-temizle').addClass('hidden');
                }

            })

            $('#topluSilButon').on('click', function () {
                topluSil();
            })


            function topluSil() {
                var idListesi = []
                $('input[type="checkbox"]:checked.mesajSec').each(function () {
                    idListesi.push($(this).val());
                });

                $.ajax({
                    url: "/Mesaj/TopluSil",
                    method: "POST",
                    data: JSON.stringify(idListesi),
                    contentType: "application/json; charset=utf-8",
                    success: function (response) {
                        idListesi = [];
                        $('.mesajSec').toggleClass('hidden');
                        $('.topluSilButon').toggleClass('hidden');
                        $('.TumunuSec').toggleClass('hidden');
                        $('.TumunuTemizle').toggleClass('hidden');
                        $('input[type="checkbox"]:checked.mesajSec').each(function () {
                            $(this).attr('checked', false);
                            $('[data-container="mesaj-container"][data-id="' + $(this).val() + '"]').remove();
                        });
                        scrollToBottom();
                    },
                    error: function (xhr, status, error) {

                        console.log("Error:", xhr.responseText);
                    }
                })

            }



            // Kullanıcı arama fonksiyonu
            const kullaniciArama = () => {

                const applyLineClamp = (element, lineCount) => {
                    element.style.display = '-webkit-box';
                    element.style.webkitLineClamp = lineCount;
                    element.style.webkitBoxOrient = 'vertical';
                    element.style.overflow = 'hidden';
                    element.style.textOverflow = 'ellipsis';
                };

                const kullaniciListesi = $('#kullaniciListesi');

                const kullaniciElementiOlustur = (kullanici) => {
                    return `
                                        <div class="d-flex flex-stack py-4 kullanici-sec" data-id="${kullanici.ID}" data-ad="${kullanici.Ad} ${kullanici.Soyad}" data-resim="${kullanici.Resim}" style="">
                                            <div class="d-flex align-items-center">
                                                <!-- Kullanıcı Bilgileri -->
                                                <div class="symbol symbol-45px symbol-circle">
                                                    <span class="symbol-label bg-light text-danger fs-6 fw-bolder">
                                                        <img style="height:40px;width:40px;border-radius:100%;object-fit:cover;" src="${kullanici.Resim}" />
                                                    </span>
                                                </div>
                                                <div class="">
                                                    <div data-id="1" class="kullanici-sec fs-5 fw-bold text-gray-900 text-hover-primary mb-1">${kullanici.Ad} ${kullanici.Soyad}</div>
                                                    <div class="ps-2 fw-semibold text-muted">E-posta: ${kullanici.KullaniciAdi}</div>
                                                     <div class=" ps-2 fw-semibold text-muted text-gray-600 son-mesaj-icerigi">${kullanici.SonMesajIcerigi}</div>
                                                </div>
                                            </div>
                                            <div style="width:90px;" class="d-flex flex-column align-items-end ms-2">
                                                     <div class="text-muted fs-7 text-end pe-3">
                                                          <p class="text-gray-600 fw-semibold" data-container="sonMesajTarihi">${kullanici.SonMesajTarihi}</p>
                                                          <span class="text-muted fs-7 mb-1"></span>
                                                          <span class="badge badge-sm badge-circle badge-light-success">${kullanici.YeniMesaj}</span>
                                                     </div>

                                            </div>
                                        </div>
                                    `;
                }


                const kullaniciListesiOlustur = (aranacakKelime = "") => {
                    $.ajax({
                        type: "POST",
                        url: '/Mesaj/KullaniciGetir?aranacakKelime=' + aranacakKelime,
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {
                            const elementler = [];
                            for (let i = 0; i < data.length; i++) {
                                elementler.push(kullaniciElementiOlustur(data[i]));
                            }
                            kullaniciListesi.html(elementler.join(""));
                            // Line-clamp uygulaması burada yapılıyor
                            const mesajIcerikleri = document.querySelectorAll('.son-mesaj-icerigi');
                            mesajIcerikleri.forEach(function (element) {
                                applyLineClamp(element, 1);  // 1 satır ile sınırla
                            });
                        },
                        error: function (msg) {
                            console.log(msg);
                        }
                    });
                }

                return {
                    kullaniciListesi,
                    kullaniciListesiOlustur
                }


            }



            kullaniciArama().kullaniciListesiOlustur("");

            $('input[name="aranacakKelime"]').on('input', function () {
                if ($(this).val().length == 0 || $(this).val().length > 2) {
                    kullaniciArama().kullaniciListesiOlustur($(this).val());
                }
            });

            const mesajlarilistele = () => {
                const mesajListesi = $('#mesajListesi');

                const mesajElementiOlustur = (mesaj) => {
                    var kullaniciID = $('#KullaniciID').val();
                    var karsiKullaniciID = $('#KarsiKullaniciID').val();
                    var id = $('#ID').val();
                    var dosyaLinki = '';
                    var dosyaIkonu = '';
                    // Dosya varsa ikonu ve linkini oluştur
                    if (mesaj.DosyaAdi) {
                        var dosyaUzantisi = mesaj.DosyaAdi.split('.').pop().toLowerCase();
                        switch (dosyaUzantisi) {
                            case 'pdf':
                                dosyaIkonu = '<i class="text-gray-700 fs-1 fa fa-file-pdf-o"></i>';
                                break;
                            case 'jpg':
                            case 'jpeg':
                            case 'png':
                                dosyaIkonu = '<i class="fs-1 fa fa-file-image-o"></i>';
                                break;
                            case 'doc':
                            case 'docx':
                                dosyaIkonu = '<i class="fs-1 fa fa-file-word-o"></i>';
                                break;
                            case 'xls':
                            case 'xlsx':
                                dosyaIkonu = '<i class="fs-1 fa fa-file-excel-o"></i>';
                                break;
                            default:
                                dosyaIkonu = '<i class="fs-1 fa fa-file-o"></i>';
                                break;
                        }
                        const dosyaElementOlustur = (dosya) => {



                            // Dosya linkini oluştur
                            dosyaLinki = `
             <div class="d-flex align-items-center mt-2">
                 ${dosyaIkonu}
                 <a href="/Uploads/Dosyalar/${mesaj.DosyaAdi}" target="_blank" class="ms-2">${mesaj.DosyaAdi}</a>
             </div>`;
                        }
                    }
                    let generateLink = mesaj.Dosya ? `<a href="/Uploads/Dosyalar/${mesaj.Dosya}">${mesaj.Mesaj}</a>` : null;

                    // Karşı kullanıcıdan gelen mesaj
                    if (mesaj.KullaniciID == karsiKullaniciID && mesaj.KarsiKullaniciID == kullaniciID) {
                        return `
                <div class="d-flex justify-content-start mb-6" data-id="${mesaj.ID}">
                 <div id="select" class="min-w-40px max-w-40"></div>
                    <div class="d-flex flex-column align-items-start">
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-3">
                                <span class="text-muted fs-7 mb-1">${mesaj.Tarih}</span>
                                <a href="#" class="fs-5 fw-bold text-gray-900 text-hover-primary ms-1"></a>
                            </div>
                        </div>

                        <div class="p-5 rounded bg-light-primary text-gray-900 fw-semibold mw-lg-400px text-end">

                            ${generateLink ? generateLink : mesaj.Mesaj}
                        </div>

                    </div>
                </div>`;
                    }
                    // Kullanıcıdan gelen mesaj

                    else if (mesaj.KullaniciID == kullaniciID && mesaj.KarsiKullaniciID == karsiKullaniciID) {
                        return `
                <div data-container="mesaj-container" class="d-flex justify-content-end mb-6" data-id="${mesaj.ID}">

                    <div class="d-flex flex-column align-items-end">
                        <div class="d-flex align-items-center mb-2">
                            <div class="me-3">
                                <span class="text-muted fs-7 mb-1">${mesaj.Tarih}</span>
                                <a href="#" class="fs-5 fw-bold text-gray-900 text-hover-primary ms-1">Sen</a>
                            </div>
                        </div>
                        <div class="d-flex align-items-center Silme-Checkbox-Gizle">
                            <div class="me-4 ">
                                <input type="checkbox" class="mesajSec hidden" value="${mesaj.ID}" />
                            </div>
                            <div class="p-5 rounded bg-light-primary text-gray-900 fw-semibold mw-lg-400px text-end">
                                ${generateLink ? generateLink : mesaj.Mesaj}
                            </div>
                        </div>

                    </div>
                </div>`;
                    }
                    return '';
                };

                const mesajListesiOlustur = () => {
                    $.ajax({
                        type: "POST",
                        url: '/Mesaj/MesajListesiGetir',
                        contentType: "application/json; charset=utf-8",
                        success: function (data) {
                            const elementler = [];
                            data = data.filter(m => (m.KarsiKullaniciID == $('#KarsiKullaniciID').val() || m.KullaniciID == $('#KarsiKullaniciID').val()))
                            for (let i = 0; i < data.length; i++) {
                                elementler.push(mesajElementiOlustur(data[i]));
                            }
                            $('#mesajListesi').html(elementler.join("")); // Mevcut mesajları tamamen yenile
                            scrollToBottom('#mesajListesi');
                        },
                        error: function (msg) {
                            console.log(msg);
                        }
                    });

                };

                return {
                    mesajListesi,
                    mesajElementiOlustur,
                    mesajListesiOlustur
                };
            };

            mesajlarilistele();



        });
    </script>
}
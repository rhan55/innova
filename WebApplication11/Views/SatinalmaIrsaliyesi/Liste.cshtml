
@model YKPortal.Models.Dto.BelgeListeViewModel
@{
    string Modul = "";
    switch (Request.QueryString["Tip"])
    {
        case "AI":
            Modul = "Satınalma İrsaliyesi";
            break;
        default:
            break;
    }
    ViewBag.Title = Modul + " Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="kt_content_container" class="container-fluid p-0 m-0">
    <div class="card bg-transparent border-0 shadow-none m-0 p-0">
        <div class="card-header align-items-center border-0 shadow-0 gap-2 gap-md-5 p-0 m-0">


            <div class="card-toolbar flex-row-fluid justify-content-end gap-3">
                <button type="button" id="topluSilButon" class="btn btn-light-primary btn-sm fw-bold" onclick="$('#DivFiltre').toggle();">
                    <span class="indicator-label fw-bold">Filtre</span>
                    <i class="ki-duotone ki-filter">
                        <span class="path1"></span>
                        <span class="path2"></span>
                    </i>
                </button>

                <!--end::Menu-->
                <!--end::Export dropdown-->
                <!--begin::Hide default export buttons-->
                <div id="kt_datatable_example_buttons" class="d-none"></div>
                <!--end::Hide default export buttons-->
                <a href="@Url.Action("Detay","SatinalmaIrsaliyesi",new { Tip = Request.QueryString["Tip"], KayitID = "" })" class="btn btn-sm btn-primary me-7" style="width:100px;">Yeni İrsaliye</a>
            </div>
        </div>
    </div>

</div>





<div class="container-fluid" id="DivFiltre" name="DivFiltre" style="display:none;">
    <div class="card border-0 shadow-none">
        <div class="card-body">

            <!--begin::Filtreleme alanı-->
            <form method="POST" action="/SatinalmaIrsaliyesi/Liste/?Tip=AI" class="content p-0" id="datatableFilters">
                <div class="d-flex">
                    <h3 class="text-primary fw-bold mb-4">Filtreler</h3>
                    <i class="ki-duotone text-primary ki-filt er-search fs-2">
                        <span class="path1"></span>
                        <span class="path2"></span>
                        <span class="path3"></span>
                    </i>
                </div>

                <div class="row">
                    <div class="col-lg-3">
                        <!--begin::Label-->
                        <label for="CariAdi" class="fw-bold fs-6 mb-1 text-gray-600">Cari</label>
                        <!--end::Label-->
                        <!--begin::Input-->
                        <input type="text" name="CariAdi" id="CariAdi" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.CariAdi)" />
                        <!--end::Input-->
                    </div>
                    <div class="col-lg-3">
                        <!--begin::Label-->
                        <label for="BelgeNo" class="fw-bold fs-6 mb-1 text-gray-600">Belge Numarası</label>
                        <!--end::Label-->
                        <!--begin::Input-->
                        <input type="text" name="BelgeNo" id="BelgeNo" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.BelgeNo)" />
                        <!--end::Input-->
                    </div>

                    <div class="col-lg-3">
                        <!--begin::Label-->
                        <label for="BaslangicTarihi" class="fw-bold fs-6 mb-1 text-gray-600">Başlangıç Tarihi</label>
                        <!--end::Label-->
                        <!--begin::Input-->
                        <input type="datetime-local" name="BaslangicTarihi" id="BaslangicTarihi" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" required
                               value="@(ViewBag.Filters.BaslangicTarihi.ToString("yyyy-MM-ddTHH:mm"))" />
                        <!--end::Input-->
                    </div>

                    <div class="col-lg-3">
                        <!--begin::Label-->
                        <label for="BitisTarihi" class="fw-bold fs-6 mb-1 text-gray-600">Bitiş Tarihi</label>
                        <!--end::Label-->
                        <input type="datetime-local" name="BitisTarihi" id="BitisTarihi" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" required
                               value="@(ViewBag.Filters.BitisTarihi.ToString("yyyy-MM-ddTHH:mm"))" />
                        <!--end::Input-->
                    </div>
                </div>
                <div class="row">

                    <div class="col-lg-3">
                        <!--begin::Label-->
                        <label for="Durumu" class="fw-bold fs-6 mb-1 text-gray-600">Durumu</label>
                        <!--begin::Input-->
                        <div class="form-group">
                            <select class="px-2 py-1 rounded-1 form-control form-control-solid" data-control="select2" name="Durumu" id="Durumu"
                                    aria-label="Floating label select example">
                                <option value="">Lütfen Seçim Yapınız</option>
                                <option value="Öneri" @(ViewBag.Durumu == "Öneri" ? "selected" : "")>Öneri</option>
                                <option value="Onaylandı" @(ViewBag.Durumu == "Onaylandı" ? "selected" : "")>Onaylandı</option>
                                <option value="Reddedildi" @(ViewBag.Durumu == "Reddedildi" ? "selected" : "")>Reddedildi</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-3"></div>
                    <div class="col-lg-3"></div>
                    <div class="col-lg-3 mt-4 d-flex justify-content-end align-items-end">
                        <button type="button" id="filtreleriTemizle" class="btn btn-light btn-sm fw-bold me-3" data-kt-users-modal-action="cancel">Temizle</button>
                        <button type="submit" class="btn btn-primary btn-sm fw-bold" data-kt-users-modal-action="Ara">
                            <span class="indicator-label">Filtrele</span>
                        </button>
                    </div>
                </div>

            </form>
        </div>
    </div>
</div>


<div class="container-fluid px-4">
    <div class="row">
        <div style="overflow: scroll; height:710px ;">


            <style>
                .max-w-700 {
                    max-width: 700px !important;
                }

                .max-w-700 {
                    max-width: 700px !important;
                }
            </style>

            <table class="table align-middle border rounded-1 table-row-dashed fs-6 g-5">
                <thead>

                    <!--begin::Table row-->
                    <tr>
                        <th><strong>Tarih</strong></th>
                        <th><strong>Belge No</strong></th>
                        @if (Request.QueryString["Tip"] == "AI")
                        {
                            <th class="max-w-700"><strong>Cari</strong></th>
                        }
                        else if (Request.QueryString["Tip"] == "DT")
                        {
                            <th><strong>Çıkış Depo</strong></th>
                            <th><strong>Giriş Depo</strong></th>
                        }
                        <th style="text-align:right;"><strong>Tutar</strong></th>
                        <th class="text-end"><strong>İşlemler</strong></th>
                    </tr>
                    <!--end::Table row-->
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        for (var i = 0; i < Model.Belgeler.Rows.Count; i++)
                        {
                            <tr>
                                <td class="text-gray-600 fw-semibold" style="vertical-align: middle;">
                                    @(Convert.ToDateTime(Model.Belgeler.Rows[i]["Tarih"]).ToString("dd-MM-yyyy"))
                                </td>
                                <td style="vertical-align: middle;">
                                    <span style="color:blue;">@(Convert.ToString(Model.Belgeler.Rows[i]["BelgeNo"]))</span>
                                </td>
                                @if (Request.QueryString["Tip"] == "AI")
                                {
                                    <td class=" max-w-700 text-gray-600 fw-semibold">
                                        @(Convert.ToString(Model.Belgeler.Rows[i]["CariIsim"]))
                                    </td>
                                }
                                else if (Request.QueryString["Tip"] == "DT")
                                {
                                    <td class="text-gray-600 fw-semibold" style="vertical-align: middle;">
                                        @(Convert.ToString(Model.Belgeler.Rows[i]["DepoCikis"]))
                                    </td>
                                    <td class="text-gray-600 fw-semibold" style="vertical-align: middle;">
                                        @(Convert.ToString(Model.Belgeler.Rows[i]["DepoGiris"]))
                                    </td>
                                }
                                <td class="text-gray-600 fw-semibold" style="text-align:right;vertical-align:middle;">
                                    @(String.Format("{0:N2}",Convert.ToDecimal(Model.Belgeler.Rows[i]["Tutar"]))) @(Convert.ToString(Model.Belgeler.Rows[i]["DovizBirimi"]))
                                </td>
                                <td class="text-end" style="vertical-align: middle;">
                                    <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm  fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        İşlemler
                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                    </a>
                                    <!--begin::Menu-->
                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item px-0 py-0">
                                            <a href="/SatinalmaIrsaliyesi/Duzenle?id=@(Convert.ToString(Model.Belgeler.Rows[i]["ID"]))&Tip=@(Request.QueryString["Tip"])" class="menu-link rounded-0 py-0  px-2">Düzenle</a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->

                                        @if (Model.Sil)
                                        {
                                            <div class="menu-item px-0 py-0">
                                                <a href="/SatinalmaIrsaliyesi/Sil?id=@(Convert.ToString(Model.Belgeler.Rows[i]["ID"]))&Tip=@(Request.QueryString["Tip"])" class="menu-link rounded-0 py-0  px-2" onclick="return confirm('Silmek istediğinizden emin misiniz?')">Sil</a>
                                            </div>
                                        }
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

        </div>

    </div>
</div>

@section Scripts {

    <script>

        const filtreleriTemizle = document.querySelector("#filtreleriTemizle");

        if (filtreleriTemizle) {
            filtreleriTemizle.addEventListener("click", function (e) {
                e.preventDefault();

                // Tüm inputları temizleyin
                document.querySelector("form#datatableFilters").querySelectorAll("input").forEach(input => {
                    input.value = "";
                });

                // Durumu selectbox'ını sıfırlayın
                const durumuSelect = document.querySelector("#Durumu");
                if (durumuSelect) {
                    durumuSelect.selectedIndex = 0;
                }

                // Formu gönderin
                document.querySelector("form#datatableFilters").submit();
            });
        }

    </script>
}

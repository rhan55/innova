@model System.Data.DataTable
@{
    ViewBag.Title = "Mail Kalıbı Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="card card-flush shadow-none border-0">
        <div class="card-header align-items-center py-5 gap-2 gap-md-5">
            <div class="card-title">
                <!--begin::Search-->
                <div class="d-flex align-items-center position-relative my-1">
                    <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                        <span class="path1 text-gray-500"></span>
                        <span class="path2 text-gray-500"></span>
                    </i>
                    <input type="text" data-kt-filter="search" placeholder="Ara" class="form-control  w-250px py-1 ps-14" />
                </div>
                <!--end::Search-->
            </div>
            <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                <!--begin::Export dropdown-->
                <button type="button" class="btn btn-sm fw-bold btn-light-primary" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                    <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                    Dışarı aktar
                </button>
                <!--begin::Menu-->
                <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px p-0" data-kt-menu="true">
                    <!--begin::Menu item-->
                    <div class="menu-item p-0">
                        <a href="#" class="menu-link px-2 py-0" data-kt-export="copy">
                            Panoya Kopyala
                        </a>
                    </div>
                    <!--end::Menu item-->
                    <!--begin::Menu item-->
                    <div class="menu-item p-0">
                        <a href="#" class="menu-link px-2 py-0" data-kt-export="excel">
                            Excel olarak dışarı aktar
                        </a>
                    </div>
                    <!--end::Menu item-->
                    <!--begin::Menu item-->
                    <div class="menu-item p-0">
                        <a href="#" class="menu-link px-2 py-0" data-kt-export="csv">
                            CSV olarak dışarı aktar
                        </a>
                    </div>
                    <!--end::Menu item-->
                    <!--begin::Menu item-->
                    <div class="menu-item p-0">
                        <a href="#" class="menu-link px-2 py-0" data-kt-export="pdf">
                            PDF olarak dışarı aktar
                        </a>
                    </div>
                    <!--end::Menu item-->
                </div>
                <!--end::Menu-->
                <!--end::Export dropdown-->
                <!--begin::Hide default export buttons-->
                <div id="kt_datatable_example_buttons" class="d-none"></div>
                <!--end::Hide default export buttons-->
                <a href="/MailKaliplari/Ekle" class="btn btn-sm fw-bold btn-primary">
                    <i class="ki-duotone ki-plus fs-2"></i>Yeni
                </a>
            </div>
        </div>
    </div>
    <div class="card card-flush mt-4 scroll-x">
        <!--begin::Table-->
        <table class="table align-middle table-row-dashed fs-6" id="E-Mail-datatable">
            <thead>
                <tr class="text-start" style="font-size:15px;">

                    <th class="min-w-125px"><strong>Kod</strong></th>
                    <th class="min-w-125px"><strong>İsim</strong></th>
                    <th class="min-w-125px"><strong>İçerik</strong></th>
                    <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                </tr>
            </thead>
            <tbody class="text-gray-600 fw-semibold">
                @for (var i = 0; i < Model.Rows.Count; i++)
                {
                    <tr class="">

                        <td class="align-items-center p-0">
                            <div href="" class="text-gray-600 text-hover-primary ">@(Convert.ToString(Model.Rows[i]["Kod"]))</div>
                        </td>
                        <td class="align-items-center p-0">
                            <div href="" class="text-gray-600 text-hover-primary ">@(Convert.ToString(Model.Rows[i]["Isim"]))</div>
                        </td>
                        <td class=" align-items-center p-0">
                            <div href="" class="text-gray-600 text-hover-primary ">@(Convert.ToString(Model.Rows[i]["Icerik"]))</div>
                        </td>
                     
                        <td class="text-end py-1">
                            <a href="#" class="btn btn-light fw-bold  btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                İşlemler
                                <i class="ki-duotone ki-down fs-5 ms-1"></i>
                            </a>
                            <!--begin::Menu-->
                            <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                <!--begin::Menu item-->
                                <div class="menu-item p-0">
                                    <a href="/MailKaliplari/Duzenle/@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link px-2 py-0">Düzenle</a>
                                </div>
                                <!--end::Menu item-->
                                <!--begin::Menu item-->
                                <div class="menu-item p-0">
                                    <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link px-2 py-0 btn-sil" data-bs-toggle="modal" data-bs-target="#Email-Kalibi-silme">
                                        Sil
                                    </button>

                                </div>
                                <!--end::Menu item-->
                            </div>
                            <!--end::Menu-->
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <!--end::Table-->
    </div>
</div>


<div class="modal fade" id="Email-Kalibi-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Email Kalıbı Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>E-mail kalıbını  istediğinize emin misiniz</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("Sil","MailKaliplari",null)">
                    <input type="hidden" name="id" value="" />
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                })
            })
        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    "info": false,
                    'order': [],
                    paging: false,
                    columnDefs: [

                    ]

                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'E-Mail-datatable' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#E-Mail-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}



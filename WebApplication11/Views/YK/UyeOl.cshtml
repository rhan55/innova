                                    <!--end::Input group-->
                                    <!--begin::Input group-->
                                </div>
                                <!--end::Input group-->
                                <!--begin::Row Input group-->
                                <div class="row mb-6">
                                    <!--begin::Input group-->
                                    <div class="col-lg-6">
                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">İletişim Numarası</label>
                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input type="text" class="form-control border-0 bg-light @(ViewData.ModelState.ContainsKey("Iletisim") ? "is-invalid" : "")" name="Iletisim" placeholder="İletişim Numarası" id="exampleFormControlTextarea1" />
                                        <!--end::Input-->

                                        <input class="form-control border-0 bg-light @(ViewData.ModelState.ContainsKey("Ad") ? "is-invalid" : "")" name="Ad" placeholder="Ad" id="exampleFormControlTextarea1" />
                                        @if (ViewData.ModelState.ContainsKey("Ad") && ViewData.ModelState["Ad"].Errors.Count() > 0)
                                        {
                                            foreach (var error in ViewData.ModelState["Ad"].Errors)
                                            {
                                                <div>@error.ErrorMessage</div>
                                            }
                                        }
                                        <!--end::Input-->
                                    </div>
                                    <!--end::Input group-->
                                    <!--begin::Input group-->
                                    <div class="col-lg-6">
                                        <!--begin::Label-->

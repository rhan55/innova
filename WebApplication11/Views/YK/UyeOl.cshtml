                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input class="form-control border-0 bg-light @(ViewData.ModelState.ContainsKey("Soyad") ? "is-invalid" : "")" name="Soyad" placeholder="Soyad" id="exampleFormControlTextarea1" />
                                        @if (ViewData.ModelState.ContainsKey("Soyad") && ViewData.ModelState["Soyad"].Errors.Count() > 0)
                                        {
                                            foreach (var error in ViewData.ModelState["Soyad"].Errors)
                                            {
                                                <div>@error.ErrorMessage</div>
                                            }
                                        }
                                        <!--end::Input-->
                                    </div>
                                    <!--end::Input group-->
                                    <!--begin::Input group-->
                                </div>
                                <!--end::Input group-->
                                <!--begin::Row Input group-->
                                <div class="row mb-6">
                                    <!--begin::Input group-->

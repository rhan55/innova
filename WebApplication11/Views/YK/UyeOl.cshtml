                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">Vergi Dairesi</label>
                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input class="form-control border-0 bg-light @(ViewData.ModelState.ContainsKey("VergiDairesi") ? "is-invalid" : "")" name="VergiDairesi" placeholder="VergiDairesi" id="exampleFormControlTextarea1" />
                                        @if (ViewData.ModelState.ContainsKey("VergiDairesi") && ViewData.ModelState["VergiDairesi"].Errors.Count() > 0)
                                        {
                                            foreach (var error in ViewData.ModelState["VergiDairesi"].Errors)
                                            {
                                                <div>@error.ErrorMessage</div>
                                            }
                                        }
                                        <!--end::Input-->
                                    </div>
                                    <!--end::Input group-->
                                    <!--begin::Input group-->
                                    <div class="col-lg-6">
                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">Vergi Numarası</label>
                                        <!--end::Label-->

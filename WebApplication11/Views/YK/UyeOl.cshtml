<!--begin::Body-->

<body id="kt_body" class="auth-bg">
    <!--begin::Theme mode setup on page load-->
    <script>var defaultThemeMode = "light"; var themeMode; if (document.documentElement) { if (document.documentElement.hasAttribute("data-bs-theme-mode")) { themeMode = document.documentElement.getAttribute("data-bs-theme-mode"); } else { if (localStorage.getItem("data-bs-theme") !== null) { themeMode = localStorage.getItem("data-bs-theme"); } else { themeMode = defaultThemeMode; } } if (themeMode === "system") { themeMode = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"; } document.documentElement.setAttribute("data-bs-theme", themeMode); }</script>
    <!--end::Theme mode setup on page load-->
    <!--begin::Main-->
    <!--begin::Root-->
    <div class="d-flex flex-root">
        <!--begin::Authentication - Sign-in -->
        <div class="d-flex flex-column flex-lg-row flex-column-fluid w-lg-50">
            <!--begin::Body-->
            <div class="d-flex flex-column flex-lg-row-fluid  p-10 order-2 order-lg-1">
                <!--begin::Form-->
                <div class="d-flex flex-center flex-column flex-lg-row-fluid">
                    <!--begin::Wrapper-->
                    <div class="w-lg-700px p-10">
                        <form id="kt_modal_add_user_form" class="form w-100 Uye-Ol-Form" action="@Url.Action("UyeOl","YK",null)" method="post" enctype="multipart/form-data">
                            <!--begin::Heading-->
                            <div class="text-center mb-11">
                                <!--begin::Title-->
                                <h1 class="text-gray-900 fw-bolder mb-3">Yeni Üyelik</h1>
                                <!--end::Title-->

                            </div>
                            <!--begin::Heading-->
                           
                            @if (Model != null)
                            {
                                if (Model.Rows.Count > 0)
                                {
                                    string ID = Convert.ToString(Model.Rows[0]["ID"]);
                                    string Bilgi = Convert.ToString(Model.Rows[0]["Bilgi"]);
                                    if (ID == "0")
                                    {
                                        <!--begin::Alert-->
                                        <div class="alert alert-danger d-flex align-items-center p-5">
                                            <!--begin::Icon-->
                                            <i class="ki-duotone ki-shield-tick fs-2hx text-danger me-4"><span class="path1"></span><span class="path2"></span></i>
                                            <!--end::Icon-->
                                            <!--begin::Wrapper-->
                                            <div class="d-flex flex-column">
                                                <!--begin::Content-->
                                                <span>@Bilgi</span>
                                                <!--end::Content-->
                                            </div>
                                            <!--end::Wrapper-->
                                        </div>
                                        <!--end::Alert-->
                                    }
                                }
                            }

                            <!--begin::Scroll-->
                            <div class="d-flex flex-column scroll-y px-5 px-lg-10 container ">
                                <!--begin::Row Input group-->
                                <div class="row mb-6">
                                    <input type="hidden" name="ID" value="" />
                                    <!--begin::Input group-->
                                    <div class="col-lg-6">
                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">Firma Kısa Adı</label>
                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input type="text" name="Isim" class="form-control form-control-solid mb-3 mb-lg-0 @(ViewData.ModelState.ContainsKey("Isim") ? "is-invalid" : "") " placeholder="Firma Kısa Adı" value="" />
                                        @if (ViewData.ModelState.ContainsKey("Isim") && ViewData.ModelState["Isim"].Errors.Count() > 0)
                                        {
                                            foreach (var error in ViewData.ModelState["Isim"].Errors)
                                            {
                                                <div class="invalid-feedback">@error.ErrorMessage</div>
                                            }
                                        }
                                        <!--end::Input-->
                                    </div>
                                    <!--end::Input group-->
                                    <!--begin::Input group-->
                                    <div class="col-lg-6">
                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">Ünvan</label>
                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input type="text" name="Unvan" class="form-control form-control-solid mb-3 mb-lg-0 @(ViewData.ModelState.ContainsKey("Unvan") ? "is-invalid" : "") " placeholder="Ünvan" value="" />
                                        @if (ViewData.ModelState.ContainsKey("Unvan") && ViewData.ModelState["Unvan"].Errors.Count() > 0)
                                        {
                                            foreach (var error in ViewData.ModelState["Isim"].Errors)
                                            {
                                                <div class="invalid-feedback">@error.ErrorMessage</div>
                                            }
                                        }
                                        <!--end::Input-->

                                    </div>
                                    <!--end::Input group-->
                                </div>
                                <!--begin::Row Input group-->
                                <!--begin::Row Input group-->
                                <div class="row mb-6">
                                    <!--begin::Input group-->
                                    <div class="col-lg-6  ">
                                        <div>
                                            <!--begin::Label-->
                                            <label class="required fw-semibold fs-6 mb-2">E-Mail/Kullanıcı Adı</label>
                                            <!--end::Label-->
                                            <!--begin::Input-->
                                            <input type="email" name="EMail" class=" Inputmask form-control form-control-solid mb-3 mb-lg-0 @(ViewData.ModelState.ContainsKey("EMail") ? "is-invalid" : "") " placeholder="EMail" value="" />
                                            <!--end::Input-->
                                            @if (ViewData.ModelState.ContainsKey("EMail") && ViewData.ModelState["EMail"].Errors.Count() > 0)
                                            {
                                                foreach (var error in ViewData.ModelState["EMail"].Errors)
                                                {
                                                    <div>@error.ErrorMessage</div>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <div class="col-lg-6 ">
                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">Parola</label>
                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input type="text" name="Parola" class="form-control form-control-solid mb-3 mb-lg-0  @(ViewData.ModelState.ContainsKey("Parola") ? "is-invalid" : "")" placeholder="Parola" value="" />
                                        <!--end::Input-->
                                        @if (ViewData.ModelState.ContainsKey("Parola") && ViewData.ModelState["Parola"].Errors.Count() > 0)
                                        {
                                            foreach (var error in ViewData.ModelState["Parola"].Errors)
                                            {
                                                <div>@error.ErrorMessage</div>
                                            }
                                        }
                                    </div>
                                </div>
                                <!--begin::Row Input group-->
                                <!--begin::Row Input group-->
                                <div class="row mb-6">
                                    <!--begin::Input group-->

                                    <!--begin::Input group-->
                                    <div class="col-lg-6">
                                        <div class="d-flex flex-column col-lg-12">
                                            <label class="required fw-semibold fs-6 mb-2">İl</label>
                                            <select name="Il" class="form-select form-select-solid @(ViewData.ModelState.ContainsKey("Il") ? "is-invalid" : "")" aria-label="Select example">
                                                <option>Open this select menu</option>
                                                <option value="Antalya">Antalya</option>
                                            </select>
                                            @if (ViewData.ModelState.ContainsKey("Il") && ViewData.ModelState["Il"].Errors.Count() > 0)
                                            {
                                                foreach (var error in ViewData.ModelState["Il"].Errors)
                                                {
                                                    <div class="">@error.ErrorMessage</div>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <div class="d-flex flex-column col-lg-12">
                                            <label class="required fw-semibold fs-6 mb-2">İlçe</label>
                                            <select name="Ilce" class="form-select form-select-solid size-4 @(ViewData.ModelState.ContainsKey("Ilce") ? "is-invalid" : "") " aria-label="Select example">

                                        <!--begin::Label-->
                                        <label class="required fw-semibold fs-6 mb-2">Adres</label>
                                        <!--end::Label-->
                                        <!--begin::Input-->
                                        <input class="form-control border-0 bg-light @(ViewData.ModelState.ContainsKey("Adres") ? "is-invalid" : "")" name="Adres" placeholder="Adres" id="exampleFormControlTextarea1" />

@using System.Linq @* Razor View içinde LINQ kullanma ihtimalinize karşı eklendi *@

@{
    ViewBag.Title = "Ant Oto";
    Layout = null; // "~/Views/Shared/_Layout.cshtml";
}

<div id="content-anasayfa-tab" class="container-fluid">
    <div class="row">
        <h2>Aktarım</h2>

        @Html.AntiForgeryToken()

        <div>
            <label for="yilSelect">Yıl:</label>
            <select id="yilSelect">
                @for (int y = DateTime.Now.Year; y >= DateTime.Now.Year - 10; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <label for="aySelect">Ay:</label>
            <select id="aySelect">
                @* Düzeltme: Ay döngüsü 1'den 12'ye gitmeli *@
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@m</option>
                }
            </select>

            @* Önizleme butonu eklendi *@
            <button id="onizleBtn" name="onizleBtn" class="btn btn-info">Önizle</button>
            <button id="aktarBtn" name="aktarBtn" class="btn btn-primary">Aktar (Test) </button>
            <button id="aktarBtn2" name="aktarBtn2" class="btn btn-primary">Aktar (Canlı) </button>
        </div>

        @* Önizleme tablosunun gösterileceği alan eklendi *@
    <div id="previewContainer" style="margin-top:25px;">
        <h3>Önizleme Tablosu</h3>
        <div id="jsonBilgisi" class="table-responsive">
           
        </div>
        <div id="previewTable" class="table-responsive">
            <p class="text-muted">Önizlemek için yıl ve ay seçip "Önizle" butonuna tıklayın.</p>
        </div>
    </div>


        <div id="progressContainer" style="margin-top:15px; display:none; width:100%; max-width:600px;">
            <div style="border:1px solid #ccc; height:25px; border-radius:4px; overflow:hidden;">
                <div id="progressBar" style="height:100%; width:0%; background-color:#28a745; transition: width0.3s;"></div>
            </div>
            <div id="progressText" style="margin-top:5px;">0%</div>
        </div>

        <div id="resultMessage" style="margin-top:15px;"></div>

            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script>

                // =======================================================
                // 1. Yardımcı Fonksiyon: JSON Verisinden HTML Tablosu Oluşturma
                // =======================================================
                function buildTable(dataArray) {
                    if (dataArray.length === 0) {
                        return '<div class="alert alert-info">Seçilen dönem için aktarılacak veri yok.</div>';
                    }

                    // Sütun başlıklarını ilk nesnenin anahtarlarından al
                    var headers = Object.keys(dataArray[0]);
                    var table = '<table class="table table-striped table-bordered table-sm">';

                    // Başlık satırı (Header Row)
                    table += '<thead><tr>';
                    headers.forEach(function(header) {
                        table += '<th>' + header + '</th>';
                    });
                    table += '</tr></thead>';

                    // Veri satırları (Data Rows)
                    table += '<tbody>';
                    dataArray.forEach(function(item) {
                        table += '<tr>';
                        headers.forEach(function(header) {
                            var value = item[header] === null || item[header] === undefined ? '' : item[header];

                            // Tarih formatını daha okunaklı hale getirme (örneğin JSON'dan /Date(12345)/ formatında geliyorsa)
                            if (value && typeof value === 'string' && value.indexOf('/Date(') === 0) {
                                var dateMatch = /\/Date\((\d+)\)\//.exec(value);
                                if(dateMatch) {
                                    value = new Date(parseInt(dateMatch[1])).toLocaleDateString();
                                }
                            }

                            table += '<td>' + value + '</td>';
                        });
                        table += '</tr>';
                    });
                    table += '</tbody></table>';

                    return table;
                }

                // =======================================================
                // 2. Önizleme Butonu İşlevi
                // =======================================================
                $('#onizleBtn').on('click', function (e) {
    e.preventDefault();

    $('#previewTable').html('<p class="text-info">Veriler yükleniyor...</p>');

    var yil = $('#yilSelect').val();
    var ay = $('#aySelect').val();
    var token = $('input[name="__RequestVerificationToken"]').val();

    $.ajax({
        // Controller metod adınız artık AntOto1AktarimYap olmalı
        url: '@Url.Action("AntOto1AktarimYap", "YK")',
        method: 'POST',
        // aktar parametresini false olarak gönderiyoruz
        data: { ay: ay, yil: yil, aktar: false,canli=false, __RequestVerificationToken: token },
        success: function (data) {

            // Controller'ınız başarı durumunda datayı doğrudan 'message' alanında döndürüyor.
            if (data && data.success && data.message) {
                // Controller'dan dönen JSON: { success: true, message: payloadList }
                // Bizim ihtiyacımız olan veri listesi 'data.message' içinde.
                var veriListesi = data.message;
                var jsonText = data.jsonText;

                $("#jsonBilgisi").text(jsonText);

                var tableHtml = buildTable(veriListesi);
                $('#previewTable').html(tableHtml);
            } else {
                // Eğer success=true döndü ama message boşsa (0 kayıt gibi)
                var uyari = data && data.message && typeof data.message === 'string'
                            ? data.message // String olarak dönen mesajı kullan
                            : 'Önizlenecek veri bulunamadı veya bir hata oluştu.';

                $('#previewTable').html('<div class="alert alert-warning">' + uyari + '</div>');
            }
        },
        error: function(xhr, status, err) {
            $('#previewTable').html('<div class="alert alert-danger">Sunucuya bağlanırken hata oluştu: ' + err + '</div>');
        }
    });
});

                // =======================================================
                // 3. Mevcut Aktar Butonu İşlevi
                // =======================================================
                $(function(){
                    $('#aktarBtn').on('click', function(e){
                        e.preventDefault();

                        // Önizleme alanını temizle
                        $('#previewTable').html('');

                        // Prevent double clicks by disabling controls immediately
                        $('#aktarBtn').prop('disabled', true);
                        $('#onizleBtn').prop('disabled', true); // Yeni eklendi
                        $('#yilSelect').prop('disabled', true);
                        $('#aySelect').prop('disabled', true);

                        var yil = $('#yilSelect').val();
                        var ay = $('#aySelect').val();
                        $('#resultMessage').html('');
                        $('#progressBar').css('width', '0%');
                        $('#progressText').text('0%');
                        $('#progressContainer').show();

                        var token = $('input[name="__RequestVerificationToken"]').val();

                        // Simulate progress locally while server work happens
                        var progress =0;
                        var progressInterval = setInterval(function(){
                            progress = Math.min(95, progress + Math.floor(Math.random()*10)+5);
                            $('#progressBar').css('width', progress + '%');
                            $('#progressText').text(progress + '%');
                        },400);

                        $.ajax({
                            url: '@Url.Action("AntOto1AktarimYap", "YK")',
                            method: 'POST',
                            data: { ay:ay, yil: yil,aktar:true,canli:false, __RequestVerificationToken: token },
                            success: function(resp){
                                clearInterval(progressInterval);
                                if(resp && resp.success){
                                    $('#progressBar').css('width', '100%');
                                    $('#progressText').text('100%');
                                    $('#resultMessage').html('<div class="alert alert-success">'+ resp.message +'</div>');
                                } else {
                                    $('#resultMessage').html('<div class="alert alert-danger">'+ (resp ? resp.message : 'Bilinmeyen hata') +'</div>');
                                }

                                // Re-enable controls
                                $('#aktarBtn').prop('disabled', false);
                                $('#onizleBtn').prop('disabled', false); // Yeni eklendi
                                $('#yilSelect').prop('disabled', false);
                                $('#aySelect').prop('disabled', false);
                            },
                            error: function(xhr, status, err){
                                clearInterval(progressInterval);
                                $('#resultMessage').html('<div class="alert alert-danger">Hata: ' + err + '</div>');

                                // Re-enable controls
                                $('#aktarBtn').prop('disabled', false);
                                $('#onizleBtn').prop('disabled', false); // Yeni eklendi
                                $('#yilSelect').prop('disabled', false);
                                $('#aySelect').prop('disabled', false);
                            }
                        });
                    });

                       $('#aktarBtn2').on('click', function(e){
       e.preventDefault();

       // Önizleme alanını temizle
       $('#previewTable').html('');

                           // Prevent double clicks by disabling controls immediately
                           $('#aktarBtn').prop('disabled', true);
                           $('#aktarBtn2').prop('disabled', true);
       $('#onizleBtn').prop('disabled', true); // Yeni eklendi
       $('#yilSelect').prop('disabled', true);
       $('#aySelect').prop('disabled', true);

       var yil = $('#yilSelect').val();
       var ay = $('#aySelect').val();
       $('#resultMessage').html('');
       $('#progressBar').css('width', '0%');
       $('#progressText').text('0%');
       $('#progressContainer').show();

       var token = $('input[name="__RequestVerificationToken"]').val();

       // Simulate progress locally while server work happens
       var progress =0;
       var progressInterval = setInterval(function(){
           progress = Math.min(95, progress + Math.floor(Math.random()*10)+5);
           $('#progressBar').css('width', progress + '%');
           $('#progressText').text(progress + '%');
       },400);

       $.ajax({
           url: '@Url.Action("AntOto1AktarimYap", "YK")',
           method: 'POST',
           data: { ay:ay, yil: yil,aktar:true,canli:true, __RequestVerificationToken: token },
           success: function(resp){
               clearInterval(progressInterval);
               if(resp && resp.success){
                   $('#progressBar').css('width', '100%');
                   $('#progressText').text('100%');
                   $('#resultMessage').html('<div class="alert alert-success">'+ resp.message +'</div>');
               } else {
                   $('#resultMessage').html('<div class="alert alert-danger">'+ (resp ? resp.message : 'Bilinmeyen hata') +'</div>');
               }

               // Re-enable controls
               $('#aktarBtn').prop('disabled', false);
               $('#aktarBtn2').prop('disabled', false);
               $('#onizleBtn').prop('disabled', false); // Yeni eklendi
               $('#yilSelect').prop('disabled', false);
               $('#aySelect').prop('disabled', false);
           },
           error: function(xhr, status, err){
               clearInterval(progressInterval);
               $('#resultMessage').html('<div class="alert alert-danger">Hata: ' + err + '</div>');

               // Re-enable controls
               $('#aktarBtn').prop('disabled', false);
               $('#aktarBtn2').prop('disabled', false);
               $('#onizleBtn').prop('disabled', false); // Yeni eklendi
               $('#yilSelect').prop('disabled', false);
               $('#aySelect').prop('disabled', false);
           }
       });
   });
                });
            </script>
        

    </div>
</div>
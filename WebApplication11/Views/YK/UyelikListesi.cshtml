@model System.Data.DataTable
@{
    ViewBag.Title = "Üyelik Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
 
<div class="content d-flex flex-column flex-column-fluid" id="kt_content">
    <!--begin::Post-->
    <div class="post d-flex flex-column-fluid" id="kt_post">
        <!--begin::Container-->
        <div id="kt_content_container" class="container-fluid">
            <!--begin::Card-->
            <div class="card border-0 shadow-none p-0">
                <!--begin::Card header-->
                <div class="card-header border-0 shadow-none p-0">
                    <!--begin::Card title-->
                    <div class="card-title">
                        <!--begin::Search-->
                        <form method="get" class="d-flex align-items-center position-relative my-1">
                            <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                                <span class="path1 text-gray-500"></span>
                                <span class="path2 text-gray-500"></span>
                            </i>
                            <input type="text" name="aranacakKelime" value="@ViewBag.AranacakKelime" data-kt-user-table-filter="search" class="form-control  w-250px py-1 ps-14" placeholder="Üyelik Ara" />
                        </form>
                        <!--end::Search-->
                    </div>
                    <!--begin::Card title-->
                    <!--begin::Card toolbar-->
                    <!--end::Search-->
                    <!--begin::Export buttons-->

                    <div class="card-toolbar flex-row-fluid justify-content-end gap-5 p-0">
                        <!--begin::Export dropdown-->
                        <button type="button" class="btn btn-light-primary btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                            <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                            Dışarı aktar
                        </button>
                        <!--begin::Menu-->
                        <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px py-4" data-kt-menu="true">
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="copy">
                                    Panoya Kopyala
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="excel">
                                    Excel olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="csv">
                                    CSV olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link px-2 py-0" data-kt-export="pdf">
                                    PDF olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                        </div>
                        <!--end::Menu-->
                        <!--end::Export dropdown-->
                        <!--begin::Hide default export buttons-->
                        <div id="kt_datatable_example_buttons" class="d-none"></div>
                        <!--end::Hide default export buttons-->

                    </div>
                    <!--end::Export buttons-->
                </div>

                <!--end::Card toolbar-->
            </div>
            <!--end::Card header-->
            <!--begin::Card body-->
            <div>
                <!--begin::Table-->
                <table class="table align-middle border rounded table-row-dashed fs-6" id="Uyelik-datatable">
                    <thead>
                        <tr class="text-start" style="font-size:15px;">

                            <th class="min-w-125px"><strong>İsim</strong></th>
                            <th class="min-w-125px"><strong>İletişim</strong></th>
                            <th class="min-w-125px"><strong>E-Mail</strong></th>
                            <th class="min-w-125px"><strong>Üyelik Tarihleri</strong></th>
                            <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 fw-semibold">
                        @for (var i = 0; i < Model.Rows.Count; i++)
                        {
                            string renk = "";
                            if (Convert.ToDateTime(Model.Rows[i]["UyelikBitisTarihi"]) <= DateTime.Today)
                            {
                                renk = "background-color:red;color:white;";
                            }
                            <tr style="@renk">

                                <td class="d-flex align-items-center">
                                    <!--begin:: Avatar -->
                                    <!--end::Avatar-->
                                    <!--begin::User details-->
                                    <div class="d-flex flex-column">
                                        @(Convert.ToString(Model.Rows[i]["Isim"]))
                                        <span>@(Convert.ToString(Model.Rows[i]["Unvan"]))</span>
                                    </div>
                                    <!--begin::User details-->
                                </td>
                                <td>
                                    @(Convert.ToString(Model.Rows[i]["Iletisim"]))
                                </td>
                                <td>@(Convert.ToString(Model.Rows[i]["EMail"]))</td>
                                <td>@(Convert.ToDateTime(Model.Rows[i]["UyelikBaslangicTarihi"]).ToString("dd-MM-yyyy")) - @(Convert.ToDateTime(Model.Rows[i]["UyelikBitisTarihi"]).ToString("dd-MM-yyyy")) </td>
                                <td class="text-end" style="padding-right:5px;">
                                    <a href="/YK/UyelikDuzenle/@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        Düzenle
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <!--end::Table-->
            </div>
            <!--end::Card body-->
        </div>
        <!--end::Card-->
    </div>
    <!--end::Container-->
</div>
<!--end::Post-->
@section Scripts {
    <script>
       

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    scrollX:true,
                    "info": false,
                    'order': [],
                    paging: false,
                    columnDefs: [

                    ]

                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Uyelik-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#Uyelik-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}
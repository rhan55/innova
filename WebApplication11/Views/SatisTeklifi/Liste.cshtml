@using YKPortal.Models.ComponentDto
@model YKPortal.Models.Dto.BelgeListeViewModel
@{
    ViewBag.Title = "Satış Teklifi Liste";
  
}

<!-- Componenti çağırın -->
@Html.Partial("~/Views/Shared/Components/_BelgeListeComponent.cshtml", new BelgeListeComponent
{

    Belgeler = Model.Belgeler,
    SilYetkisiVarMi = Model.Sil,
    DuzenleYetkisiVarMi = Model.Duzenle
})


@section Scripts {

    <script>
        const filtreleriTemizle = document.querySelector("#filtreleriTemizle");

        if (filtreleriTemizle) {
            filtreleriTemizle.addEventListener("click", function (e) {
                e.preventDefault();

                // Tüm inputları temizleyin
                document.querySelector("form#datatableFilters").querySelectorAll("input").forEach(input => {
                    input.value = "";
                });

                // Durumu selectbox'ını sıfırlayın
                const durumuSelect = document.querySelector("#Durumu");
                if (durumuSelect) {
                    durumuSelect.selectedIndex = 0;
                }

                // Formu gönderin
                document.querySelector("form#datatableFilters").submit();
            });
        }

    </script>
}




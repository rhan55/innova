@model System.Data.DataTable
@using YKPortal.Models.Dto
@{
    ViewBag.Title = "Duzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!--begin::Form-->
<div class="container">
    <form id="kt_modal_add_user_form" class="form" action="@Url.Action("Duzenle","Sube",null)" method="post" enctype="multipart/form-data">

        <!--begin::Scroll-->
        <div class="d-flex flex-column scroll-y container mt-10">
            <input type="hidden" name="ID" value="" />

            <!--begin::Row Input group-->
            <div class="row mb-12">
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Kod" class="fw-bold text-gray-800 fs-6 mb-2">Kod</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" id="Kod" name="Kod" class="form-control p-2" value="@(Convert.ToString(Model.Rows[0]["Kod"]))" required>
                    <!--end::Input-->
                </div>
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Isim" class="fw-bold text-gray-800 fs-6 mb-2">İsim</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" id="Isim" name="Isim" class="form-control p-2" value="@(Convert.ToString(Model.Rows[0]["Isim"]))" required>
                    <!--end::Input-->
                </div>

            </div>
            <!--end::Input group-->
            <!--begin::Row Input group-->
            <div class="row">
            <div class="row">
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Adres" class="fw-bold text-gray-800 fs-6 mb-2">Adres</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" id="Adres" name="Adres" class="form-control p-2" value="@(Convert.ToString(Model.Rows[0]["Adres"]))">
                    <!--end::Input-->
                </div>
                <!--begin::Input group-->
                <div class="col-lg-6">
                    <!--begin::Label-->
                    <label for="Telefon" class="fw-bold text-gray-800 fs-6 mb-2">Telefon</label>
                    <!--end::Label-->
                    <!--begin::Input-->
                    <input type="text" id="Telefon" name="Telefon" class="form-control p-2" value="@(Convert.ToString(Model.Rows[0]["Telefon"]))">
                    <!--end::Input-->
                </div>

            </div>
            <!--end::Input group-->
            <!--begin::Actions-->
            <div class="pt-10">
                <a onclick="history.back()" class="btn btn-light me-3" data-kt-users-modal-action="cancel">Geri</a>
                <button type="submit" class="btn btn-primary" data-kt-users-modal-action="Duzenle">
                    <span class="indicator-label">Kaydet</span>
                    <span class="indicator-progress">
                        Lütfen Bekleyin...
                        <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                </button>
            </div>
            <!--end::Actions-->
        </div>
    </form>
    <!--end::Form-->
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {

            Inputmask({
                "mask": "(999) 999-9999"
            }).mask("#Telefon");

        });

    </script>
}

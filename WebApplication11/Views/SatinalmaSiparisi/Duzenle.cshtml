        function Kaydet() {
            // Belge numarası kontrolü (SS tipi için zorunlu)
            if ($("#BelgeNo").val() == "" && Tip == "AS") {
                alert("Lütfen belge numarası yazınız.");
                return;
            }

            // Cari seçimi kontrolü (AF tipi için zorunlu)
            if (($("#CariID").val() == "" || $("#CariID").val() == null) && Tip == "AS") {
                alert("Lütfen cari seçiniz.");
                return;
            }

            // Kalemler verisinin toplanması
            var kalemler = [];
            $('#TabloKalemler tbody tr').each(function () {
                var $data = $(this).attr("data-ID2");
                var KalemID = $(this).attr("data-ID");
                if ($data != "" && $data != null) {
                    var StokID = $("#StokID_" + $data).val();
                    var Seri = $("#Seri_" + $data).val();
                    var Miktar = $("#Miktar_" + $data).val();
                    var Fiyat = $("#Fiyat_" + $data).val();
                    var KdvOrani = $('#KdvOrani_' + $data).val();
                    var IskontoOrani1 = $('#IskontoOrani1_' + $data).val();

                    // Kalem objesini oluştur ve kalemler dizisine ekle
                    var kalem = {
                        ID: KalemID,
                        StokID: StokID,
                        Seri: Seri,
                        Miktar: Miktar,
                        Fiyat: Fiyat,
                        KdvOrani: KdvOrani,
                        IskontoOrani1: IskontoOrani1
                    };
                    kalemler.push(kalem);
                }
            });

            // En az bir kalem girilmiş mi kontrolü
            if (kalemler.length === 0) {
                alert("Lütfen kalem giriniz.");
                return;
            }

            // AJAX isteği için veri hazırlığı
            var _data = {
                Tip: Tip,
                ID: $("#ID").val(),
                BelgeNo: $("#BelgeNo").val(),
                Tarih: $("#Tarih").val(),
                CariID: $("#CariID").val(),
                Durumu: $("#Durumu").val(),
                DepoCikisID: $("#DepoCikisID").val(),
                DepoGirisID: $("#DepoGirisID").val(),
                Aciklama: $("#Aciklama").val(),
                SatisPersonelID: $("#SatisPersonelID").val(),
                Kalemler: kalemler // Kalemler dizisi burada atanmıştır
            };

            console.log(_data);

            // AJAX isteği gönderimi
            $.ajax({
                url: '/SatinalmaSiparisi/Kaydet',
                data: JSON.stringify(_data), // Veriyi JSON formatına dönüştür
                contentType: "application/json",
                dataType: "json",
                type: "POST",
                success: function (data) {
                    alert("Belge Kaydedildi!");
                    // Detay sayfasını aç
                    window.open("/SatinalmaSiparisi/Detay/" + data.Data + "?Tip=@(Request.QueryString["Tip"])","_parent");
                },
                error: function (msg) {
                    console.log(msg);
                }
            });
        }





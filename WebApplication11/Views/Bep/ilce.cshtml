
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-lg-12">
            <div class="d-flex flex-column scroll-y px-5 px-lg-10  mt-10">
                <div class="row mb-7">
                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:50px;">il</label>
                        <select id="ddlil" style="width:300px;">
                            @foreach (var item in ViewBag.iller)
                            {
                                <option value="@item.ID">@item.IL</option>
                            }
                        </select>
                    </div>
                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:50px;">İlçe</label>
                        <input type="text" id="txtilce" value="" style="width:300px;" />
                    </div>

                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:50px;">Sıra</label>
                        <input type="text" id="txtSira" style="width:50px;text-align:right;" />
                    </div>

                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:50px;"></label>
                        <button type="submit" class="btn btn-primary btn-sm" id="btnkaydet">
                            <span class="indicator-label">Kaydet</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-flush mt-4 scroll-x">
        <table class="table align-middle table-row-dashed fs-6" id="tblliste" style="width:500px;">
            <thead>
                <tr class="text-start" style="font-size:15px;">
                    <th class="min-w-125px"><strong>Sıra</strong></th>
                    <th class="min-w-125px"><strong>İlçe</strong></th>
                    <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                </tr>
            </thead>
            <tbody class="text-gray-600 fw-semibold">
            </tbody>
        </table>
    </div>
</div>



@section Scripts {


    <script type="text/javascript">
        var id = "";
        //$(document).ready(function () {
        //    ilgetir();
        //});

        $("#ddlil").on("change", function () {
            ilgetir();
        });

        function ilgetir() {
            $('#tblliste > tbody > tr').remove();
            $.ajax({
                url: '/Bep/ilcegetir',
                type:"POST",
                data: JSON.stringify({ ilid: $("#ddlil").val() }),
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {

                        var options = '';
                        var butongroup = "";
                        butongroup += '<tr data-id="' + seri.ID + '" data-text="' + seri.ilce + '" data-sira="' + seri.Sira + '">';

                        butongroup += '<td class="align-items-center p-0">';
                        butongroup += '<a href="" class="text-gray-600 text-hover-primary">' + seri.Sira + '</a>';
                        butongroup += '</td>';

                        butongroup += '<td class="align-items-center p-0">';
                        butongroup += '<a href="" class="text-gray-600 text-hover-primary">' + seri.ilce + '</a>';
                        butongroup += '</td>';

                        butongroup += '<td class="text-end py-1">';
                        butongroup += '<div class="menu-item p-0" style="float: left;">';
                        butongroup += '<a href="javascript:void(0);" class="menu-link px-2 py-0 btnduzenle" >Düzenle</a>';
                        butongroup += '</div>';

                        butongroup += '<div class="menu-item p-0" style="float: left;">';
                        butongroup += '<a href="javascript:void(0);" class="menu-link px-2 py-0 btnsil">Sil</a>';
                        butongroup += '</div>';

                        butongroup += '</td>';
                        butongroup += '</tr>';

                        $("#tblliste tbody").append(butongroup);
                    });

                    $(".btnduzenle").on("click", function () {
                        id = $(this).closest("tr").attr("data-id");
                        $("#txtilce").val($(this).closest("tr").attr("data-text"));
                        $("#txtSira").val($(this).closest("tr").attr("data-sira"));
                    });

                    $(".btnsil").on("click", function () {
                        Swal.fire({
                            title: 'Silinsin mi?',
                            showDenyButton: true,
                            showCancelButton: false,
                            confirmButtonText: 'Evet',
                            denyButtonText: 'Hayır',
                            customClass: {
                                actions: 'my-actions',
                                cancelButton: 'order-1 right-gap',
                                confirmButton: 'order-2',
                                denyButton: 'order-3',
                            },
                        }).then((result) => {
                            if (result.isConfirmed) {
                                var secilisatir = $(this).closest("tr");
                                $.ajax({
                                    url: '/Bep/İlceSil',
                                    data: JSON.stringify({ id: secilisatir.attr("data-id") }),
                                    type: 'POST',
                                    contentType: 'application/json',
                                    success: function (data) {
                                        $(secilisatir).remove();
                                    },
                                });
                            }
                        })
                    });
                },
            });
        }

        $("#btnkaydet").on("click", function () {
            $.ajax({
                url: '/Bep/ilcekaydet',
                data: JSON.stringify({ ilid: $("#ddlil").val(), ilceid: id, ilce: $("#txtilce").val(), Sira: $("#txtSira").val() }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    id = "";
                    $("#txtilce").val("");
                    $("#txtSira").val("");
                    ilgetir();
                },
            });
        });


    </script>
}






@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <div class="row">
        <div class="col-lg-12">
            <!--begin::Form-->
            <!--begin::Scroll-->
            <div class="d-flex flex-column scroll-y px-5 px-lg-10  mt-10">
                <input type="hidden" name="ID" value="@ViewBag.ID" />

                <div class="row mb-7">

                    <div class="col-lg-8">

                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:40px;">İl &nbsp;&nbsp;&nbsp;&nbsp;</label>

                        <select id="ddlil" style="width:200px;">
                            @foreach (var item in ViewBag.iller)
                            {
                                <option value="@item.ID">@item.IL</option>
                            }
                        </select>
                    </div>

                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:40px;">İlçe</label>
                        <select id="ddlilce" style="width: 200px;">
                            <option>Seçiniz.</option>
                        </select>
                    </div>
                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:40px;">Okul</label>
                        <input type="text" id="txtokul" value="" style="width:400px;" />
                    </div>

                    <div class="col-lg-8">
                        <label for="Aciklama" class="fw-bold text-gray-600 fs-6 mb-2" style="width:40px;"></label>
                        <button type="submit" class="btn btn-primary btn-sm" id="btnkaydet">
                            <span class="indicator-label">Kaydet</span>
                            <span class="indicator-progress">
                                Lütfen Bekleyin...
                                <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                            </span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card card-flush mt-4 scroll-x">
        <table class="table align-middle table-row-dashed fs-6" id="tblliste" style="width:400px;">
            <thead>
                <tr class="text-start" style="font-size:15px;">
                    <th class="min-w-125px"><strong>Okul</strong></th>
                    <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                </tr>
            </thead>
            <tbody class="text-gray-600 fw-semibold">
            </tbody>
        </table>
    </div>
</div>



@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="~/Tema/plugins/custom/tinymce/tinymce.min.js"></script>
    <script>

        $(document).ready(function () {
            var AciklamaEditorOptions = {
                selector: "#Aciklama",
                height: 200,
                promotion: false
            };
            if (typeof KTThemeMode !== 'undefined') {
                if (KTThemeMode.getMode() === "dark") {
                    AciklamaEditorOptions["skin"] = "oxide-dark";
                    AciklamaEditorOptions["content_css"] = "dark";
                }
            }
            // tinyMCE init
            tinymce.init(AciklamaEditorOptions);

            ilcegetir();
        });

        var id = "";
        $("#ddlil").on("change", function () {
            ilcegetir();
        });

        $("#btnkaydet").on("click", function () {
            $.ajax({
                url: '/Bep/okulkaydet',
                data: JSON.stringify({ id: id, ilid: $("#ddlil").val(), ilceid: $("#ddlilce").val(), okul: $("#txtokul").val() }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    id = "";
                    $("#txtokul").val("");
                    Okulgetir($("#ddlil").val(), $("#ddlilce").val());
                },
            });
        });

        function ilcegetir() {
            $('#ddlilce').find("option").remove();
            $("#ddlilce").append('<option>Seçiniz.</option>');
            $.ajax({
                url: '/Bep/ilcegetir',
                data: JSON.stringify({ ilid: $("#ddlil").val() }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddlilce").append('<option value=' + seri.ID + '>' + seri.ILCE + '</option>');
                    });
                },
            });
        }

        $("#ddlilce").on("change", function () {
            Okulgetir($("#ddlil").val(),$(this).val());
        });

        function Okulgetir(ilid, ilceid) {
            $('#tblliste > tbody > tr').remove();
            $.ajax({
                url: '/Bep/okulgetir',
                data: JSON.stringify({ ilceid: ilceid, ilid: ilid }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {

                    data.forEach(function (seri) {
                        var options = '';
                        var butongroup = "";
                        butongroup += '<tr data-id=' + seri.ID + ' data-ilid=' + seri.ILID + ' data-ilceid=' + seri.ILCEID + ' data-text=' + seri.OKUL + '>';

                        butongroup += '<td class="align-items-center p-0">';
                        butongroup += '<a href="" class="text-gray-600 text-hover-primary">' + seri.OKUL + '</a>';
                        butongroup += '</td>';


                        butongroup += '<td class="text-end py-1">';
                        butongroup += '<div class="menu-item p-0" style="float: left;">';
                        butongroup += '<a href="javascript:void(0);" class="menu-link px-2 py-0 btnduzenle">Düzenle</a>';
                        butongroup += '</div>';

                        butongroup += '<div class="menu-item p-0" style="float: left;">';
                        butongroup += '<a href="javascript:void(0);" class="menu-link px-2 py-0 btnsil">Sil</a>';
                        butongroup += '</div>';

                        butongroup += '</td>';
                        butongroup += '</tr>';


                        $("#tblliste tbody").append(butongroup);
                    });

                    $(".btnduzenle").on("click", function () {
                        id = $(this).closest("tr").attr("data-id");
                        $("#txtokul").val($(this).closest("tr").attr("data-text"));
                        $("#ddlil").val($(this).closest("tr").attr("data-ilid"));
                        $("#ddlilce").val($(this).closest("tr").attr("data-ilceid"));
                    });

                    $(".btnsil").on("click", function () {
                        Swal.fire({
                            title: 'Silinsin mi?',
                            showDenyButton: true,
                            showCancelButton: false,
                            confirmButtonText: 'Evet',
                            denyButtonText: 'Hayır',
                            customClass: {
                                actions: 'my-actions',
                                cancelButton: 'order-1 right-gap',
                                confirmButton: 'order-2',
                                denyButton: 'order-3',
                            },
                        }).then((result) => {
                            if (result.isConfirmed) {
                                var secilisatir = $(this).closest("tr");
                                $.ajax({
                                    url: '/Bep/OkulSil',
                                    data: JSON.stringify({ id: secilisatir.attr("data-id") }),
                                    type: 'POST',
                                    contentType: 'application/json',
                                    success: function (data) {
                                        $(secilisatir).remove();
                                    },
                                });
                            }
                        })
                    });
                },
            });
        }
    </script>
}





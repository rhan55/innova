                                                <div class="form-group">
                                                    <label>İl</label>
                                                    <select class="form-control" id="ddlil" name="ddlil">
                                                        <option value="...">...</option>
                                                        @foreach (var item in ViewBag.iller)
                                                        {
                                                            <option value="@item.ID">@item.IL</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-sm-6">
                                                <div class="form-group">
                                                    <label>İlçe</label>
                                                    <select name="ddlilce" class="form-control" id="ddlilce">
                                                        <option value="">...</option>
                                                    </select>
                                                </div>
                                            </div>

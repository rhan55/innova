    </div>

    <script src="~/Content/assets/js/jquery-2.2.4.min.js" type="text/javascript"></script>
    <script src="~/Content/assets/js/bootstrap.min.js" type="text/javascript"></script>
    <script src="~/Content/assets/js/jquery.bootstrap.wizard.js" type="text/javascript"></script>
    <script src="~/Content/assets/js/demo.js" type="text/javascript"></script>
    <script src="~/Content/assets/js/paper-bootstrap-wizard.js" type="text/javascript" charset="utf-8"></script>
    <script src="~/Content/assets/js/jquery.validate.min.js" type="text/javascript"></script>
    <script src="~/Content/assets/js/modal.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.3/js/select2.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.3/css/select2.min.css" rel="stylesheet" />
    <script type="text/javascript">

        $(document).ready(function () {
            $("select").select2();
            DersleriListele();
        });

        $("#ddldersler").on("change", function () {
            SorulariGetir($(this).val());
            AracGerecGetir($(this).val());
            YontemGetir($(this).val());
        });

        $("#ddlil").on("change", function () {
            ilgetir();
            EgitimDuzeyiListele();
            SinifDuzeyiListele();
        });

        $("#ddlilce").on("change", function () {
            Okulgetir($("#ddlil").val(), $(this).val());
        });

        $("#ddlegitimduzeyi").on("change", function () {
            SinifListele();
        });

        $("#btnkaydet").on("click", function () {
            var data = {
                ilid: $("#ddlilid").val(),
                ilceid: $("#ddlilceid").val(),
                okulid: $("#ddlokul").val(),
                donem: $("#txtDonem").val(),
                adi: $("#txtadi").val(),
                soyadi: $("#txtsoyadi").val(),
                egitimduzeyi: $("#ddlegitimduzeyi").val(),
                sinif: $("#ddlsinif").val(),
                ogrencivelisi: $("#txtOgrenciVelisi").val(),
                sinifduzeyi: $("#ddlsinifduzeyi").val(),
                sinifrehberogretmeni: $("#txtSinifRehberOgretmeni").val(),
                bransogretmeni: $("#txtBransOgretmeni").val(),
                rehberogretmeni: $("#txtRehberOgretmeni").val(),
                uygulayici: $("#txtUygulayici").val(),
                mudur: $("#txtMudur").val(),
                dersler: $("#ddldersler").val(),
            }
            $.ajax({
                url: '/Bep/BepKaydet',
                data: data,
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    $("#txtSinif").val("");
                },
            });
        });

        function ilgetir() {
            $('#ddlilce').find("option").remove();
            $("#ddlilce").append('<option>...</option>');
            $.ajax({
                url: '/Bep/ilcegetir',
                data: JSON.stringify({ ilid: $("#ddlil").val() }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddlilce").append('<option value=' + seri.ID + '>' + seri.ilce + '</option>');
                    });
                },
            });
        }

        function Okulgetir(ilid, ilceid) {
            $('#ddlokul').find("option").remove();
            $("#ddlokul").append('<option>...</option>');
            $.ajax({
                url: '/Bep/okulgetir',
                data: JSON.stringify({ ilceid: ilceid, ilid: ilid }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddlokul").append('<option value=' + seri.ID + '>' + seri.OKUL + '</option>');
                    });
                },
            });
        }

        function EgitimDuzeyiListele() {
            $('#ddlegitimduzeyi').find("option").remove();
            $("#ddlegitimduzeyi").append('<option>...</option>');
            $.ajax({
                url: '/Bep/egitimduzeylerigetir',
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddlegitimduzeyi").append('<option value=' + seri.ID + '>' + seri.EgitimDuzeyi + '</option>');
                    });
                },
            });
        }

        function SinifListele() {
            $('#ddlsinif').find("option").remove();
            $("#ddlsinif").append('<option>...</option>');
            $.ajax({
                url: '/Bep/siniflarigetir',
                type: 'POST',
                data: JSON.stringify({ egitimduzeyid: $("#ddlegitimduzeyi").val() }),
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddlsinif").append('<option value=' + seri.ID + '>' + seri.Sinif + '</option>');
                    });

                },
            });
        }

        function SinifDuzeyiListele() {
            $('#ddlsinifduzeyi').find("option").remove();
            $("#ddlsinifduzeyi").append('<option>...</option>');
            $.ajax({
                url: '/Bep/SinifDuzeyiGetir',
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddlsinifduzeyi").append('<option value=' + seri.ID + '>' + seri.SinifDuzeyi + '</option>');
                    });
                },
            });
        }

        function DersleriListele() {
            $('#ddldersler').find("option").remove();
            $("#ddldersler").append('<option>...</option>');
            $.ajax({
                url: '/Bep/DersGetir',
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#ddldersler").append('<option value=' + seri.ID + '>' + seri.Ders + '</option>');
                    });
                },
            });
        }

        function YontemGetir(dersid) {
            $("#divyontemler").html("");
            var data = {
                dersid: dersid,
            }
            $.ajax({
                url: '/Bep/YontemTeknikGetir',
                data: JSON.stringify({ dersid: dersid }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#divyontemler").append("<div class='row checklist'><div class='checkbox col-xs-6 col-sm-4 col-md-3 col-lg-2''><label style='white-space: nowrap;'><input type='checkbox'>" + seri.YontemTeknik + "</label></div></div>");
                    });
                },
            });
        };

        function AracGerecGetir(dersid) {
            $("#divaracgerecler").html("");
            var data = {
                dersid: dersid,
            }
            $.ajax({
                url: '/Bep/AracGerecGetir',
                data: JSON.stringify({ dersid: dersid }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    data.forEach(function (seri) {
                        $("#divaracgerecler").append("<div class='row checklist'><div class='checkbox col-xs-6 col-sm-4 col-md-3 col-lg-2''><label style='white-space: nowrap;'><input type='checkbox'>" + seri.AracGerec + "</label></div></div>");
                    });
                },
            });
        };

        function SorulariGetir(dersid) {
            $("#tblhedefler > tbody > tr").remove();
            var data = {
                dersid: dersid,
            }
            $.ajax({
                url: '/Bep/SorulariGetir',
                data: JSON.stringify({ dersid: dersid }),
                type: 'POST',
                contentType: 'application/json',
                success: function (data) {
                    console.log(data);
                    data.forEach(function (seri) {
                        $("#tblhedefler > tbody").append("<tr><td>" + seri.Soru + "</td><td class='myCheckbox'><input type='checkbox' style='text-align:center' /></td><td class='myCheckbox'><input type='checkbox' style='text-align:center' /></td>");
                    });
                    $('#infoModal').modal('show');
                },
            });
        }

    </script>
</body>
</html>


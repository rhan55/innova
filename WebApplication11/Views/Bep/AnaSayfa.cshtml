                                <div class="tab-content">
                                    <div class="tab-pane" id="hedefler">
                                        <div class="row">
                                            <h5 class="info-text">Uzun Dönem ve Kısa Dönem Hedefler</h5>
                                        </div>
                                        <div class="row">
                                            <div class="col-8">
                                                <table class="table table-bordered" id="tblhedefler">
                                                    <thead>
                                                        <tr>
                                                            <th scope="col" class="col-10"></th>
                                                            <th scope="col" style="width: 10%;">Yapar</th>
                                                            <th scope="col" style="width: 10%;">Yapamaz</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    </tbody>
                                                </table>

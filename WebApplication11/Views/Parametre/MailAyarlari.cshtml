@using YKPortal.Models.Dto
@{
    ViewBag.Title = "Mail Ayarları";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container">
    <div class="row">
        <!--begin::Form-->
        <form id="kt_modal_add_user_form" class="form mt-10" action="@Url.Action("MailAyarlari","Parametre",null)" method="post" enctype="multipart/form-data">
            <!--begin::Scroll-->
            <div class="d-flex flex-column">

                <!--begin::Row Input group-->
                <div class="row mb-7">
                    @foreach (ParametreDto parametre in ViewBag.Parametreler)
                    {
                        if (parametre.Isim == "SSL")
                        {
                            <div class="col-lg-6 mt-4 d-flex align-items-center">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="true" name="@parametre.Isim" id="@parametre.Isim" @(parametre.Deger == "1" ? "checked" : "") />
                                    <label class="form-check-label" for="@parametre.Isim">
                                        @parametre.Isim
                                    </label>
                                </div>
                            </div>
                        }
                        else
                        {

                            <!--begin::Input group-->
                            <div class="col-lg-6 mt-4">
                                <!--begin::Label-->
                                <label class="fw-semibold fs-6 mb-2">@parametre.Isim</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="@(parametre.Isim == "Parola" ? "password" : "text")" name="@parametre.Isim" class="form-control p-2 mb-3 mb-lg-0" value="@parametre.Deger" />

                                <!--end::Input-->
                            </div>
                            <!--end::Input group-->
                        }

                    }



                </div>
                <!--begin::Row Input group-->
            </div>


            <div class="pt-4">
                <a onclick="history.back()" class="btn btn-light me-3 btn-sm" data-kt-users-modal-action="cancel">Geri</a>
                <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Kaydet">
                    <span class="indicator-label">Kaydet</span>
                    <span class="indicator-progress">
                        Lütfen Bekleyin...
                        <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                </button>
            </div>
        </form>
    </div>
    <!--end::Scroll-->
    <!--begin::Actions-->
    <!--end::Actions-->


</div>

<!--end::Form-->
@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
}

@using YKPortal.Models.Dto
@using System.Collections
@{
    ViewBag.Title = "Parametreler";
    Layout = "~/Views/Shared/_Layout.cshtml";

    List<ParametreDto> parametreler = ViewBag.Parametreler as List<ParametreDto>;
    ArrayList kategoriler = new ArrayList();
    foreach (ParametreDto item in parametreler)
    {
    if (!kategoriler.Contains(item.Kategori))
    {
    kategoriler.Add(item.Kategori);
    }
    }
    int sira = 0;
    int sira2 = 0;
    }
    <div class="container">
        <div class="row">

            <div class="card-body">
                <!--begin::Nav-->
                <ul class="nav nav-pills nav-pills-custom row position-relative mx-0 mb-9">

                    @foreach (string kategori in kategoriler)
                    {
                        sira++;
                        <!--begin::Item-->
                        <li class="nav-item col-4 mx-0 p-0">
                            <!--begin::Link-->
                            <a class="nav-link active d-flex justify-content-center w-100 border-0 h-100" data-bs-toggle="pill" href="#kt_list_widget_10_tab_@(sira)">
                                <!--begin::Subtitle-->
                                <span class="nav-text text-gray-800 fw-bold fs-6 mb-3">@kategori</span>
                                <!--end::Subtitle-->
                                <!--begin::Bullet-->
                                <span class="bullet-custom position-absolute z-index-2 bottom-0 w-100 h-4px bg-primary rounded"></span>
                                <!--end::Bullet-->
                            </a>
                            <!--end::Link-->
                        </li>
                        <!--end::Item-->
                    }

                    <!--begin::Bullet-->
                    <span class="position-absolute z-index-1 bottom-0 w-100 h-4px bg-light rounded"></span>
                    <!--end::Bullet-->
                </ul>
                <!--end::Nav-->
                <!--begin::Tab Content-->
                <div class="tab-content">
                    @foreach (string kategori in kategoriler)
                    {
                        sira2++;
                        <!--begin::Tap pane-->
                        <div class="tab-pane fade show active" id="kt_list_widget_10_tab_@(sira2)">


                        </div>
                        <!--end::Tap pane-->
                    }
                </div>
                <!--end::Tab Content-->
            </div>

        </div>
    </div>

    <!--end::Form-->
    @section Styles {

    }

    @section Scripts {

    }

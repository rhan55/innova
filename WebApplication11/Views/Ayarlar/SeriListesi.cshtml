@model List<YKPortal.Models.Dto.SeriDto>
@{
    ViewBag.Title = "Seri Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}




<div class="container-fluid  mt-4 mb-10 ">
    <div class="card card-flush">
        <form method="get" action="/Ayarlar/SeriListesi">
            <div class="px-6 py-6">
                <label for="seriTipiSelect" class="form-label fs-6 fw-bold text-gray-600 mb-4">Seri Tipini Seçin:</label>
                <select id="seriTipiSelect" class="form-select form-select-solid p-2 rounded-1 " name="Kod" onchange="this.form.submit()">
                    <option value="EFatura" @(ViewBag.Kod == "EFatura" ? "selected" : "")>EFatura</option>
                    <option value="EArsiv" @(ViewBag.Kod == "EArsiv" ? "selected" : "")>EArşiv</option>
                </select>
            </div>

        </form>
      
    </div>
    <div id="seriListesiContainer px-4">
        <!-- Seri listesi AJAX ile yüklenecek -->
        <div class="col-lg-12">
            <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid overflow-hidden" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container p-0" class="container-fluid p-0 m-0">
                        <div class="card card-flush mt-4">


                            <div class="card-body px-4 py-2 scroll-x">
                                <table class="table align-middle rounded-0 table-row-dashed  fs-6 g-5" id="Cari-Kisi-datatable">
                                    <thead>
                                        <!--begin::Table row-->
                                        <tr class="text-start">
                                            <th class="min-w-125px"><strong>Kod</strong></th>
                                            <th class="min-w-125px"><strong>Değer </strong></th>
                                            <th class="min-w-125px"><strong>Aktif</strong></th>

                                            <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>

                                        </tr>
                                        <!--end::Table row-->
                                    </thead>
                                    <tbody class="text-gray-600 fw-semibold">
                                        @foreach (var seri in Model)
                                        {
                                            <tr>
                                                <td>
                                                    @(seri.Kod)
                                                </td>
                                                <td>
                                                    @(seri.Deger)

                                                </td>

                                                <td>@(seri.Aktif ? "Evet" : "Hayır") </td>
                                                <td class="text-end">
                                                    <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm text-gray-700 fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                        İşlemler
                                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                                    </a>
                                                    <!--begin::Menu-->
                                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <a href="/Ayarlar/SeriDuzenle?ID=@(seri.ID)" class="menu-link rounded-0 px-2 py-2">Düzenle</a>
                                                        </div>
                                                        <!--end::Menu item-->
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <button type="button" data-id="@(seri.ID)" class="btn btn-sm w-100 menu-link rounded-0 px-2 text-gray-700 fw-bold py-2 btn-sil" data-bs-toggle="modal" data-bs-target="#seri-silme">
                                                                Sil
                                                            </button>

                                                        </div>
                                                        <!--end::Menu item-->
                                                    </div>
                                                    <!--end::Menu-->
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
                <!--end::Post-->
            </div>

        </div>
    </div>
</div>



<div class="modal fade" id="seri-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Seri Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Seriyi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("SeriSil","Ayarlar",null)">

                    <input type="hidden" name="ID" value="@ViewBag.ID" />
                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="ID"]').value = silButonu.dataset.id;
                });
            });

            $('#silme-formu').on('submit', function (event) {
                event.preventDefault();
                const form = $(this);
                var id = form.find('[name="ID"]').val();

                $.ajax({
                    url: '/Ayarlar/SeriSil',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ ID: id }), // JSON formatına uygun veri gönderimi
                    success: function (response) {
                        if (response.SonucKodu == "0") {
                            Swal.fire("Başarılı", response.Aciklama, "success").then(() => {
                                $('#seri-silme').modal('hide'); // Modalı kapat
                                tabloyuYenidenYukle(); // Tabloyu güncelle
                            });
                        } else {
                            Swal.fire("Hata", response.Aciklama, "error");
                        }
                        form.find('[name="ID"]').val("");
                    },
                    error: function () {
                        Swal.fire("Hata", "Kayıt sırasında bir hata oluştu.", "error");
                    }
                });
            });
            function tabloyuYenidenYukle() {
                setTimeout(function () {
                    window.location.reload();
                }, 1000);
            }


        });
    </script>
}

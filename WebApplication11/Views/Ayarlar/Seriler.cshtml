
@{
    ViewBag.Title = "Seriler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Seriler</h2>


<div class="container">


    <div class="row mt-10">
        <div class="card-body">
            <ul class="nav nav-pills nav-pills-custom row position-relative mx-0 mb-9 d-flex align-items-center justify-content-center">
                <li class="nav-item col-2 mx-0 p-0">
                    <!--begin::Link-->
                    <a class="nav-link d-flex justify-content-center w-100 border-0 h-100 active Tab-Class" data-bs-toggle="pill" href="#tab_EFaturaSerisi">
                        <!--begin::Subtitle-->
                        <span class="nav-text text-gray-800 fw-bold fs-6 mb-3">EFatura Serisi</span>
                        <!--end::Subtitle-->
                        <!--begin::Bullet-->
                        <span class="bullet-custom position-absolute z-index-2 bottom-0 w-100 h-4px bg-primary rounded"></span>
                        <!--end::Bullet-->
                    </a>
                    <!--end::Link-->
                </li>
                <li class="nav-item col-2 mx-0 p-0">
                    <!--begin::Link-->
                    <a class="nav-link d-flex justify-content-center w-100 border-0 h-100  Tab-Class" data-bs-toggle="pill" href="#tab_EArsivSerisi">
                        <!--begin::Subtitle-->
                        <span class="nav-text text-gray-800 fw-bold fs-6 mb-3">EArşiv Serisi</span>
                        <!--end::Subtitle-->
                        <!--begin::Bullet-->
                        <span class="bullet-custom position-absolute z-index-2 bottom-0 w-100 h-4px bg-primary rounded"></span>
                        <!--end::Bullet-->
                    </a>
                    <!--end::Link-->
                </li>

                <span class="position-absolute z-index-1 bottom-0 w-100 h-4px bg-light rounded"></span>
            </ul>


            <div class="tab-content">
                <div class="tab-pane fade  show active" id="tab_EFaturaSerisi" style="margin:10px;">
                    <div class="container mt-10">
                        <form id="EFaturaForm">

                            <div class="row mb-10">

                                EFATURA SERİSİ
                            </div>


                            <div class="pt-10">
                                <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                                <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Kaydet">
                                    <span class="indicator-label">Kaydet</span>

                                </button>
                            </div>


                        </form>
                    </div>
                </div>
                <div class="tab-pane fade" id="tab_EArsivSerisi">

                    <div class="container mt-14">
                        <form id="EArsivForm">


                            <div class="row">
                                EARSİVSERİSİ
                            </div>
                            <div class="pt-10">
                                <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                                <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Kaydet">
                                    <span class="indicator-label">Kaydet</span>

                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>



@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>

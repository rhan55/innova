@using YKPortal.Models.Dto
@{
    ViewBag.Title = "Entegrasyonlar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container mt-10">

    <div class="row  mt-lg-0">
        <div class="form-group">
            <label for="EFaturaEntagrator" class="fw-bold text-gray-700 fs-6 mb-2">EFatura Entagratör</label>
            <select class="form-control p-2 rounded-1" name="Il" data-control="select2" id="EFaturaEntagrator"
                    aria-label="Floating label select example">
                <option value="">Lütfen Seçim Yapınız</option>
                @foreach (GrupKoduDto EFaturaEntagrator in ViewBag.Entegratorler)
                {
                    <option value="@EFaturaEntagrator.ID">@EFaturaEntagrator.Deger</option>
                }
            </select>
        </div>
    </div>
    <div class="row mt-6">

        <div class="">
            <div class="" id="tab_EFatura" style="margin:10px;">
                <div class="container mt-10">
                    <form id="EFaturaForm">

                        <div class="row mb-10">


                            <div class="col-lg-6">
                                <!--begin::Label-->
                                <label for="EFaturaLogoPostBoxServiceUrl" class="fw-bold text-gray-700 fs-6 mb-2">EFatura Logo Post Box Service Url</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" id="EFaturaLogoPostBoxServiceUrl" name="EFaturaLogoPostBoxServiceUrl" class="form-control p-2" value="@ViewBag.Efatura.EFaturaLogoPostBoxServiceUrl">
                                <!--end::Input-->
                            </div>
                            <!--begin::Input group-->
                            <div class="col-lg-6">
                                <!--begin::Label-->
                                <label for="EFaturaLogoPostBoxServiceKullaniciAdi" class="fw-bold text-gray-700 fs-6 mb-2">EFatura Logo Post Box Service Kullanici Adi</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" id="EFaturaLogoPostBoxServiceKullaniciAdi" name="EFaturaLogoPostBoxServiceKullaniciAdi" class="form-control p-2" value="@ViewBag.Efatura.EFaturaLogoPostBoxServiceKullaniciAdi">
                                <!--end::Input-->
                            </div>
                            <!--begin::Input group-->



                        </div>
                        <div class="row mb-10">
                            <div class="col-lg-6">
                                <!--begin::Label-->
                                <label for="EFaturaLogoPostBoxServiceSifre" class="fw-bold text-gray-700 fs-6 mb-2">EFatura Logo Post Box Service Sifre</label>
                                <!--end::Label-->
                                <!--begin::Input-->
                                <input type="text" id="EFaturaLogoPostBoxServiceSifre" name="EFaturaLogoPostBoxServiceSifre" class="form-control p-2" value="@ViewBag.EFatura.EFaturaLogoPostBoxServiceSifre">
                                <!--end::Input-->
                            </div>

                        </div>
                        <div class="pt-10">
                            <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                            <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Kaydet">
                                <span class="indicator-label">Kaydet</span>

                            </button>
                        </div>


                    </form>
                </div>
            </div>
            <div class="tab-pane fade" id="tab_EArsiv">

                <div class="container mt-14">
                    <form id="EArsivForm">


                        <div class="row">
                            AAAAAAAAAAAAA
                        </div>
                        <div class="pt-10">
                            <a onclick="history.back()" class="btn btn-light btn-sm me-3" data-kt-users-modal-action="cancel">Geri</a>
                            <button type="submit" class="btn btn-primary btn-sm" data-kt-users-modal-action="Kaydet">
                                <span class="indicator-label">Kaydet</span>

                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>



@section Scripts {

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.min.js"></script>

    <script>

        $(document).ready(function () {



            // B2B formunu submit ettiğimizde
            $('#EFaturaForm').on('submit', function (e) {
                e.preventDefault(); // Formun normal submit olmasını engelle

                // Form verilerini topla
                var formData = {
                    EFaturaLogoPostBoxServiceUrl: $('#EFaturaLogoPostBoxServiceUrl').val(),
                    EFaturaLogoPostBoxServiceKullaniciAdi: $('#EFaturaLogoPostBoxServiceKullaniciAdi').val(),
                    EFaturaLogoPostBoxServiceSifre: $('#EFaturaLogoPostBoxServiceSifre').val(),

                };

                $.ajax({
                    url: '/Ayarlar/EFaturaAyarlari', // Metodun adresi
                    type: 'POST',
                    data: formData, // Gönderilecek veri
                    success: function (response) {
                        // Başarılı olduğunda yapılacaklar

                        sweetalert("EFatura Ayarları başarıyla kaydedildi.", "succsess")

                    },
                    error: function (xhr, status, error) {
                        // Hata durumunda yapılacaklar
                        sweetalert("Bir hata oluştu", "error")

                    }
                });
            });

        });

    </script>


}

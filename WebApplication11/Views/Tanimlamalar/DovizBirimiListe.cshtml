
@{
    ViewBag.Title = "DovizBirimiListe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content d-flex flex-column flex-column-fluid" id="kt_content">
    <!--begin::Post-->
    <div class="post d-flex flex-column-fluid" id="kt_post">
        <!--begin::Container-->
        <div id="kt_content_container" class="container-fluid">
            <div class="card shadow-none card-flush border-0">
                <div class="card-header align-items-center p-0 gap-2 gap-md-5">
                    <div class="card-title px-4">
                        <!--begin::Search-->
                        <div class="d-flex align-items-center position-relative my-1">
                            <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                                <span class="path1 text-gray-500"></span>
                                <span class="path2 text-gray-500"></span>
                            </i>
                            <input type="text" data-kt-filter="search" class="form-control  w-250px py-1 ps-14"/>
                        </div>
                        <!--end::Search-->
                    </div>
                    <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                        <!--begin::Export dropdown-->
                        <button type="button" class="btn btn-light-primary btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                            <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                            Dışarı aktar
                        </button>
                        <!--begin::Menu-->
                        <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px p-0" data-kt-menu="true">
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link py-0 px-2" data-kt-export="copy">
                                    Panoya Kopyala
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link py-0 px-2" data-kt-export="excel">
                                    Excel olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link py-0 px-2" data-kt-export="csv">
                                    CSV olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item p-0">
                                <a href="#" class="menu-link py-0 px-2" data-kt-export="pdf">
                                    PDF olarak dışarı aktar
                                </a>
                            </div>

                            <!--end::Menu item-->
                        </div>
                        <!--end::Menu-->
                        <div id="kt_datatable_example_buttons" class="d-none"></div>
                        <!--end::Export dropdown-->
                        <div class="me-6">
                            <a href="/Tanimlamalar/DovizBirimiEkle" class="btn btn-primary btn-sm">
                                <i class="ki-duotone ki-plus fs-2"></i>Yeni
                            </a>
                        </div>

                    </div>
                </div>
                <!--begin::Card body-->
                <!--end::Card body-->
            </div>
            <div class="my-4">
                <!--begin::Table-->
                <table class="table align-middle border rounded table-row-dashed fs-6 display nowrap w-100 p-4" id="DovizBirimi-datatable">
                    <thead>
                        <tr class="text-start" style="font-size:15px;">

                            <th class="min-w-125px"><strong>Kod</strong></th>
                            <th class="min-w-125px "><strong>İsim</strong></th>
                            <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-600 fw-semibold">
                        @for (var i = 0; i < Model.Rows.Count; i++)
                        {
                            <tr>

                                <td>
                                    <div href="" class="text-gray-600 text-hover-primary">@(Convert.ToString(Model.Rows[i]["Kod"]))</div>
                                </td>

                                <td>
                                    <div href="" class="text-gray-600 text-hover-primary ">@(Convert.ToString(Model.Rows[i]["Isim"]))</div>
                                </td>

                            
                                <td class="text-end py-2">
                                    <a href="#" class=" text-gray-700 fw-bold btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        İşlemler
                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                    </a>
                                    <!--begin::Menu-->
                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="/Tanimlamalar/DovizBirimiDuzenle/@(Convert.ToString(Model.Rows[0]["ID"]))" class="menu-link rounded-0 py-0 px-2">Düzenle</a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link rounded-0 py-0 px-2 btn-sil" data-bs-toggle="modal" data-bs-target="#DovizBirimi-silme">
                                                Sil
                                            </button>

                                        </div>
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <!--end::Table-->
            </div>
        </div>
        <!--end::Container-->
    </div>
    <!--end::Post-->
</div>

<div class="modal fade" id="DovizBirimi-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Döviz birimi Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Döviz birimini silmek istediğinize emin misiniz</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("DovizBirimiSil","Tanimlamalar",null)">
                    <input type="hidden" name="id" />
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    console.log(silButonu.dataset.id);
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                })
            });


        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    "info": false,

                    'order': [],
                    paging: false,
                });

                datatable.on('columns-reordered', function (e, settings, details) {
                    KTMenu.createInstances();
                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'DovizBirimi-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#DovizBirimi-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}


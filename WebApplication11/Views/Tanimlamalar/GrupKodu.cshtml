@model System.Data.DataTable
@{
    ViewBag.Title = "GroupKodu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!--begin::Container-->
<div id="kt_content_container" class="container-fluid mt-5">
    <div class="row">
        <div class="col-lg-10">
            <div class="card card-flush">
                <div class="card-header align-items-center py-5 px-8 gap-2 gap-md-5">
                    <div class="card-title">
                        <!--begin::Search-->
                        <div class="d-flex align-items-center position-relative my-1">
                            <i class="ki-duotone ki-magnifier fs-3 position-absolute m-4">
                                <span class="path1 text-gray-500"></span>
                                <span class="path2 text-gray-500"></span>
                            </i>
                            <input type="text" data-kt-filter="search" class="form-control  w-250px ps-14" placeholder="Kullanıcı Ara" />
                        </div>
                        <!--end::Search-->
                    </div>
                    <div class="card-toolbar flex-row-fluid justify-content-end gap-5">
                        <!--begin::Export dropdown-->
                        <button type="button" class="btn btn-light-primary btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                            <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                            Dışarı aktar
                        </button>
                        <!--begin::Menu-->
                        <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px py-4" data-kt-menu="true">
                            <!--begin::Menu item-->
                            <div class="menu-item px-3">
                                <a href="#" class="menu-link px-3" data-kt-export="copy">
                                    Panoya Kopyala
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item px-3">
                                <a href="#" class="menu-link px-3" data-kt-export="excel">
                                    Excel olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item px-3">
                                <a href="#" class="menu-link px-3" data-kt-export="csv">
                                    CSV olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                            <!--begin::Menu item-->
                            <div class="menu-item px-3">
                                <a href="#" class="menu-link px-3" data-kt-export="pdf">
                                    PDF olarak dışarı aktar
                                </a>
                            </div>
                            <!--end::Menu item-->
                        </div>
                        <!--end::Menu-->
                        <!--end::Export dropdown-->
                        <!--begin::Hide default export buttons-->
                        <div id="kt_datatable_example_buttons" class="d-none"></div>
                        <!--end::Hide default export buttons-->
                        <a href="/Tanimlamalar/Ekle?grupKodu=@Request.QueryString["grupKodu"]" class="btn btn-primary btn-sm fw-bold">
                            <i class="ki-duotone ki-plus fs-2"></i>Yeni
                        </a>
                    </div>
                </div>
                <!--begin::Card body-->
                <div class="card-body py-4 p-8">
                    <!--begin::Table-->
                    <table class="table align-middle table-row-dashed fs-6 gy-5" id="grup-kodu-datatable">
                        <thead>
                            <tr class="text-start" style="font-size:15px;">

                                <th class="min-w-125px"><strong>Değer</strong></th>

                                <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                            </tr>
                        </thead>
                        <tbody class="text-gray-600 fw-semibold">
                            @for (var i = 0; i < Model.Rows.Count; i++)
                            {
                                <tr>

                                    <td class="d-flex align-items-center">

                                        <!--end::Avatar-->
                                        <!--begin::User details-->
                                        <div href="" class="text-gray-800 text-hover-primary mb-1">@(Convert.ToString(Model.Rows[i]["Deger"]))</div>

                                        <!--begin::User details-->
                                    </td>
                                    <td class="text-end">
                                        <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                            İşlemler
                                            <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                        </a>
                                        <!--begin::Menu-->
                                        <div class="menu menu-sub menu-sub-dropdown menu-column menu-rounded menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-2" data-kt-menu="true">
                                            <!--begin::Menu item-->
                                            <div class="menu-item">
                                                <a href="/Tanimlamalar/Duzenle/?grupKodu=@Request.QueryString["grupKodu"]&id=@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link p-0">Düzenle</a>
                                            </div>
                                            <!--end::Menu item-->
                                            <!--begin::Menu item-->
                                            <div class="menu-item">
                                                <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" data-grupKodu="@(Convert.ToString(Model.Rows[i]["Kod"]))" class="btn btn-sm w-100 menu-link p-0 btn-sil" data-bs-toggle="modal" data-bs-target="#grup-kodu-silme">
                                                    Sil
                                                </button>

                                            </div>
                                            <!--end::Menu item-->
                                        </div>
                                        <!--end::Menu-->
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <!--end::Table-->
                </div>
                <!--end::Card body-->
            </div>
        </div>
    </div>
</div>
<!--end::Container-->

<div class="modal fade" id="grup-kodu-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Grup Kod Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Grup Kod değerini silmek istediğinize emin misiniz</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("Sil","Tanimlamalar",null)">
                    <input type="hidden" name="id" value="" />
                    <input type="hidden" name="grupKodu" value="" />
                    <button type="submit" class="btn btn-danger">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                    document.querySelector('form#silme-formu input[name="grupKodu"]').value = silButonu.dataset.grupkodu;
                })
            })
        });

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;

            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    scrollX:true,
                    "info": false,
                    'order': [],
                    paging: false,
                    columnDefs: [

                    ]

                });
            }

            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Grup-Kodu-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            var handleSearchDatatable = () => {
                const filterSearch = document.querySelector('[data-kt-filter="search"]');
                filterSearch.addEventListener('keyup', function (e) {
                    datatable.search(e.target.value).draw();
                });
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#grup-kodu-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();
                    handleSearchDatatable();
                }
            };
        }();

        // On document ready
        KTUtil.onDOMContentLoaded(function () {
            KTDatatablesExample.init();
        });
    </script>
}

        <script type="text/javascript">
        @if (Model != null )
        {
            foreach (System.Data.DataRow item in Model.Rows)
            {
                @Html.Raw(@"var sig_" + item["ID"] + " = $('#sig_" + item["ID"] + "').signature();")
                @Html.Raw("function FormGonder"+item["ID"]+ "() { ")
                @Html.Raw("$(\"#Imza_" + item["ID"] + "\").val(sig_"+item["ID"]+ ".signature('toJSON')); ")

                if (Convert.ToInt32(item["TipID"]) == 1)
                {
                    @Html.Raw("if ($(\"#Sikayet_" + item["ID"] + "\").val() == \"\") { alert('Lütfen şikayet yazınız.');  } ")
                    @Html.Raw("else if ($(\"#Aciklama_" + item["ID"] + "\").val() == \"\") { alert('Lütfen açıklama yazınız.');  } ")
                    @Html.Raw("else if ($(\"#YetkiliIsim_" + item["ID"] + "\").val() == \"\") { alert('Lütfen yetkili yazınız.');  } ")

                    @Html.Raw("else if ($(\"#Cevap1_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap2_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap3_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap4_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap5_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap6_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap7_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                    @Html.Raw("else if ($(\"#Cevap8_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")

                }
                else if (Convert.ToInt32(item["TipID"]) == 2)
                {
                    @Html.Raw("if ($(\"#SeriNo_" + item["ID"] + "\").val() == \"\") { alert('Lütfen seri seçimi yapınız.');  } ")
                    @Html.Raw("else if ($(\"#Aciklama_" + item["ID"] + "\").val() == \"\") { alert('Lütfen açıklama yazınız.');  } ")
                    @Html.Raw("else if ($(\"#YetkiliIsim_" + item["ID"] + "\").val() == \"\") { alert('Lütfen yetkili yazınız.');  } ")

                    @Html.Raw("else if ($(\"#Cevap1_" + item["ID"] + "\")[0].files.length == 0) { alert('Lütfen resim seçiniz.');  } ")
                }

                @Html.Raw("else { ")
                @Html.Raw("document.getElementById(\"id_" + item["ID"] + "\").setAttribute(\"name\", \"id\"); ")

@model System.Data.DataTable
@using System.Data.SqlClient
@using System.Data
@using YKWebPortal.Controllers
@{
    ViewBag.Title = "Bakım Listesi";
    int sira = 0;
}

@if (true)
{
    <section class="card">
        <!-- Preview -->
        <div style="text-align:center;">
            <strong>
                Bekleyen Ziyaretler
                <br /><span style="color:blue;">Bekleyen : @(Model.Select(" Tip <> 'Gecikme' ").Count())</span>
                |<spanl style="color:red;">Geçikmiş : @(Model.Select(" Tip = 'Gecikme' ").Count())</spanl>
                <br /> <span style="color:black;">Seçilen Tarih : @Convert.ToDateTime(ViewBag.Tarih).ToString("dd-MM-yyyy")</span>
            </strong>

            <form action="@Url.Content("~/YKMakine/BakimListem/?")" method="get">
                <label><a class="btn btn-danger" style="padding-left:15px;padding-right:15px;color:white;" href="@Url.Content("~/YKMakine/BakimListem/?Tarih="+Convert.ToDateTime(ViewBag.Tarih).AddDays(-1).ToString("yyyy-MM-dd"))">Önceki Gün</a></label>
                <label><a class="btn btn-success" style="padding-left:15px;padding-right:15px;color:white;" href="@Url.Content("~/YKMakine/BakimListem/?Tarih="+DateTime.Today.ToString("yyyy-MM-dd"))">Bugün</a></label>

                <label><a class="btn btn-info" style="padding-left: 15px; padding-right: 15px; color: white;" href="@Url.Content("~/YKMakine/BakimListem/?Tarih="+Convert.ToDateTime(ViewBag.Tarih).AddDays(1).ToString("yyyy-MM-dd"))">Sonraki Gün</a></label>
            </form>
            <form action="@Url.Content("~/YKMakine/BakimListem/?")" method="get">
                <input type="text" name="Barkod" id="Barkod" value="@ViewBag.Barkod" placeholder="aranacak kelime" style="text-align:center;" />
                <input type="button" value="Barkod Oku" onclick="BarkodOku();" />
                <input type="submit" value="Ara" id="Ara" name="Ara" />





                <p id="code"></p>
                <script src="/exif.min.js"></script>
                <script src="/BarcodeScanner.min.js"></script>
                <script src="/app.js"></script>
                <script type="module" src="/index.ts"></script>
                <script>
                    function BarkodOku() {
                        var resultElement = document.getElementById('code');
                        setupLiveReader(resultElement);
                    }

                </script>

            </form>
        </div>

        <table class="table table-striped table-advance table-hover">
            <thead>
                <tr>
                    <td>Sıra</td>
                    <td>Müşteri</td>
                    <td>İşlem</td>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    foreach (System.Data.DataRow item in Model.Rows)
                    {
                        sira++;
                        <tr style="font-size:10px;">
                            <td>@(sira).</td>
                            <td>
                                <strong>Müşteri: </strong>@item["CariAdi"]<br />
                                <strong>Adres: </strong>@item["Adres"]<br />
                                <strong>Telefon: </strong>@item["Telefon"]<br />
                                <strong>Seri: </strong>@item["SeriNo"]<br />
                                @if (Convert.ToInt32(item["TipID"]) == 2)
                                {
                                    <span style="color:red;"><strong>Şikayet: </strong>@item["Sikayet"]</span>
                                }
                            </td>
                            <td>
                                @if (Convert.ToString(item["Tip"]) == "Gecikme")
                                {
                                    <a href="#" style="@(Convert.ToString(item["Tip"]) == "Gecikme" ? "background-color:red;color:white;" : "")">

                                        <a href="@Url.Action("BakimYap","YKMakine",new { id = item["ID"] })" class="btn btn-sm" style="color:white;font-size:10px;background-color:red;color:white;">
                                            Bakım Tamamla<br /><span style="font-size:6px;"><strong>@Convert.ToDateTime(item["Tarih"]).ToString("dd-MM-yyyy")</strong></span>
                                        </a>
                                    </a>
                                }
                                else if (Convert.ToString(item["Durum"]) == "Bakım Yapıldı" && Convert.ToInt32(item["TipID"]) == 1)
                                {
                                    <a href="@Url.Action("BakimYap","YKMakine",new { id = item["ID"] })">
                                        <span style="color:green;">BAKIM YAPILDI<br />DETAYA GİT</span>
                                    </a>
                                }
                                else if (Convert.ToString(item["Durum"]) == "Bakım Yapıldı" && Convert.ToInt32(item["TipID"]) == 2)
                                {
                                    <a href="@Url.Action("BakimYap","YKMakine",new { id = item["ID"] })">
                                        <span style="color:green;">ARIZA YAPILDI<br />DETAYA GİT</span>
                                    </a>
                                }
                                else if (Convert.ToInt32(item["TipID"]) == 1)
                                {
                                    <a href="#">
                                        <a href="@Url.Action("BakimYap","YKMakine",new { id = item["ID"] })" class="btn btn-sm" style="color:white;font-size:10px;background-color:blue;color:white;">
                                            Bakım Tamamla<br /><span style="font-size:6px;"><strong>@Convert.ToDateTime(item["Tarih"]).ToString("dd-MM-yyyy")</strong></span>
                                        </a>
                                    </a>

                                }
                                else if (Convert.ToInt32(item["TipID"]) == 2)
                                {
                                    <a href="#">
                                        <a href="@Url.Action("BakimYap","YKMakine",new { id = item["ID"] })" class="btn btn-sm" style="color:white;font-size:10px;background-color:orange;color:white;">
                                            Arıza Tamamla<br /><span style="font-size:6px;"><strong>@Convert.ToDateTime(item["Tarih"]).ToString("dd-MM-yyyy")</strong></span>
                                        </a>
                                    </a>
                                }

                                @if (Convert.ToInt32(item["TipID"]) == 1)
                                {

                                    <div aria-hidden="true" aria-labelledby="myModalLabel" role="dialog" tabindex="-1" id="myModal_id_@item["ID"]" class="modal fade">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Bakımı Tamamla</h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <form role="form" name="Form_@item["ID"]" id="Form_@item["ID"]" action="@Url.Action("BakimKapat", "YKMakine", null)" method="post" enctype="multipart/form-data">
                                                        <input type="hidden" name="id_@(item["ID"])" id="id_@(item["ID"])" value="@(item["ID"])" />
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">İşlem Tipleri <strong>( Şu anki durum: @item["Tip"] )</strong></label>
                                                            <select class="form-control" name="Durum_@(item["ID"])" id="Durum_@(item["ID"])" required>
                                                                @foreach (System.Data.DataRow item2 in ((System.Data.DataTable)ViewBag.IslemTipleri).Rows)
                                                                {
                                                                    <option value="@item2["Kod"]" @(Convert.ToString(item2["Kod"]) == "Bakım Yapıldı" ? "selected" : "")>@item2["Kod"]</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div><input type="hidden" name="SeriNo_@(item["ID"])" id="SeriNo_@(item["ID"])" value="" /></div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">LDU Kontrol (Manuel Otomatik Kurtarma)</label>
                                                            <input type="file" id="Cevap1_@(item["ID"])" name="Cevap1_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Motor Mekan ve Regulatör</label>
                                                            <input type="file" id="Cevap2_@(item["ID"])" name="Cevap2_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Kat Kapıları</label>
                                                            <input type="file" id="Cevap3_@(item["ID"])" name="Cevap3_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Karşı Ağırlık</label>
                                                            <input type="file" id="Cevap4_@(item["ID"])" name="Cevap4_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Kuyu Dibi (Regülatör ve Tamponlar</label>
                                                            <input type="file" id="Cevap5_@(item["ID"])" name="Cevap5_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Kabin Altı (Paraşüt ve Makaralar)</label>
                                                            <input type="file" id="Cevap6_@(item["ID"])" name="Cevap6_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Katları Donaşıp Seviye ve Buton Kontrolü</label>
                                                            <input type="file" id="Cevap7_@(item["ID"])" name="Cevap7_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">LDU (Bakım Defteri, Kuyu Işığı)</label>
                                                            <input type="file" id="Cevap8_@(item["ID"])" name="Cevap8_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>

                                                        <hr />
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">Şikayet</label>
                                                            <textarea rows="5" class="form-control" id="Sikayet_@(item["ID"])" name="Sikayet_@(item["ID"])"></textarea>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">Yapılan İşlem</label>
                                                            <textarea rows="5" class="form-control" id="Aciklama_@(item["ID"])" name="Aciklama_@(item["ID"])"></textarea>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">Yetkili İsim</label>
                                                            <textarea rows="1" class="form-control" id="YetkiliIsim_@(item["ID"])" name="YetkiliIsim_@(item["ID"])"></textarea>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">İmza</label><br />
                                                            <div id="sig_@item["ID"]" name="sig_@item["ID"]"></div>
                                                        </div>
                                                        <input type="hidden" name="Imza_@item["ID"]" id="Imza_@item["ID"]" value="" />
                                                        <hr />
                                                        <button type="button" class="btn btn-danger" onclick="FormGonder@(item["ID"])();">Kaydet</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else if (Convert.ToInt32(item["TipID"]) == 2)
                                {
                                    SqlCommand cmd = new SqlCommand();
                                    cmd.CommandText = "select * from w_CariStokListesi Where SaticiKodu = @CariKodu";
                                    cmd.CommandType = System.Data.CommandType.Text;
                                    cmd.Parameters.AddWithValue("@CariKodu", item["CariKodu"]);

                                    DataTable dtAsansorler = (DataTable)YKWebPortal.Models.ID.Sorgula(cmd, YKWebPortal.Models.SorgulaTuru.Tablo, "");

                                    <div aria-hidden="true" aria-labelledby="myModalLabel" role="dialog" tabindex="-1" id="myModal_id_@item["ID"]" class="modal fade">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Arıza Tamamla</h5>
                                                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                                        <span aria-hidden="true">&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <form role="form" name="Form_@item["ID"]" id="Form_@item["ID"]" action="@Url.Action("BakimKapat", "YKMakine", null)" method="post" enctype="multipart/form-data">
                                                        <input type="hidden" name="id_@(item["ID"])" id="id_@(item["ID"])" value="@(item["ID"])" />
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">İşlem Tipleri <strong>( Şu anki durum: @item["Tip"] )</strong></label>
                                                            <select class="form-control" name="Durum_@(item["ID"])" id="Durum_@(item["ID"])" required>
                                                                @foreach (System.Data.DataRow item2 in ((System.Data.DataTable)ViewBag.IslemTipleri).Rows)
                                                                {
                                                                    <option value="@item2["Kod"]" @(Convert.ToString(item2["Kod"]) == "Bakım Yapıldı" ? "selected" : "")>@item2["Kod"]</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Seri No</label>
                                                            <select class="form-control" name="SeriNo_@(item["ID"])" id="SeriNo_@(item["ID"])" required>
                                                                <option value=""></option>
                                                                @foreach (System.Data.DataRow item2 in dtAsansorler.Rows)
                                                                {
                                                                    <option value="@item2["StokKodu"]">@item2["StokKodu"] - @item2["StokAdi"]</option>
                                                                }
                                                            </select>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputFile">Arıza Resmi</label>
                                                            <input type="file" id="Cevap1_@(item["ID"])" name="Cevap1_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">Motor Mekan ve Regulatör</label>
                                                            <input type="file" id="Cevap2_@(item["ID"])" name="Cevap2_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">Kat Kapıları</label>
                                                            <input type="file" id="Cevap3_@(item["ID"])" name="Cevap3_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">Karşı Ağırlık</label>
                                                            <input type="file" id="Cevap4_@(item["ID"])" name="Cevap4_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">Kuyu Dibi (Regülatör ve Tamponlar</label>
                                                            <input type="file" id="Cevap5_@(item["ID"])" name="Cevap5_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">Kabin Altı (Paraşüt ve Makaralar)</label>
                                                            <input type="file" id="Cevap6_@(item["ID"])" name="Cevap6_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">Katları Donaşıp Seviye ve Buton Kontrolü</label>
                                                            <input type="file" id="Cevap7_@(item["ID"])" name="Cevap7_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputFile">LDU (Bakım Defteri, Kuyu Işığı)</label>
                                                            <input type="file" id="Cevap8_@(item["ID"])" name="Cevap8_@(item["ID"])" accept="image/*" Capture="">
                                                        </div>

                                                        <hr />
                                                        <div class="form-group" style="display:none;">
                                                            <label for="exampleInputPassword1">Şikayet</label>
                                                            <textarea rows="5" class="form-control" id="Sikayet_@(item["ID"])" name="Sikayet_@(item["ID"])"></textarea>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">Yapılan İşlem</label>
                                                            <textarea rows="5" class="form-control" id="Aciklama_@(item["ID"])" name="Aciklama_@(item["ID"])"></textarea>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">Yetkili İsim</label>
                                                            <textarea rows="1" class="form-control" id="YetkiliIsim_@(item["ID"])" name="YetkiliIsim_@(item["ID"])"></textarea>
                                                        </div>
                                                        <div class="form-group">
                                                            <label for="exampleInputPassword1">İmza</label><br />
                                                            <div id="sig_@item["ID"]" name="sig_@item["ID"]"></div>
                                                        </div>
                                                        <input type="hidden" name="Imza_@item["ID"]" id="Imza_@item["ID"]" value="" />
                                                        <hr />
                                                        <button type="button" class="btn btn-danger" onclick="FormGonder@(item["ID"])();">Kaydet</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </td>
                        </tr>

                    }
                }
            </tbody>
        </table>

    </section>






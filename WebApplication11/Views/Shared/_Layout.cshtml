                                <span class="text-muted fw-semibold me-1">2014 - @(DateTime.Today.Year)&copy;</span>
                                <a href="https://ykyazilim.com.tr" target="_blank" class="text-gray-800 text-hover-primary">@System.Configuration.ConfigurationManager.AppSettings["FirmaAdi"]</a>

    <!--begin::Javascript-->
    <script>var hostUrl = "~/Tema/";</script>
    <!--begin::Global Javascript Bundle(mandatory for all pages)-->
    <script src="~/Tema/plugins/global/plugins.bundle.js"></script>
    <script src="~/Tema/plugins/custom/datatables/datatables.min.js"></script>
    <script src="~/Tema/js/scripts.bundle.js"></script>
    <script src="~/Tema/plugins/custom/fullcalendar/fullcalendar.bundle.js"></script>
    <script src="~/Tema/plugins/custom/vis-timeline/vis-timeline.bundle.js"></script>
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/SignalR/Hubs"></script>
    <!--end::Global Javascript Bundle-->
    <!--begin::Vendors Javascript(used for this page only)-->
    <script src="~/Tema/plugins/custom/fullcalendar/fullcalendar.bundle.js"></script>

    <!--end::Vendors Javascript-->
    <!--begin::Custom Javascript(used for this page only)-->
    <script src="~/Tema/js/widgets.bundle.js"></script>
    <script src="~/Tema/js/custom/widgets.js"></script>
    <script src="~/Tema/js/custom/apps/chat/chat.js"></script>
    <script src="~/Tema/js/custom/utilities/modals/upgrade-plan.js"></script>
    <script src="~/Tema/js/custom/utilities/modals/create-app.js"></script>
    <script src="~/Tema/js/custom/utilities/modals/new-target.js"></script>
    <script src="~/Tema/js/custom/utilities/modals/users-search.js"></script>
    <script>

     function loader() {
         var toggle = () => {
             document.querySelector('.custom-page-loader').classList.toggle('hidden');
         }

         var hide = () => {
             document.querySelector('.custom-page-loader').classList.add('hidden');
         }

         var show = () => {
             document.querySelector('.custom-page-loader').classList.remove('hidden');
         }

         return {
             toggle, hide, show
         }
     }

     const anaSayfaBilgileri = {
         Cari: 0,
         Stok: 0,
         Belge: 0,
         YeniOkunmamisMesaj: 0
     }

     function AnaSayfaBilgileriGetir() {
         $.ajax({
             url: "/YK/AnaSayfaBilgileriGetir",
             method: 'POST',
             data: JSON.stringify({}),
             success: (response) => {
                 if (response.Data) {
                     anaSayfaBilgileri.Belge = response.Data.Belge;
                     anaSayfaBilgileri.Cari = response.Data.Cari;
                     anaSayfaBilgileri.Stok = response.Data.Stok;
                     anaSayfaBilgileri.YeniOkunmamisMesaj = response.Data.YeniOkunmamisMesaj;
                     YeniOkunmamisMesajEkle();
                 }
             },
             error: (err) => {
                 console.log(err)
             }
         })
     }

     function YeniOkunmamisMesajEkle(ekle = null) {
         if (ekle == null) {
             if (anaSayfaBilgileri.YeniOkunmamisMesaj > 0) {
                 $('[data-id="YeniOkunmamisMesaj"]').html(anaSayfaBilgileri.YeniOkunmamisMesaj);
                 $('[data-id="YeniOkunmamisMesaj"]').removeClass('hidden');
             } else {
                 $('[data-id="YeniOkunmamisMesaj"]').addClass('hidden');
             }
         } else if (ekle === "") {
             var suAnkiMesajSayisi = Number($('[data-id="YeniOkunmamisMesaj"]').html());

             $('[data-id="YeniOkunmamisMesaj"]').html(suAnkiMesajSayisi + 1);
             $('[data-id="YeniOkunmamisMesaj"]').removeClass('hidden');
         }

     }

     function bildirimHubBaglantisi() {
         var bildirimHub = $.connection.bildirimHub;

         bildirimHub.client.receiveNotification = function (bosIcerik) {

             YeniOkunmamisMesajEkle("");
         };

         $.connection.hub.start({ transport: ['webSockets', 'longPolling'], connectionTimeout: 20000 }).done(function () {
             console.log('Connected to SignalR hub');
         }).fail(function (error) {
             console.log('Could not connect: ' + error);
         })
     }

     $(document).ready(function () {


         loader().hide();

         let menuIdListesi = [];

         const loadingEl = document.createElement("div");
         document.body.prepend(loadingEl);
         loadingEl.classList.add("page-loader");
         loadingEl.classList.add("flex-column");
         loadingEl.innerHTML = `
                   <span class="spinner-border text-primary" role="status"></span>
                   <span class="text-muted fs-6 fw-semibold mt-5">Loading...</span>
               `;

         // Show page loading
         KTApp.showPageLoading();

         // Hide after 3 seconds
         setTimeout(function () {
             KTApp.hidePageLoading();
             loadingEl.remove();
         }, 0);


         const navigations = [

              @foreach (YetkilerDto yetki in yetkiler)
              {
                  if (yetki.UstID == "")
                  {
                      @Html.Raw("{")
                      @Html.Raw("   title: '"+yetki.Menu+"',")
                      @Html.Raw("   icon: '"+yetki.icon+"',")
                      @Html.Raw("   isOpen: false,")
                      @Html.Raw("   items: [")



                      foreach (YetkilerDto altyetki in yetkiler)
                      {
                          if (altyetki.UstID == yetki.MenuID)
                          {
                              if (altyetki.url.Trim().Length > 0)
                              {
                                    @Html.Raw("    {");
                                       @Html.Raw("    title: '"+ altyetki.Menu+"',");
                                       @Html.Raw("       url: '"+ Url.Content(altyetki.url)+"'");
                                       @Html.Raw("   },");

                              }
                              else
                              {
                                    @Html.Raw("    {");
                                   @Html.Raw("       title: '"+altyetki.Menu+"',");
                                   @Html.Raw("      isMenu: true,");
                                   @Html.Raw("      icon: '"+altyetki.icon+"',");
                                   @Html.Raw("      items: [");


                                    foreach (YetkilerDto alt2yetki in yetkiler)
                                    {
                                        if (alt2yetki.UstID == altyetki.MenuID)
                                        {

                                              @Html.Raw("    {");
                                              @Html.Raw("    title: '"+alt2yetki.Menu+"',");
                                              @Html.Raw("       url: '"+Url.Content(alt2yetki.url)+"'");
                                              @Html.Raw("   },");


                                        }
                                    }

                                   @Html.Raw("      ]");
                                   @Html.Raw("  },");
                              }

                                  }
                              }

                      @Html.Raw("   ]")
                      @Html.Raw(" },")
                          }
                      }




         ];

                      const navigationContainer = document.querySelector("#navigation");

                      const searchInNavigation = document.querySelector("#searchInNavigation");

                      let navigationData = buildNavigation(navigations);

                      navigationContainer.innerHTML = navigationData.join("")

         function createLink(item) {

                          return `
                                                            <div class="menu-item">
                                                                <a class="menu-link hover py-1" href="${item.url}">
                                                                    <span class="menu-bullet ps-1">
                                                                        <span class="bullet bullet-dot"></span>
                                                                    </span>
                                                                    <span class="menu-title">${item.title}</span>
                                                                </a>
                                                            </div>
                                                                    `
         }
         function createMenu(navigationMenu, links) {
             return `
                                                       <div data-kt-menu-trigger="click" class="menu-item menu-accordion">
                                                           <span class="menu-link hover ps-4 py-1">
                                                               <span class="menu-icon">
                                                                   <i class="${navigationMenu.icon}"></i>
                                                               </span>
                                                               <span class="menu-title">${navigationMenu.title}</span>
                                                               <span class="menu-arrow"></span>
                                                           </span>

                                                           <div class="menu-sub menu-sub-accordion">${links.join('')}</div>
                                                       </div>

                                                        `;
         }
         function createNavigation(navigation, menus) {
             return ` <div data-kt-menu-trigger="click" class="menu-item ${navigation.isOpen ? 'show' : ''} menu-accordion">
                                                       <span class="menu-link hover ps-2">
                                                           <span class="menu-icon">
                                                               <i class="${navigation.icon}">
                                                                    <span class="path1"></span>
                                                        <span class="path2"></span>
                                                        <span class="path3"></span>
                                                        <span class="path4"></span>
                                                               </i>
                                                           </span>
                                                           <span class="menu-title">${navigation.title}</span>
                                                           <span class="menu-arrow"></span>
                                                       </span>
                                                       <div class="menu-sub menu-sub-accordion">
                                                           ${menus.join('')}
                                                       </div>
                                                   </div>`
         }

         function buildNavigation(navigationList) {
             return navigationList.map(navigation => {
                 let menus = navigation.items.map(navigationMenu => {
                     if (navigationMenu.isMenu) {
                         var links = navigationMenu.items.map(link => {
                             return createLink(link);
                         })

                         return createMenu(navigationMenu, links);
                     } else {
                         return createLink(navigationMenu);
                     }
                 })

                 return createNavigation(navigation, menus);
             })
         }

         searchInNavigation.addEventListener("input", function (event) {
             let filteredNavigation = [];
             if (event.target.value == "") {
                 filteredNavigation = buildNavigation(navigations);
             } else {
                 navigations.forEach(navigation => {
                     navigation.items.forEach(menu => {
                         if (menu.isMenu) {
                             menu.items.forEach(link => {
                                 if (link.title.toLocaleUpperCase("tr-TR").includes(event.target.value.toLocaleUpperCase("tr-TR"))) {
                                     filteredNavigation.push(createLink(link));
                                 }
                             })
                         } else {
                             if (menu.title.toLocaleUpperCase("tr-TR").includes(event.target.value.toLocaleUpperCase("tr-TR"))) {
                                 filteredNavigation.push(createLink(menu));
                             }
                         }
                     })
                 })
             }

             navigationContainer.innerHTML = filteredNavigation.join("")
         });

     });

     $(document).ready(function () {
         AnaSayfaBilgileriGetir();
         bildirimHubBaglantisi();

     })

    </script>
    @RenderSection("Scripts", required: false)
    <!--end::Custom Javascript-->
    <!--end::Javascript-->
</body>
<!--end::Body-->

</html>
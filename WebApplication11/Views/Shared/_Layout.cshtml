                                                <a href="/POSAPI/UyelikPaketleri">Üyeliğinizi Uzatmak için ödeme planlarına göz atın.</a>
                                            </div>
                                        }
                                    }
                                }
                            </div>
                            <!--end::Page title-->

                        </div>
                        <div id="kt_app_content" class="app-content flex-column-fluid">
                            <!--begin::Content container-->
                            @RenderBody()
                            
                        </div>
                    </div>
                    <!--end::Content wrapper-->

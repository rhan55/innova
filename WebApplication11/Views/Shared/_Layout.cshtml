@using YKPortal.Models.Dto
@using System.Data
@using System.Data.SqlClient
@using YKPortal.Models

@{
    string UyelikIsim = HttpUtility.UrlDecode(Request.Cookies["UyelikIsim"].Value);
    string KullaniciAdi = HttpUtility.UrlDecode(Request.Cookies["KullaniciAdi"].Value);
    string Isim = HttpUtility.UrlDecode(Request.Cookies["Isim"].Value);
    string Resim = HttpUtility.UrlDecode(Request.Cookies["Resim"].Value);
    string KullaniciID = HttpUtility.UrlDecode(Request.Cookies["KullaniciID"].Value);
    string UyelikID = HttpUtility.UrlDecode(Request.Cookies["UyelikID"].Value);
    string UyelikBitisTarihi = HttpUtility.UrlDecode(Request.Cookies["UyelikBitisTarihi"].Value);

    SqlCommand cmd = new SqlCommand();
    cmd.CommandText = "p_KullaniciYetkileri";
    cmd.CommandType = System.Data.CommandType.StoredProcedure;
    cmd.Parameters.AddWithValue("@UyelikID", UyelikID);
    cmd.Parameters.AddWithValue("@KullaniciID", KullaniciID);
    DataTable dtYetkikler = (DataTable)IDVeritabani.Sorgula(cmd, SorgulaTuru.Tablo);

    List<YetkilerDto> yetkiler = new List<YetkilerDto>();

    foreach (DataRow row in dtYetkikler.Rows)
    {
        if (Convert.ToBoolean(row["Gor"]) == true)
        {
            yetkiler.Add(new YetkilerDto()
            {
                MenuID = Convert.ToString(row["MenuID"]),
                KullaniciID = Convert.ToString(row["KullaniciID"]),
                UyelikID = Convert.ToString(row["UyelikID"]),
                Menu = Convert.ToString(row["Menu"]),
                UstID = Convert.ToString(row["UstID"]),
                url = Convert.ToString(row["url"]),
                icon = Convert.ToString(row["icon"]),
            });
        }
    }


}


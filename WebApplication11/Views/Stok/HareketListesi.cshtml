
@{
    ViewBag.Title = "Stok Hareket Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal ToplamBorc = 0;
    decimal ToplamMiktar = 0;

    string StokID = "";
    string Isim = "";
    if (ViewBag.Stok != null)
    {
        StokID = ViewBag.Stok.ID;
        Isim = ViewBag.Stok.Isim;
    }

}
<div class="container-fluid m-0 p-0">
    <div class="row p-0 m-0">
        <div class="col-lg-12 p-0">
            <div class="content d-flex justify-center flex-column flex-column-fluid p-0" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container" class="container-fluid p-4 m-0">
                        <div class="card card-flush border-0 shadow-none m-0 p-0">
                            <div class="card-header align-items-center border-0 shadow-0 gap-2 gap-md-5 m-0">

                                <div>
                                    <form action="/Stok/HareketListesi" class="stok-listesi " method="get" style="float:left;">
                                        <input type="hidden" name="ID" value="@ViewBag.ID" />
                                        <div class="form-group me-6 mt-0">
                                            <label for="StokID" class="form-label">Stok Seç</label>
                                            <select class="form-select form-select-solid p-2 rounded-1 w-300px p-1" name="StokID" id="StokID" aria-label="Floating label select example" data-control="select2" data-placeholder="arama yapmak için birşeyler yazın...">
                                                @if (StokID != "")
                                                {
                                                    <option value="@StokID" selected>@Isim</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-primary btn-sm fw-bold">Seç</button>
                                        </div>
                                    </form>

                                    @if (StokID != "")
                                    {
                                        <a href="/Stok/YeniStokHareketKaydi/?StokID=@(StokID)&Isim=@(Isim)" class="btn btn-primary btn-sm fw-bold me-4" style=" float:left;margin-left: 3px;">
                                            <i class="ki-duotone ki-plus fs-2"></i>Hareket Ekle
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/Stok/YeniStokHareketKaydi/" class="btn btn-primary btn-sm fw-bold me-4" style=" float:left;margin-left: 3px;">
                                            <i class="ki-duotone ki-plus fs-2"></i>Hareket Ekle
                                        </a>
                                    }


                                </div>
                            </div>
                        </div>

                        <div>


                            <div class="my-4 scroll-x">
                                <table class="table align-middle border rounded table-row-dashed p-4 fs-6 display nowrap w-100">
                                    <thead>
                                        <!--begin::Table row-->
                                        <tr class="text-start" style="font-size:15px;">
                                            <th class="min-w-125px"><strong>Tarih</strong></th>
                                            <th class="min-w-125px"><strong>Vade Tarihi</strong></th>
                                            <th class="min-w-125px"><strong>Belge No</strong></th>
                                            <th class="min-w-125px"><strong>Hareket Tipi</strong></th>
                                            <th class="min-w-125px" style="text-align:right;"><strong>Miktar</strong></th>
                                            <th class="min-w-125px" style="text-align:right;"><strong>Tutar</strong></th>
                                            <th class="min-w-125px"><strong>Döviz Tipi</strong></th>
                                            <th class="min-w-125px"><strong>Açıklama</strong></th>
                                            <th class="text-end min-w-100px"><strong>İşlemler</strong></th>
                                        </tr>
                                        <!--end::Table row-->
                                    </thead>
                                    <tbody class="text-gray-600 fw-semibold">
                                        @for (var i = 0; i < Model.Rows.Count; i++)
                                        {
                                            ToplamBorc += Convert.ToString(Model.Rows[i]["GC"]) == "G" ? Convert.ToDecimal(Model.Rows[i]["Tutar"]) : Convert.ToDecimal(Model.Rows[i]["Tutar"]) * -1;
                                            ToplamMiktar += Convert.ToString(Model.Rows[i]["GC"]) == "G" ? Convert.ToDecimal(Model.Rows[i]["Miktar"]) : Convert.ToDecimal(Model.Rows[i]["Miktar"]) * -1;
                                            <tr style="@(Convert.ToString(Model.Rows[i]["GC"]) == "G" ? "color:green;" : "color:darkred;")">
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToDateTime(Model.Rows[i]["Tarih"]).ToString("dd-MM-yyyy"))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToDateTime(Model.Rows[i]["VadeTarihi"]).ToString("dd-MM-yyyy"))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToString(Model.Rows[i]["BelgeNo"]))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToString(Model.Rows[i]["HareketTipi"]))
                                                </td>
                                                <td class="pt-4 pb-4" style="text-align:right;">
                                                    @(String.Format("{0:N2}", Convert.ToDecimal(Model.Rows[i]["Miktar"])))
                                                </td>
                                                <td class="pt-4 pb-4" style="text-align:right;">
                                                    @(String.Format("{0:N2}", Convert.ToString(Model.Rows[i]["GC"]) == "G" ? Convert.ToDecimal(Model.Rows[i]["Tutar"]) : Convert.ToDecimal(Model.Rows[i]["Tutar"])*-1))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToString(Model.Rows[i]["DovizTipi"]))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToString(Model.Rows[i]["Aciklama"]))
                                                </td>

                                                <td class="text-end pt-4 pb-4">
                                                    <button class="dropdown btn btn-light btn-active-light-primary btn-flex btn-center btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                        İşlemler
                                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                                    </button>
                                                    <!--begin::Menu-->
                                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-0 px-0" data-kt-menu="true">
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <a href="/Stok/YeniStokHareketKaydi/?StokID=@(StokID)&Isim=@(Isim)&KayitID=@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link py-2  px-2">Düzenle</a>
                                                        </div>
                                                        <!--end::Menu item-->
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link rounded-0 px-2 py-2 btn-sil" data-bs-toggle="modal" data-bs-target="#Hareket-silme">
                                                                Sil
                                                            </button>

                                                        </div>
                                                        <!--end::Menu item-->

                                                    </div>
                                                    <!--end::Menu-->
                                                </td>
                                            </tr>
                                        }
                                    <tr class="text-start" style="font-size:15px;@(ToplamBorc-ToplamMiktar < 0 ? "color:red;" : "color:green;")">
                                        <th class="min-w-125px"></th>
                                        <th class="min-w-125px"></th>
                                        <th class="min-w-125px"></th>
                                        <th class="min-w-125px"></th>
                                        <th class="min-w-125px" style="text-align:right;"><strong>@(String.Format("{0:N2}", ToplamMiktar))</strong></th>
                                        <th class="min-w-125px" style="text-align:right;"><strong>@(String.Format("{0:N2}", ToplamBorc))</strong></th>
                                        <th class="min-w-125px"></th>
                                        <th class="min-w-125px mt-8"></th>
                                        <th class="min-w-125px"></th>
                                    </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
            </div>   
        </div>
    </div>
</div>


<div class="modal fade" id="Hareket-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Hareket Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Hareketi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("HareketSil","Stok",null)">
                    <input type="hidden" name="kayitid" value="" />
                    <input type="hidden" name="StokID" value="@StokID" />
                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
}
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="kayitid"]').value = silButonu.dataset.id;
                })
            });


        });

        function setCookie(name, value, days) {
            let expires = "";
            if (days) {
                let date = new Date();
                date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                expires = "; expires=" + date.toUTCString();
            }
            document.cookie = name + "=" + (value || "") + expires + "; path=/";
        }

        function getCookie(name) {
            let nameEQ = name + "=";
            let ca = document.cookie.split(';');
            for (let i = 0; i < ca.length; i++) {
                let c = ca[i];
                while (c.charAt(0) == ' ') c = c.substring(1, c.length);
                if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
            }
            return null;
        }

        var select = document.querySelectorAll("#select")


        $(function () {

            const StokIDSelect = $('#StokID').select2(select2Options("/Stok/SelectListe"));


    </script>
}

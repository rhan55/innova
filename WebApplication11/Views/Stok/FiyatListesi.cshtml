
@{
    ViewBag.Title = "Stok Hareket Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal ToplamBorc = 0;
    decimal ToplamAlacak = 0;

    string StokID = "";
    if (ViewBag.Stok != null)
    {
        StokID = ViewBag.Stok.ID;

    }

}
<div class="container-fluid m-0 p-0">
    <div class="row p-0 m-0">
        <div class="col-lg-12 p-0">
            <div class="content d-flex justify-center flex-column flex-column-fluid p-0" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container" class="container-fluid p-4 m-0">
                        <div class="card card-flush border-0 shadow-none m-0 p-0">
                            <div class="card-header align-items-center border-0 shadow-0 gap-2 gap-md-5 m-0">

                                <div>
                                    <form action="/Stok/HareketListesi" class="stok-listesi " method="get" style="float:left;">
                                        <input type="hidden" name="ID" value="@ViewBag.ID" />

                                    </form>

                                    @if (StokID != "")
                                    {
                                        <a href="/Stok/FiyatEkle/?StokID=@(StokID)" class="btn btn-primary btn-sm fw-bold me-4" style=" float:left;margin-left: 3px;">
                                            <i class="ki-duotone ki-plus fs-2"></i>Fiyat Ekle
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/Stok/FiyatEkle/" class="btn btn-primary btn-sm fw-bold me-4" style=" float:left;margin-left: 3px;">
                                            <i class="ki-duotone ki-plus fs-2"></i>Fiyat Ekle
                                        </a>
                                    }


                                </div>
                            </div>
                        </div>

                        <div>


                            <div class="my-4 scroll-x">
                                <table class="table align-middle border rounded table-row-dashed p-4 fs-6 display nowrap w-100">
                                    <thead>
                                        <!--begin::Table row-->
                                        <tr class="text-start" style="font-size:15px;">
                                            <th class="min-w-125px"><strong>Fiyat</strong></th>
                                            <th class="min-w-125px"><strong>Fiyat Grubu</strong></th>
                                            <th class="min-w-125px"><strong>Başlangıç Tarihi</strong></th>
                                            <th class="min-w-125px"><strong>Bitiş Tarihi</strong></th>
                                            <th class="min-w-125px" style="text-align:right;"><strong>Alış</strong></th>
                                            <th class="min-w-125px mt-8" style="text-align:right;"><strong>Satış</strong></th>
                                            <th class="text-end min-w-100px"><strong>İşlemler</strong></th>
                                        </tr>
                                        <!--end::Table row-->
                                    </thead>
                                    <tbody class="text-gray-600 fw-semibold">
                                        @for (var i = 0; i < Model.Rows.Count; i++)
                                        {
                                            ToplamBorc += Convert.ToString(Model.Rows[i]["Tip"]) == "A" ? Convert.ToDecimal(Model.Rows[i]["Fiyat"]) : 0;
                                            ToplamAlacak += Convert.ToString(Model.Rows[i]["Tip"]) == "S" ? Convert.ToDecimal(Model.Rows[i]["Fiyat"]) : 0;
                                            <tr>

                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToString(Model.Rows[i]["Fiyat"]))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToString(Model.Rows[i]["FiyatGrubu"]))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToDateTime(Model.Rows[i]["BaşlangicTarihi"]).ToString("dd-MM-yyyy"))
                                                </td>
                                                <td class="pt-4 pb-4">
                                                    @(Convert.ToDateTime(Model.Rows[i]["BitisTarihi"]).ToString("dd-MM-yyyy"))
                                                </td>
                                                <td class="pt-4 pb-4" style="text-align:right;">
                                                    @(String.Format("{0:N2}", Convert.ToString(Model.Rows[i]["Tip"]) == "A" ? Convert.ToDecimal(Model.Rows[i]["Tip"]) : 0 ))
                                                </td>
                                                <td class="pt-4 pb-4" style="text-align:right;">
                                                    @(String.Format("{0:N2}", Convert.ToString(Model.Rows[i]["Tip"]) == "S" ? Convert.ToDecimal(Model.Rows[i]["Tip"]) : 0 ))
                                                </td>


                                                <td class="text-end pt-4 pb-4">
                                                    <button class="dropdown btn btn-light btn-active-light-primary btn-flex btn-center btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                                        İşlemler
                                                        <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                                    </button>
                                                    <!--begin::Menu-->
                                                    <div class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px py-0 px-0" data-kt-menu="true">
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <a href="/Stok/YeniStokHareketKaydi/?StokID=@(StokID)&ID=@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link py-0  px-2">Düzenle</a>
                                                        </div>
                                                        <!--end::Menu item-->
                                                        <!--begin::Menu item-->
                                                        <div class="menu-item p-0">
                                                            <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link rounded-0 px-2 py-0 btn-sil" data-bs-toggle="modal" data-bs-target="#Hareket-silme">
                                                                Sil
                                                            </button>

                                                        </div>
                                                        <!--end::Menu item-->

                                                    </div>
                                                    <!--end::Menu-->
                                                </td>
                                            </tr>
                                        }
                                        <tr class="text-start" style="font-size:15px;@(ToplamBorc-ToplamAlacak < 0 ? "color:red;" : "color:green;")">
                                            <th class="min-w-125px"></th>
                                            <th class="min-w-125px"></th>
                                            <th class="min-w-125px"></th>
                                            <th class="min-w-125px"></th>
                                            <th class="min-w-125px"></th>
                                            <th class="min-w-125px" style="text-align:right;"><strong>@(String.Format("{0:N2}", ToplamBorc))</strong></th>
                                            <th class="min-w-125px mt-8" style="text-align:right;"><strong>@(String.Format("{0:N2}", ToplamAlacak))</strong></th>
                                            <th class="min-w-125px"></th>
                                            <th class="min-w-125px mt-8" style=""><strong>@(String.Format("Bakiye : {0:N2}", ToplamBorc-ToplamAlacak))</strong></th>
                                            <th class="min-w-125px"></th>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="Hareket-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Hareket Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Hareketi silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm fw-bold" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("FiyatSil","Stok",null)">
                    <input type="hidden" name="id" value="" />
                    <input type="hidden" name="StokID" value="@StokID" />
                    <button type="submit" class="btn btn-danger btn-sm fw-bold">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>


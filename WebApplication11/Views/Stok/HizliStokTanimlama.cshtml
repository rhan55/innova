
@using YKPortal.Models.Dto
@using System.Data
@model System.Data.DataTable
@{
    ViewBag.Title = "Stok Tanımlama";
    Layout = "~/Views/Shared/_Layout.cshtml";

    DataTable dtGrupKodu1 = ViewBag.dtGrupKodu1 as DataTable;
    DataTable dtGrupKodu2 = ViewBag.dtGrupKodu2 as DataTable;
}
<div class="container-fluid d-flex" id="kt_content" style="width:90%;padding:3px;">
    <div class="row" style="width:100%;">


        <table style="width:100%;">
            <tr>
                <td style="width:100%;">
                    <lable>Stok Ara</lable>
                    <select name="StokAra" id="StokAra" class="form-control" onchange="StokSec();">
                    </select>
                </td>
            </tr>
            <tr>
                <td>
                    <label for="Kod1">Grup Kodu</label>
                    <select name="Kod1" id="Kod1" class="form-control" onchange="StokKoduOlustur();">
                        <option value="">Seçim yapınız...</option>
                        @foreach (DataRow item in dtGrupKodu1.Rows)
                        {
                            <option value="@item["ID"]">@item["Deger"]</option>
                        }
                    </select>
                </td>
            </tr>
            <tr>
                <td>
                    <label for="Kod2">Kod 1</label>
                    <select name="Kod2" id="Kod2" class="form-control" onchange="StokKoduOlustur();">
                        <option value="">Seçim yapınız...</option>
                        @foreach (DataRow item in dtGrupKodu2.Rows)
                        {
                            <option value="@item["ID"]">@item["Deger"]</option>
                        }
                    </select>
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="StokKodu">Stok Kodu</label>
                    <input type="text" name="StokKodu" id="StokKodu" value="" style="background-color:lightgray;" class="form-control" readonly="readonly" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="StokAdi">Stok Adı</label>
                    <input type="text" name="StokAdi" id="StokAdi" value="" class="form-control" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="OlcuBirimi">Ölçü Birimi</label>
                    <input type="text" name="OlcuBirimi" id="OlcuBirimi" value="" class="form-control" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="Barkod1">Barkod 1</label>
                    <input type="text" name="Barkod1" id="Barkod1" value="" class="form-control" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="Barkod2">Barkod 2</label>
                    <input type="text" name="Barkod2" id="Barkod2" value="" class="form-control" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="Barkod3">Barkod 3</label>
                    <input type="text" name="Barkod3" id="Barkod3" value="" class="form-control" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <label for="Barkod3">Fotoğraf</label>
                    <input type="file" name="Resim" id="Resim" value="" class="form-control" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <br /><br />
                    <input type="button" name="Kaydet" id="Kaydet" value="Kaydet" class="btn btn-primary" onclick="Kaydet();" style="width:75px;" />
                    <input type="button" name="Kaydet" id="Yeni" value="Yeni" class="btn btn-primary" onclick="window.location.reload();" style="width:75px;" />
                </td>
            </tr>
            <tr>
                <td colspan="2">
                    <img id="Dosya" name="Dosya" src="" height="300" />
                </td>
            </tr>
        </table>

    </div>
</div>


@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    
    <script>
        $(function () {

            const StokIDSelect = $('#StokAra').select2(select2Options("/Stok/SelectListe"));



        function StokKoduOlustur() {
            /*
            $.ajax({
                async: false,
                cache: false,

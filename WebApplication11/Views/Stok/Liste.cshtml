@model System.Data.DataTable
@{
    ViewBag.Title = "Stok Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container-fluid  m-0 p-0">
    <div class="row p-0 m-0">

        <div class="col-lg-12 p-0">
            <div class="content d-flex justify-center flex-column flex-column-fluid" id="kt_content">
                <!--begin::Post-->
                <div class="post d-flex flex-column-fluid" id="kt_post">
                    <!--begin::Container-->
                    <div id="kt_content_container" class="container-fluid p-0 m-0">
                        <div class="card shadow-none border-0">
                            <div class="card-header align-items-center shadow-none border-0 py-5 gap-2">

                                <div class="card-title">
                                    <!--begin::Export buttons-->
                                    <div id="kt_datatable_example_1_export" class="d-none"></div>
                                    <!--end::Export buttons-->
                                </div>
                                <div class="card-toolbar flex-row-fluid justify-content-end gap-3">
                                    <button type="button" id="topluSilButon" class="btn btn-light-primary btn-sm fw-bold" onclick="$('#DivFiltre').toggle();">
                                        <span class="indicator-label fw-bold">Filtre</span>
                                        <i class="ki-duotone ki-filter">
                                            <span class="path1"></span>
                                            <span class="path2"></span>
                                        </i>
                                    </button>
                                    <div>
                                        <button type="button" id="topluSilButon" class="btn btn-light-primary btn-sm fw-bold" data-bs-toggle="modal" data-bs-target="#Stok-toplu-silme">
                                            <span class="indicator-label">Toplu Sil</span>
                                        </button>
                                    </div>
                                    <button type="button" class="btn btn-light-primary btn-sm fw-bold" data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                        <i class="ki-duotone ki-exit-down fs-2"><span class="path1"></span><span class="path2"></span></i>
                                        Dışarı aktar
                                    </button>
                                    <!--begin::Menu-->
                                    <a class="btn btn-primary btn-sm fw-bold" href="/Stok/ExcelIceAktar">
                                        Excel içe aktar

                                    </a>
                                    <div id="kt_datatable_example_export_menu" class="menu menu-sub menu-sub-dropdown menu-column menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-200px p-0" data-kt-menu="true">
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link py-0 px-2" data-kt-export="copy">
                                                Panoya Kopyala
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link  py-0 px-2" data-kt-export="excel">
                                                Excel olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link py-0 px-2" data-kt-export="csv">
                                                CSV olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                        <!--begin::Menu item-->
                                        <div class="menu-item p-0">
                                            <a href="#" class="menu-link py-0 px-2" data-kt-export="pdf">
                                                PDF olarak dışarı aktar
                                            </a>
                                        </div>
                                        <!--end::Menu item-->
                                    </div>
                                    <!--end::Menu-->
                                    <!--end::Export dropdown-->
                                    <!--begin::Hide default export buttons-->
                                    <div id="kt_datatable_example_buttons" class="d-none"></div>
                                    <!--end::Hide default export buttons-->
                                    <a href="/Stok/Ekle" class="btn btn-primary btn-sm fw-bold me-4">
                                        <i class="ki-duotone ki-plus fs-2"></i>Stok Ekle
                                    </a>
                                </div>

                            </div>

                        </div>

                    </div>
                    <div>
                        <div class="card border-0 shadow-none ps-4 pe-4" style="display:none;" id="DivFiltre" name="DivFiltre">
                            <div class="card-body">
                                <!--begin::Filtreleme alanı-->
                                <form method="POST" action="" class="content" id="datatableFilters">
                                    <div class="d-flex">
                                        <h3 class="text-gray-600 fw-bold">Filtreler</h3>
                                        <i class="ki-duotone ki-filter-search fs-2">
                                            <span class="path1"></span>
                                            <span class="path2"></span>
                                            <span class="path3"></span>
                                        </i>
                                    </div>

                                    <div class="row">
                                        <div class="col-lg-3">
                                            <!--begin::Label-->
                                            <label for="Kod" class="fw-semibold fs-6 mb-2 text-gray-600 fw-bold">Kod</label>
                                            <!--end::Label-->
                                            <!--begin::Input-->
                                            <input type="text" name="Kod" id="Kod" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.Kod)" />
                                            <!--end::Input-->
                                        </div>
                                        <div class="col-lg-3">
                                            <!--begin::Label-->
                                            <label for="Isim" class="fw-semibold fs-6 mb-2 text-gray-600 fw-bold">Stok Adı</label>
                                            <!--end::Label-->
                                            <!--begin::Input-->
                                            <input type="text" name="Isim" id="Isim" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.Isim)" />
                                            <!--end::Input-->
                                        </div>
                                        <div class="col-lg-3">
                                            <!--begin::Label-->
                                            <label for="GrupKoduAdi1" class="fw-semibold fs-6 mb-2 text-gray-600 fw-bold">Grup Kodu1</label>
                                            <!--end::Label-->
                                            <!--begin::Input-->
                                            <input type="text" name="GrupKoduAdi1" id="GrupKoduAdi1" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.GrupKodu1ID)" />
                                            <!--end::Input-->
                                        </div>
                                        <div class="col-lg-3">
                                            <!--begin::Label-->
                                            <label for="GrupKoduAdi2" class="fw-semibold fs-6 mb-2 text-gray-600 fw-bold">Grup Kodu2</label>
                                            <!--end::Label-->
                                            <!--begin::Input-->
                                            <input type="text" name="GrupKoduAdi2" id="GrupKoduAdi2" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.GrupKodu2ID)" />
                                            <!--end::Input-->
                                        </div>

                                    </div>
                                    <div class="row mt-4">

                                        <div class="col-lg-3">
                                            <!--begin::Label-->
                                            <label for="Aciklama" class="fw-semibold fs-6 mb-2 text-gray-600 fw-bold">Açıklama</label>
                                            <!--end::Label-->
                                            <!--begin::Input-->
                                            <input type="text" name="Aciklama" id="Aciklama" class="form-control form-control-solid px-2 py-1 mb-3 mb-lg-0" value="@(ViewBag.Filters.Aciklama)" />
                                            <!--end::Input-->
                                        </div>
                                        <div class="col-lg-3 offset-lg-6 d-flex justify-content-end align-items-end">
                                            <button type="button" id="filtreleriTemizle" class="btn btn-light me-3 btn-sm fw-bold" data-kt-users-modal-action="cancel">Temizle</button>
                                            <button type="submit" class="btn btn-primary btn-sm fw-bold" data-kt-users-modal-action="Ara">
                                                <span class="indicator-label">Filtrele</span>
                                            </button>
                                        </div>
                                    </div>

                                </form>
                                <!--end::Filtreleme alanı-->
                            </div>
                        </div>
                    </div>
                </div>
                <div class="my-4 scroll-x">

                    <table class="table align-middle border rounded table-row-dashed fs-6 g-5 p-5" id="Stok-datatable">

                        <thead>

                            <!--begin::Table row-->
                            <tr class="text-start" style="font-size:15px;">
                                <th id="select" class="min-w-40px max-w-40px no-export"></th>
                                <th class="min-w-125px no-export"><strong>İsim</strong></th>
                                <th class="min-w-125px"><strong>Stok İsmi</strong></th>
                                <th class="min-w-125px"><strong>Stok Kodu</strong></th>
                                <th class="min-w-125px mt-8"><strong>Açıklama</strong></th>
                                <th class="min-w-125px mt-8"><strong>GrupKodu1</strong></th>
                                <th class="min-w-125px"><strong>GrupKodu2</strong></th>
                                <th class="text-end min-w-100px no-export"><strong>İşlemler</strong></th>
                                <th class="text-end min-w-100px no-export"><strong>ID</strong></th>
                            </tr>
                            <!--end::Table row-->
                        </thead>
                        <tbody class="text-gray-600 fw-semibold">
                            @for (var i = 0; i < Model.Rows.Count; i++)
                            {
                                <tr>
                                    <td class="pt-4 pb-4">
                                    </td>

                                    <td class="">
                                        @(Convert.ToString(Model.Rows[i]["Kod"])) -
                                        <strong> @(Convert.ToString(Model.Rows[i]["Isim"])) </strong>
                                    </td>
                                    <td class="pt-4 pb-4">
                                        @(Convert.ToString(Model.Rows[i]["Isim"]))
                                    </td>
                                    <td class="pt-4 pb-4">
                                        @(Convert.ToString(Model.Rows[i]["Kod"]))
                                    </td>
                                    <td class="pt-4 pb-4">
                                        @(Convert.ToString(Model.Rows[i]["Aciklama"]))
                                    </td>
                                    <td class="pt-4 pb-4">
                                        @(Convert.ToString(Model.Rows[i]["GrupKoduAdi1"]))
                                    </td>
                                    <td class="pt-4 pb-4">
                                        @(Convert.ToString(Model.Rows[i]["GrupKoduAdi2"]))
                                    </td>
                                    <td class="text-end">
                                        <a href="#" class="btn btn-light btn-active-light-primary btn-flex btn-center btn-sm fw-bold text-gray-800 " data-kt-menu-trigger="click" data-kt-menu-placement="bottom-end">
                                            İşlemler
                                            <i class="ki-duotone ki-down fs-5 ms-1"></i>
                                        </a>
                                        <!--begin::Menu-->
                                        <div class="menu menu-sub menu-sub-dropdown menu-column  menu-gray-600 menu-state-bg-light-primary fw-semibold fs-7 w-125px p-0" data-kt-menu="true">
                                            <!--begin::Menu item-->
                                            <div class="menu-item p-0">
                                                <a href="/Stok/Duzenle/@(Convert.ToString(Model.Rows[i]["ID"]))" class="menu-link py-0 px-2">Düzenle</a>
                                            </div>
                                            <!--end::Menu item-->
                                            <div class="menu-item p-0">
                                                <a href="/Stok/YeniStokHareketKaydi?StokID=@(Convert.ToString(Model.Rows[i]["ID"]))&Isim=@ViewBag.Isim" class="menu-link py-0  px-2">Yeni Stok Hareket</a>
                                            </div>
                                            <!--begin::Menu item-->
                                            <div class="menu-item p-0">
                                                <button type="button" data-id="@(Convert.ToString(Model.Rows[i]["ID"]))" class="btn btn-sm w-100 menu-link rounded-0 py-0 px-2 btn-sil stok-silme" data-bs-toggle="modal" data-bs-target="#Stok-silme">
                                                    Sil
                                                </button>
                                            </div>
                                            <!--end::Menu item-->
                                        </div>
                                        <!--end::Menu-->
                                    </td>
                                    <td>@(Convert.ToString(Model.Rows[i]["ID"]))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <!--end::Container-->
    </div>
</div>
</div>
</div>

<div class="modal fade" id="Stok-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Stok Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Stok bilgisini silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Vazgeç</button>
                <form method="post" id="silme-formu" action="@Url.Action("Sil","Stok",null)">
                    <input type="hidden" name="id" value="" />
                    <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="Stok-toplu-silme" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Stok Silme İşlemi</h3>

                <!--begin::Close-->
                <div class="btn btn-icon btn-sm btn-active-light-primary ms-2" data-bs-dismiss="modal" aria-label="Close">
                    <i class="ki-duotone ki-cross fs-1"><span class="path1"></span><span class="path2"></span></i>
                </div>
                <!--end::Close-->
            </div>

            <div class="modal-body">
                <p>Seçtiğiniz stok bilgilerini silmek istediğinize emin misiniz?</p>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Vazgeç</button>
                <button type="button" id="topluSilOnay" class="btn btn-danger btn-sm">Sil</button>
            </div>
        </div>
    </div>
</div>
@section Styles {
}
@section Scripts {
    <script>

        function setCookie(name, value, days) {
            let expires = "";
            if (days) {
                let date = new Date();
                date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                expires = "; expires=" + date.toUTCString();
            }
            document.cookie = name + "=" + (value || "") + expires + "; path=/";
        }

        function getCookie(name) {
            let nameEQ = name + "=";
            let ca = document.cookie.split(';');
            for (let i = 0; i < ca.length; i++) {
                let c = ca[i];
                while (c.charAt(0) == ' ') c = c.substring(1, c.length);
                if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
            }
            return null;
        }

        var select = document.querySelectorAll("#select")


        document.addEventListener('DOMContentLoaded', function () {

            const stokDatatable = KTDatatablesExample.init();

            stokDatatable.loadDataTableSettingsFromCookie(stokDatatable.datatable);

            stokDatatable.datatable.on('column-visibility.dt', function (e, settings, column, state) {
                stokDatatable.saveDataTableColumnSettingsToCookie(stokDatatable.datatable, column, state)
            });

            document.querySelectorAll('.btn-sil').forEach(silButonu => {
                silButonu.addEventListener('click', function () {
                    document.querySelector('form#silme-formu input[name="id"]').value = silButonu.dataset.id;
                });
            });

            const filtreleriTemizle = document.querySelector("#filtreleriTemizle");

            if (filtreleriTemizle) {

                filtreleriTemizle.addEventListener("click", function (e) {
                    e.preventDefault();
                    document.querySelector("form#datatableFilters").querySelectorAll("input").forEach(input => {
                        input.value = ""
                    })
                    document.querySelector("form#datatableFilters").submit();
                });
            }

            $('#topluSilOnay').on('click', function () {
                topluSil();
            })

            function topluSil() {
                var idListesi = [];
                $('#Stok-datatable tr.selected .btn-sil.stok-silme').each(function (event) {
                    var id = $(this).attr('data-id');
                    idListesi.push(id);

                })
                $.ajax({
                    url: "/Stok/TopluSil",
                    method: "POST",
                    data: { idListesi: idListesi },
                    success: function (response) {

                        console.log("Success:", response);
                        window.location.reload();
                    },
                    error: function (xhr, status, error) {

                        console.log("Error:", xhr.responseText);
                    }
                })

            }
        });

        var colResize_options = {
            isEnabled: true,
            hoverClass: 'dt-colresizable-hover',
            hasBoundCheck: true,
            minBoundClass: 'dt-colresizable-bound-min',
            isResizable: function (column) { return true; },
            onResize: function (column) { },
            onResizeEnd: function (column) { },
            getMinWidthOf: function ($thNode) { }

        }
        var colReorder_options = {
            realtime: false
        }

        // Class definition
        var KTDatatablesExample = function () {
            // Shared variables
            var table;
            var datatable;


            // Private functions
            var initDatatable = function () {
                // Set date data order
                const tableRows = table.querySelectorAll('tbody tr');

                // Init datatable --- more info on datatables: https://datatables.net/manual/
                datatable = $(table).DataTable({
                    /* "info": false,*/


                    //scrollY: true,
                    //scrollX: true,
                    //scrollCollopse: true,
                    colResize: true,
                    colReorder: colReorder_options,
                    autoWidth: false,
                    caching: true,
                    select: {
                        style: "multi",
                        style: 'bootstrap',
                        selector: 'td:first-child'
                    },
                    order: [
                        [2, "asc"],
                    ],
                    ordering: true,
                    paging: true,
                    pageLength: 10,


                    language: { url: '//cdn.datatables.net/plug-ins/2.0.7/i18n/tr.json', },

                    columnDefs: [
                        {
                            targets: [0, 7],
                            orderable: false
                        },
                        {
                            render: DataTable.render.select(),
                            targets: 0,
                            width: "40px"
                        },
                        {
                            targets: [2, 3, 8],
                            visible: false
                        },
                        {
                            targets: [0, 7, 8, 2, 3],
                            className: 'noVis'
                        }

                    ],

                    order: [[1, 'asc']],
                    layout: {
                        topStart: {
                            buttons: [
                                {
                                    extend: 'colvis',
                                    columns: ':not(.noVis)',
                                    popoverTitle: 'Görünecek Kolonları Seçiniz'
                                }

                            ],


                        },
                        topEnd: {
                            pageLength: {
                                menu: [
                                    [10, 20, 50, 100, -1],
                                    ['10 Adet', '20 Adet', '50 Adet', '100 Adet', "Tümü"]
                                ]
                            }
                        }
                    },


                });

                datatable.on('columns-reordered', function (e, settings, details) {
                    KTMenu.createInstances();
                });
            }


            // Hook export buttons
            var exportButtons = () => {
                const documentTitle = 'Stok-Listesi-' + moment(new Date()).format("DD-MM-YYYY");
                var buttons = new $.fn.dataTable.Buttons(table, {
                    buttons: [
                        {
                            extend: 'copyHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'excelHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'csvHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        },
                        {
                            extend: 'pdfHtml5',
                            title: documentTitle,
                            exportOptions: {
                                columns: ['th:not(.no-export)'],
                            }
                        }
                    ]
                }).container().appendTo($('#kt_datatable_example_buttons'));

                // Hook dropdown menu click event to datatable export buttons
                const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                exportButtons.forEach(exportButton => {
                    exportButton.addEventListener('click', e => {
                        e.preventDefault();

                        // Get clicked export value
                        const exportValue = e.target.getAttribute('data-kt-export');
                        const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                        // Trigger click event on hidden datatable export buttons
                        target.click();
                    });
                });
            }

            // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
            function getDataTableColumnSettings(table) {
                let columnSettings = [];
                table.columns().every(function () {
                    let column = this;

                    columnSettings.push({
                        index: column.index(),
                        visible: column.visible(),

                    });
                });
                return columnSettings;
            }
            // Kolonları aldıktan sonra Stok-datatable cookie'si içerisinde kaydedeceğiz.
            function saveDataTableSettingsToCookie(table) {
                let settings = getDataTableColumnSettings(table);
                setCookie('Stok-datatable', JSON.stringify(settings), 7);
            }

            function saveDataTableColumnSettingsToCookie(table, column, state) {
                var settings = getCookie("Stok-datatable");

                if (settings) {
                    settings = JSON.parse(settings);
                    settings = settings.map(setting => {
                        if (column == setting.index) {
                            setting.visible = state;
                        }

                        return setting;
                    })

                    console.log(settings);

                    setCookie('Stok-datatable', JSON.stringify(settings), 365);
                }
            }

            function loadDataTableSettingsFromCookie(table) {
                let settings = getCookie('Stok-datatable');

                if (settings) {
                    settings = JSON.parse(settings);
                    settings.forEach(function (setting) {
                        let column = table.column(setting.index);
                        column.visible(setting.visible);
                        // Burada başka kolon özelliklerini güncelleyebilirsiniz
                    });
                    table.draw();
                } else {
                    saveDataTableSettingsToCookie(table);
                }
            }

            // Public methods
            return {
                init: function () {
                    table = document.querySelector('#Stok-datatable');

                    if (!table) {
                        return;
                    }

                    initDatatable();
                    exportButtons();

                    return {
                        // Datatable API ile kolon özelliklerini alacağız
                        loadDataTableSettingsFromCookie,
                        saveDataTableSettingsToCookie,
                        saveDataTableColumnSettingsToCookie,
                        datatable
                    }

                },

            };
        }();


        $('#Stok-datatable').on('click', 'thead th', function () {

            var index = table.column(this).index();

            alert(index);

        });



    </script>
}



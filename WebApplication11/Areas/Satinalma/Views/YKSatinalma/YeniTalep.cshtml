                                            Excel olarak dışarı aktar
                                        </a>
                                    </div>
                                    <!--end::Menu item-->
                                    <!--begin::Menu item-->
                                    <div class="menu-item p-0">
                                        <a href="#" class="menu-link px-2 py-0" data-kt-export="csv">
                                            CSV olarak dışarı aktar
                                        </a>
                                    </div>
                                    <!--end::Menu item-->
                                    <!--begin::Menu item-->
                                    <div class="menu-item p-0">
                                        <a href="#" class="menu-link px-2 py-0" data-kt-export="pdf">
                                            PDF olarak dışarı aktar
                                        </a>
                                    </div>
                                    <!--end::Menu item-->
                                </div>
                                <!--end::Menu-->
                                <!--end::Export dropdown-->
                                <!--begin::Hide default export buttons-->
                                <div id="kt_datatable_example_buttons" class="d-none"></div>
                                <!--end::Hide default export buttons-->

                            </div>
                        </div>

                        <div class="px-4 mt-4 scroll-x  w-100">
                            <div class=" w-100">
                                @if (Model != null)
                                {
                                    <table class="table align-middle rounded-0 table-row-dashed  fs-6 g-5" id="TabloListe">
                                        <thead>
                                            <!--begin::Table row-->
                                            <tr class="text-start" style="font-size:15px;">
                                                <th class="min-w-125px text-gray-600"><strong>Kategori1</strong></th>
                                                <th class="min-w-125px text-gray-600"><strong>Kod </strong></th>
                                                <th class="min-w-125px text-gray-600"><strong>İsim (@(sayi) kayıt mevcut.)</strong></th>
                                                <th class="min-w-125px text-gray-600"><strong>Stok</strong></th>
                                                <th class="min-w-125px text-gray-600"><strong>Talep Miktar</strong></th>
                                                <th class="min-w-125px text-gray-600"><strong>Açıklama</strong></th>
                                                <th class=" text-gray-600 d-none no-export"><strong>Dosya</strong></th>


                                            </tr>
                                            <!--end::Table row-->
                                        </thead>

                                        <tbody class="text-gray-600 fw-semibold">
                                            @foreach (DataRow satir in Model.Rows)
                                            {
                                                string renk = "";
                                                if (Model != null && Model.Rows.Count > 0)
                                                {
                                                    <tr>


                                                        <td>
                                                            @(string.IsNullOrEmpty(Convert.ToString(satir["Kategori1"])) ? "Veri Yok" : satir["Kategori1"])
                                                        </td>
                                                        <td>
                                                            @(string.IsNullOrEmpty(Convert.ToString(satir["StokKodu"])) ? "Veri Yok" : satir["StokKodu"])
                                                        </td>
                                                        <td>
                                                            @(string.IsNullOrEmpty(Convert.ToString(satir["StokAdi"])) ? "Veri Yok" : satir["StokAdi"])
                                                        </td>
                                                        <td> @(satir["Bakiye"] == DBNull.Value ? "Veri Yok" : String.Format("{0:N2} {1}", Convert.ToDecimal(satir["Bakiye"]), satir["OlcuBirimi"]))</td>
                                                        <td>
                                                            <div class="d-flex">
                                                                <input class="form-control p-1 rounded-1" style="width:50px;" type="text" data-id="@satir["ID"]" name="Miktar_@(Convert.ToString(satir["IDTresiz"]))" id="Miktar_@(Convert.ToString(satir["IDTresiz"]))" value="0" onchange="TutarKontroluYap(this);" />
                                                                <div class="ms-2">
                                                                    @satir["OlcuBirimi"]
                                                                </div>
                                                            </div>

                                                        </td>
                                                        <td> <textarea class="form-control p-1 rounded-1" rows="1" id="Aciklama_@(Convert.ToString(satir["IDTresiz"]))" name="Aciklama_@(Convert.ToString(satir["IDTresiz"]))"></textarea></td>
                                                        <td style="display: none;"><input type="file" name="Dosya_@(Convert.ToString(satir["IDTresiz"]))" id="Dosya_@(Convert.ToString(satir["IDTresiz"]))" value="" accept="image/png, image/gif, image/jpeg,application/pdf,application/vnd.ms-excel" /></td>

                                                    </tr>

                                                }
                                            }
                                        </tbody>
                                    </table>

                                }
                            </div>
                        </div>
                    </div>
                    <!--end::Container-->
                </div>
                <!--end::Post-->
            </div>

        </div>
    </div>
</div>



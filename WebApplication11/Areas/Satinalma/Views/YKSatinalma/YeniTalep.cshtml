@using System.Data
@model System.Data.DataTable
@{
    ViewBag.Title = "Satınalma - Yeni Talep";
    Layout = "~/Views/Shared/_Layout.cshtml";

    DataTable dtSubeler = ViewBag.dtSubeler as DataTable;
    DataTable dtKategori1 = ViewBag.dtKategori1 as DataTable;
    int sayi = Model.Rows.Count;
}

<div class="Conteiner-fluid">
    <div class="card card-flush w-100 p-6">
        <form action="/Satinalma/YKSatinalma/YeniTalep" method="post">
            <div class="row mb-2">
                <div class="col-lg-3">
                    <div class="form-group">
                        <label class="form-label fs-6 fw-bold text-gray-600 mb-2 pt-2 pe-2">Şube</label>
                        <select id="Sube" class="form-control p-1 rounded-1" name="Sube">
                            @foreach (DataRow satir in dtSubeler.Rows)
                            {
                                if (Convert.ToBoolean(satir["Yetki"]))
                                {
                                    <option value="@satir["Kod"]" @(ViewBag.Sube == Convert.ToString(satir["Kod"]) ? "selected" : "")>@satir["Isim"]</option>
                                }
                            }
                        </select>
                    </div>

                </div>
                <div class="col-lg-3">
                    <div class="form-group">
                        <label class="form-label fs-4 fw-bold text-gray-600 mb-2 pt-2 pe-2">Kategori 1</label>
                        <select id="Kategori1" class="form-control p-1 rounded-1" name="Kategori1" onchange="SecimKategori1();">
                            <option value="">Kategori Seçimi</option>
                            @foreach (DataRow satir in dtKategori1.Rows)
                            {
                                if (ViewBag.Kategori1 == Convert.ToString(satir["Kategori1"]))
                                {

                                }
                                <option value="@satir["Kategori1"]" @(ViewBag.Kategori1 == Convert.ToString(satir["Kategori1"]) ? "selected" : "")>@satir["Kategori1"]</option>
                            }
                        </select>
                    </div>

                </div>
                <div class="col-lg-3">
                    <div class="form-group">
                        <label class="form-label fs-6 fw-bold text-gray-600 mb-2 pt-2 pe-2">Kategori 2</label>
                        <select id="Kategori2" class="form-control p-1 rounded-1" name="Kategori2" onchange="SecimKategori2();">
                        </select>
                    </div>

                </div>
                <div class="col-lg-3">
                    <div class="form-group">
                        <label class="form-label fs-6 fw-bold text-gray-600 mb-2 pt-2 pe-2">Kategori 3</label>
                        <select id="Kategori3" class="form-control p-1 rounded-1" name="Kategori3">
                        </select>
                    </div>

                </div>
            </div>
            <div class="row mb-2">

                <div class="col-lg-3">
                    <div class="form-group">
                        <label class="form-label fs-6 fw-bold text-gray-600 mb-2 pt-2 pe-2">Aranacak Kelime</label>
                        <input type="text" value="" class="form-control p-1 rounded-1" id="AranacakKelime" name="AranacakKelime" />
                    </div>

                </div>
                <div class="col-lg-3">
                    <div class="form-group mt-6">

                    </div>

                </div>
                <div class="col-lg-3">
                    <div class="form-group mt-6">

                    </div>

                </div>
                <div class="col-lg-3 text-end">
                    <div class="form-group mt-6">
                        <input type="submit" name="name" value="Getir" class="btn btn-primary btn-sm" />
                        <input type="button" name="btnKaydet" id="btnKaydet" value="Kaydet" class="btn btn-primary  btn-sm" onclick="Kaydet();" />
                    </div>

                </div>
            </div>




        </form>
    </div>
</div>






<div style="clear:both;"></div>

<div class="container-fluid mt-6 ">
    <div class="col-lg-12">
        <div class="content d-flex flex-column flex-column-fluid" id="kt_content">
            <!--begin::Post-->
            <div class="post d-flex flex-column-fluid overflow-hidden" id="kt_post">
                <!--begin::Container-->
                <div id="kt_content_container p-0" class="container-fluid p-0 m-0">
                    <div class="card card-flush">
                        <div class="card-header align-items-center py-5 gap-2 gap-md-5 px-4">
                            <div class="card-title">

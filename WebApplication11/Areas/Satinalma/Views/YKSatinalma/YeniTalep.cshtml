@section scripts {

    <script type="text/javascript">


            function Kaydet() {
            $("#btnKaydet").val("Bekleyin...");
            var table = document.getElementById("TabloListe");
                var SonucBilgilendirme = "";
             for (var i = 1, row; row = table.rows[i]; i++)
             {
                 //satırları dönüyoruz 1 satır veri olduğu için veri satırını dönüyoruz
                 for (var j = 1, col; col = row.cells[j]; j++)
                 {
                     //kolonları dönüyoruz
                     if (col.querySelector('input') != null) {
                         var MiktarID = col.querySelector('input').getAttribute("id");
                         var Miktar = $("#Miktar_" + MiktarID.split("_")[1]).val();
                         Miktar = Miktar.toString().replace(",", ".");

                         var Aciklama = $("#Aciklama_" + MiktarID.split("_")[1]).val();
                         var SubeKodu = $("#Sube").val();
                         if (Miktar > 0) {
                             var formData = null;// new FormData(document.getElementById("Dosya_" + MiktarID.split("_")[1]));
                             var formData = new FormData();
                             //formData.append('id', MiktarID.split("_")[1]);
                             formData.append('id', col.querySelector('input').getAttribute("data-id"));
                             formData.append('SubeKodu', SubeKodu);
                             formData.append('miktar', Miktar);
                             formData.append('aciklama', Aciklama);
                             formData.append('Dosya', $('#Dosya_' + MiktarID.split("_")[1])[0].files[0]);

                             $.ajax({
                                 type: "POST",
                                 url: '/Satinalma/YKSatinalma/TalepKaydet',
                                 data: formData,
                                 dataType: "json",
                                 enctype: 'multipart/form-data',
                                 async: false,
                                 contentType: false,
                                 processData: false,
                                 //contentType: "application/json; charset=utf-8",
                                 //dataFilter: function (data) { return data; },
                                 success: function (data) {
                                     if (data.SonucKodu == "1") {
                                         if (SonucBilgilendirme.indexOf(data.Aciklama) < 0) {
                                             SonucBilgilendirme += data.Aciklama;
                                         }
                                         $("#Miktar_" + MiktarID.split("_")[1]).val("0");
                                         $("#Aciklama_" + MiktarID.split("_")[1]).val("");
                                         $("#Dosya_" + MiktarID.split("_")[1]).val("");
                                     } else {
                                         Swal.fire({
                                             position: "center",
                                             icon: "error",
                                             title: data.Aciklama,
                                             showConfirmButton: true,
                                             //timer: 3000
                                         });
                                         return;
                                     }
                                 },
                                 error: function (msg) {

                                     Swal.fire({
                                         position: "center",
                                         icon: "error",
                                         title: msg,
                                         showConfirmButton: false,
                                         timer: 1500
                                     });
                                     return;
                                 }
                             });
                         }

                     }
                 }
                }
                if (SonucBilgilendirme == "" || SonucBilgilendirme == null) {
                    SonucBilgilendirme = "Talepler başarıyla kaydedildi.";
                }
             Swal.fire({
                 position: "center",
                 icon: "success",
                 title: SonucBilgilendirme,
                 showConfirmButton: true,
                 //timer: 3000
             });
            $("#btnKaydet").val("Kaydet");
        }



        function SecimKategori1() {
            var Kategori1 = $("#Kategori1").val();
            var SecilenKategori2 = "@(ViewBag.Kategori2)";

            $.ajax({
                async: false,
                cache: false,
                type: "GET",
                url: "/Satinalma/YKSatinalma/JsonGetirKategori2",
                data: { "Kategori1": Kategori1 },
                success: function (data2) {

                    $('#Kategori2').empty();
                    $('#Kategori2')
                        .append($("<option></option>")
                            .attr("value", "")
                            .text("Kategori Seçimi"));
                    $.each(data2.Data, function (data3, key, value) {
                        $('#Kategori2')
                            .append($("<option " + (SecilenKategori2 == key.Isim ? "selected" : "")+"></option>")
                                .attr("value", key.Isim)
                                .text(key.Isim));
                    });
                    SecimKategori2();
                },
                error: function (data) {
                }
            });
        }

        function SecimKategori2() {
            var Kategori1 = $("#Kategori1").val();
            var Kategori2 = $("#Kategori2").val();
            var SecilenKategori3 = "@(ViewBag.Kategori3)";

            $.ajax({
                async: false,
                cache: false,
                type: "GET",
                url: "/Satinalma/YKSatinalma/JsonGetirKategori3",
                data: { "Kategori1": Kategori1, "Kategori2": Kategori2 },
                success: function (data2) {

                    $('#Kategori3').empty();
                    $('#Kategori3')
                        .append($("<option></option>")
                            .attr("value", "")
                            .text("Kategori Seçimi"));
                    $.each(data2.Data, function (data3, key, value) {
                        $('#Kategori3')
                            .append($("<option " + (SecilenKategori3 == key.Isim ? "selected" : "") +"></option>")
                                .attr("value", key.Isim)
                                .text(key.Isim));
                    });
                },
                error: function (data) {
                }
            });
        }

        SecimKategori1();
            SecimKategori2();


            // Class definition
            var KTDatatablesExample = function () {
                // Shared variables
                var table;
                var datatable;

                // Private functions
                var initDatatable = function () {
                    // Set date data order
                    const tableRows = table.querySelectorAll('tbody tr');

                    // Init datatable --- more info on datatables: https://datatables.net/manual/
                    datatable = $(table).DataTable({
                        "info": false,

                        'order': [],
                        paging: false,
                        columnDefs: [
                            {
                                targets: [0, 6],
                                className: 'noVis'
                            },
                        ]

                    });

                    datatable.on('columns-reordered', function (e, settings, details) {
                        KTMenu.createInstances();
                    });
                }

                // Hook export buttons
                var exportButtons = () => {
                    const documentTitle = 'TabloListe-' + moment(new Date()).format("DD-MM-YYYY");
                    var buttons = new $.fn.dataTable.Buttons(table, {
                        buttons: [
                            {
                                extend: 'copyHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            },
                            {
                                extend: 'excelHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            },
                            {
                                extend: 'csvHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            },
                            {
                                extend: 'pdfHtml5',
                                title: documentTitle,
                                exportOptions: {
                                    columns: ['th:not(.no-export)'],
                                }
                            }
                        ]
                    }).container().appendTo($('#kt_datatable_example_buttons'));

                    // Hook dropdown menu click event to datatable export buttons
                    const exportButtons = document.querySelectorAll('#kt_datatable_example_export_menu [data-kt-export]');
                    exportButtons.forEach(exportButton => {
                        exportButton.addEventListener('click', e => {
                            e.preventDefault();

                            // Get clicked export value
                            const exportValue = e.target.getAttribute('data-kt-export');
                            const target = document.querySelector('.dt-buttons .buttons-' + exportValue);

                            // Trigger click event on hidden datatable export buttons
                            target.click();
                        });
                    });
                }

                // Search Datatable --- official docs reference: https://datatables.net/reference/api/search()
                var handleSearchDatatable = () => {
                    const filterSearch = document.querySelector('[data-kt-filter="search"]');
                    filterSearch.addEventListener('keyup', function (e) {
                        datatable.search(e.target.value).draw();
                    });
                }

                // Public methods
                return {
                    init: function () {
                        table = document.querySelector('#TabloListe');

                        if (!table) {
                            return;
                        }

                        initDatatable();
                        exportButtons();
                        handleSearchDatatable();
                    }
                };
            }();

            // On document ready
            KTUtil.onDOMContentLoaded(function () {
                KTDatatablesExample.init();
            });
    </script>

}


                                    showConfirmButton: true,
                                    //timer: 3000
                                });
                                return;
                            }
                        },
                        error: function (msg) {
                            Swal.fire({
                                position: "center",
                                icon: "error",
                                title: msg,
                                showConfirmButton: false,
                                timer: 1500
                            });
                        }
                    });
                } else if (result.isDenied) {

                    var _data = {
                        "Grupla": "@Grupla",
                        "KayitID": id,
                        "StokKodu": stokkodu,
                        "SecilenCariID": cariid,

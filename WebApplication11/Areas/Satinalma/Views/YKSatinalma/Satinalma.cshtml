        function TabloAramaYapSatinalma(kolonsirasi, tabloismi) {

            var input, filter, table, tr, td;
            input = document.getElementById("AranacakKelime" + kolonsirasi);
            filter = input.value.toLowerCase();
            table = document.getElementById(tabloismi);
            tr = table.getElementsByTagName("tr");

            var toplam = 0;
            for (i = 0; i < tr.length; i++) {
                td = tr[i].getElementsByTagName("td")[kolonsirasi];
                if (td) {
                    if (td.innerHTML.toLowerCase().indexOf(filter) > -1) {
                        tr[i].style.display = "";
                        toplam++;
                    } else {
                        tr[i].style.display = "none";
                    }
                }

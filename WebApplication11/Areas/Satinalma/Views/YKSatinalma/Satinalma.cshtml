        function FiyatSec(id, stokkodu, cariid, fiyat) {
            if (id == "") {
                id = "0";
            }
            Swal.fire({
                title: "Fiyatı onaylanacak, emin misiniz? <br/> " + parseFloat(fiyat).toFixed(2),
                showDenyButton: true,
                showCancelButton: true,
                confirmButtonText: "Fiyatı Seç",
                denyButtonText: `FiyatSeçimini Kaldır`
            }).then((result) => {
                /* Read more about isConfirmed, isDenied below */
                if (result.isConfirmed) {

                    var _data = {
                        "Grupla": "@Grupla",
                        "KayitID": id,
                        "StokKodu": stokkodu,
                        "SecilenCariID": cariid,
                        "SecilenFiyat": fiyat.split(' ')[0],
                        "SecilenDovizBirimi": fiyat.split(' ')[1]
                    };
                    if (id == "0") {
                        id = "";
                    }
                    $.ajax({
                        url: '/Satinalma/YKSatinalma/SatinalmaFiyatSec',
                        data: _data,
                        //dataType: "json",
                        enctype: 'multipart/form-data',
                        async: false,
                        type: "POST",
                        //contentType: "application/json; charset=utf-8",
                        //dataFilter: function (data) { return data; },
                        success: function (data) {
                            if (data.SonucKodu == "1") {
                                var table = document.getElementById("TabloListe");

                                for (var i = 1, row; row = table.rows[i]; i++) {
                                    //satırları dönüyoruz 1 satır veri olduğu için veri satırını dönüyoruz
                                    for (var j = 1, col; col = row.cells[j]; j++) {
                                        if (row.cells[j].id.includes(stokkodu + id)) {
                                            $("#" + row.cells[j].id).css({ "backgroundColor": "white", "color": "black" });

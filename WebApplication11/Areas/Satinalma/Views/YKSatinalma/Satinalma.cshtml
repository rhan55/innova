                            if (data.SonucKodu == "1") {
                                var table = document.getElementById("TabloListe");

                                for (var i = 1, row; row = table.rows[i]; i++) {
                                    //satırları dönüyoruz 1 satır veri olduğu için veri satırını dönüyoruz
                                    for (var j = 1, col; col = row.cells[j]; j++) {
                                        if (row.cells[j].id.includes(stokkodu + id)) {
                                            $("#" + row.cells[j].id).css({ "backgroundColor": "white", "color": "black" });

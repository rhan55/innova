                            deger += "<td style='text-align:center;padding:1px;'>" + data.Data[i].Aciklama1 + "</td>";
                            deger += "<td style='text-align:center;padding:1px;'>" + data.Data[i].Tarih + "</td>";
                            deger += "<td style='text-align:center;padding:1px;'>" + data.Data[i].Kullanici + "</td>";
                            deger += "<td style='text-align:center;padding:1px;'><input type='button' class='btn btn-dancer' onclick='Reddet2(" + data.Data[i].ID + ");' value='Geriye Gönder' /></td>";
                            deger += "</tr>";
                            deger += "<tr>";
                            deger += "<td style='text-align:left;padding:1px;' colspan='7'>Talep Açıklaması : " + data.Data[i].Aciklama1 + "</td>";
                            deger += "<td style='text-align:center;padding:1px;' colspan='2'><strong>Son Alış Bilgileri</strong></td>";
                            deger += "</tr>";
                            deger += "<tr>";
                            deger += "<td style='text-align:left;padding:1px;color:red;' colspan='7'>Red Açıklaması : " + data.Data[i].Aciklama2 + "</td>";
                            deger += "<td style='text-align:center;padding:1px;' colspan='2'>" + data.Data[i].SonAlisCarisi + "</td>";
                            deger += "</tr>";
                            deger += "<tr>";
                            deger += "<td style='text-align:left;padding:1px;color:orange;' colspan='7'>Satınalma Açıklaması : " + data.Data[i].Aciklama3 + "</td>";
                            deger += "<td style='text-align:center;padding:1px;' colspan='2'>" + data.Data[i].SonAlisTarihi + " - " + data.Data[i].SonAlisSubesi + "</td>";
                            deger += "</tr>";
                            deger += "<tr>";
                            deger += "<td style='text-align:left;padding:1px;color:orange;' colspan='7'></td>";
                            deger += "<td style='text-align:center;padding:1px;' colspan='2'>" + data.Data[i].SonAlisFiyati + "</td>";

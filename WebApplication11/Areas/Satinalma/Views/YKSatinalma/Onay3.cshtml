                    // waitingDialog.hide();
                    if (data.SonucKodu == "1") {
                        $('#TabloDetay tbody tr').remove();
                        var deger = "";
                        for (var i = 0; i < data.Data.length; i++) {
                            deger += "<tr>";
                            deger += "<td style='text-align:center;padding:1px;'>" + data.Data[i].SubeKodu + "</td>";
                            deger += "<td style='text-align:center;padding:1px;'>" + data.Data[i].Kod + "</td>";
                            deger += "<td style='text-align:center;padding:1px;'>" + data.Data[i].Isim + "</td>";
                            deger += "<td style='text-align:center;padding:1px;'><input type='text' value='" + data.Data[i].Miktar + "' name='MiktarGuncelle_" + data.Data[i].ID + "' id='MiktarGuncelle_" + data.Data[i].ID + "' style='width:70px;' /><input type='button' value='Güncelle' onclick=\"MiktarGuncelle('" + data.Data[i].ID + "');\"  /></td>";

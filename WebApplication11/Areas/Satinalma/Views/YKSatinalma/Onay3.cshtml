                    });
                }
            });
        }
        function SecilenToplamHesapla() {
            var toplam = 0;
            var kolonsirasi = 0;
            var input, filter, table, tr, td;
            input = "";
            filter = input.toLowerCase();
            table = document.getElementById("TabloListe");
            tr = table.getElementsByTagName("tr");

            var toplam = 0;
            for (i = 1; i < tr.length; i++) {

                td = tr[i].getElementsByTagName("td")[kolonsirasi];
                var id = td.id.replace("OnaySecimi", "");
                var secimKontrol = document.querySelector('input[name="Durum' + id + '"]:checked');
                if (secimKontrol != null) {
                    if (secimKontrol.value == "Onay") {
                        toplam += parseFloat($("#Tutar_" + (i - 1)).val());
                    }
                }
            }

            $("#SecilenToplam").text(new Intl.NumberFormat().format(toplam.toFixed(2)));
        }



        function SecimKategori1() {
            var Kategori1 = $("#Kategori1").val();
            var SecilenKategori2 = "@(ViewBag.Kategori2)";

            $.ajax({
                async: false,
                cache: false,
                type: "GET",
                url: "/Satinalma/YKSatinalma/JsonGetirKategori2",
                data: { "Kategori1": Kategori1 },
                success: function (data2) {

                    $('#Kategori2').empty();
                    $('#Kategori2')
                        .append($("<option></option>")
                            .attr("value", "")
                            .text("Kategori Seçimi"));
                    $.each(data2.Data, function (data3, key, value) {
                        $('#Kategori2')
                            .append($("<option " + (SecilenKategori2 == key.Isim ? "selected" : "")+"></option>")
                                .attr("value", key.Isim)
                                .text(key.Isim));
                    });
                    SecimKategori2();
                },
                error: function (data) {
                }
            });
        }


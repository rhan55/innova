@using System.Data

@{
    ViewBag.Title = "Innova_Uretim_Okutma";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string KullaniciID = Request.Cookies["KullaniciID"].Value;

    System.Data.DataTable dt = ViewBag.dtDetay as System.Data.DataTable;
}
<html>
<head>

    <title>@ViewBag.Title</title>



</head>
<body>
    <div style="padding:20px;text-align:center;">

        <form action="@Url.Content("~/Depo/NetsisDepo/Innova_Uretim_Okutma_Bilgisi")" method="post">

            <table border="0" style="width:100%;">
                <tr>
                    <td width="50%"> 
                        <label>Okutma No</label>
                    </td>
                        <td width="50%">
                            <input type="text" name="Okutma_Fisno" value="@ViewBag.Belge_Fis_Numarasi" class="form-control" style="font-size:50px;width:100%;height:50px;" />
                        </td>
                  
                </tr>
                <tr>
                    <td width="50%">
                        <label>Okutulacak Barkod</label>
                    </td>
                    <td>
                        <input type="text" name="Okutma_Barkod" value="" class="form-control" style="font-size:50px;width:100%;height:50px;" />
                    </td>
                </tr>
                <tr>
                    <td>
                        <a href="@Url.Content("~/Depo/NetsisDepo/Innova_Uretim_Okutma/?Belge_Fis_Numarasi=")">
                            Yeni Okutma
                        </a>
                    </td>
                    <td>
                        <input type="submit" name="name" value="Kaydet" class="btn btn-block btn-default" />
                    </td>
                </tr>
                
            </table>
            
            
            <br /><br />
                  <table border="0" style="width:100%;">
                      <tr>
                          <td>
                             BARKOD
                          </td>
                          <td>
                              ADET
                          </td>
                          <td>
                              KG
                          </td>
                      </tr>
                      @if (dt != null)
                      {

                          foreach (DataRow dr in dt.Rows)
                          {
                          <tr>
                              <td>
                                  @dr["BARKOD"]
                              </td>
                              <td>
                                  @dr["ADET"]
                              </td>
                              <td>
                                  @dr["KG"]
                              </td>
                          </tr>
                          }
                      }
                      </table>


        </form>
        <div style="clear:both;"></div>
        @if (((System.Data.DataTable)ViewBag.Detay) != null)
        {
            if (ViewBag.Baslangic == null)
            {
            <form action="@Url.Content("~/Depo/NetsisDepo/Innova_IstasyonAsama")" method="post" style="width:100%;height:100px;text-align:center;">
                <input type="hidden" name="IslemTipi" id="IslemTipi" value="104" />
                <input type="hidden" name="Barkod" id="Barkod" value="@ViewBag.Barkod" />
                <input type="submit" name="name" value="Başlat" class="btn btn-block btn-success" style="height:100px;font-size:40px;" />
            </form>
            }
            else
            {
            <form action="@Url.Content("~/Depo/NetsisDepo/Innova_IstasyonAsama")" method="post" style="width: 100%; height: 100px;text-align: center; ">
                <input type="hidden" name="IslemTipi" id="IslemTipi" value="106" />
                <input type="hidden" name="Barkod" id="Barkod" value="@ViewBag.Barkod" />
                <input type="submit" name="name" value="Bitiş" class="btn btn-block btn-danger"  style="height: 100px; font-size: 40px;"/>

            </form>
            }
        }


        <div style="clear:both;"></div>
        <hr />

        @if (ViewBag.Detay != null)
        {
            <table class="table" border="1">
                <tr>
                    <th><strong>Makine ID</strong></th>
                    <th><strong>Makine Adı</strong></th>
                    <th><strong>Başlangış</strong></th>
                    <th><strong>Bitiş</strong></th>
                </tr>
                @foreach (System.Data.DataRow item in ((System.Data.DataTable)ViewBag.Detay).Rows)
                {
                    <tr>
                        <th>@item["MAKINE_ID"]</th>
                        <th>@item["MAKINE_ADI"]</th>
                        <th>@item["FIS_BASLANGIC"]</th>
                        <th>@item["FIS_BITIS"]</th>
                    </tr>
                }
            </table>
        }
    </div>

</body>
</html>
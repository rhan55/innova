@using System.Data
@using YKPortal.Models.Dto
@model DataSet
@{
    ViewBag.Title = "Depo Otomasyonu";
    Layout = "~/Views/Shared/_Layout.cshtml";

    string KullaniciID = Request.Cookies["KullaniciID"].Value;
    DataTable dtMenuler = ViewBag.dtMenuler as DataTable;

}


<div class="container-fluid p-4 m-0">
    <div class="row">

        <div class="col-lg-12">
            <!--begin::Post-->
            @foreach (DataRow dr in dtMenuler.Rows)
            {
                <a href="@dr["url"]" class="tum-kenar-oval" style="width:49%;margin:1px;padding:0px;height:150px;font-size:17px;float:left;text-align:center;vertical-align:middle; @dr["icon"]">
                    <img src="@dr["Resim"]" style="height:100px;" /><br />
                    <strong>@dr["Menu"]</strong>
                </a>
            }
            <!--end::Post-->

        </div>
    </div>
</div>

<style>
    .tum-kenar-oval {
        border: 2px solid #a1a1a1;
        padding: 10px 40px;
        background: green;
        width: 200px;
        height: 100px;
        border-radius: 25px;
        color: white;
        margin: 20px;
        float: left;
    }
</style>

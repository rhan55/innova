
@{
    ViewBag.Title = "GenelBilgiler";
    Layout = "~/Areas/E/Views/Shared/_Layout.cshtml";
}



<div class="container my-5">
    <div class="">
        <form id="uyelikFormu" action="@Url.Action("GenelBilgiler","Bilgiler",new { Area = "E" })" class="mb-0" method="post">
            <input type="hidden" name="ID" value="" />
            <input type="hidden" name="KullaniciID" value="" />
            <h2>GenelBilgiler</h2>
            <div class="row">
                <div class="col-lg-6 mt-4">
                    <label class="text-dark" for="ETicaretTelefon">
                        E-Ticaret Telefon
                        <span class="required">*</span>
                    </label>
                    <input type="text" class="form-input p-3 form-wide mb-2" id="ETicaretTelefon" name="ETicaretTelefon" value="" required="">
                </div>

                <div class="col-lg-6 mt-4">
                    <label class="text-dark" for="ETicaretEmail">
                        ETicaret Email
                        <span class="required">*</span>
                    </label>
                    <input type="text" class="form-input p-3 form-wide mb-2" id="ETicaretEmail" name="ETicaretEmail" required="">
                </div>

            </div>
            <div class="row">

                <div class="col-lg-6 mt-4 mb-2">
                    <label class="text-dark" for="ETicaretLogo">
                        ETicaretLogo
                        <span class="required">*</span>
                    </label>
                    <input type="text" class="form-input form-wide p-3" name="ETicaretLogo" id="ETicaretLogo">
                    <div data-error="ETicaretLogo"></div>
                </div>
                <div class="col-lg-6 mt-4">
                    <label class="text-dark" for="ETicaretFirmaAdi">
                        ETicaretFirmaAdi
                        <span class="required">*</span>
                    </label>
                    <input type="text" class="form-input text-dark form-wide mb-2 p-3" id="ETicaretFirmaAdi" name="ETicaretFirmaAdi" required="">
                </div>
            </div>



            <div class="d-flex mt-2">
                <div>
                    <button type="submit" id="KaydetButonu" class="btn-lg btn btn-primary font-weight-bold py-2 btn-block" style="height:40px;">
                        Kaydet
                    </button>
                </div>
                <div class="">
                    <button type="button" onclick="history.back()" class="btn btn-light btn-block btn-md">
                        Geri
                    </button>
                </div>

            </div>

        </form>
    </div>

</div>






@section Styles {

}
<script>var hostUrl = "~/Tema/ETicaret";</script>
@section scripts {


    <script>



    </script>

}


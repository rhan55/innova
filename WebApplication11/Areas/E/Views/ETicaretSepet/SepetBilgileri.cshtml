@using System.Data
@using System.Globalization
@using YKPortal.Models.Dto
@model System.Data.DataTable
@{
    ViewBag.Title = "SepetBilgileri";
    Layout = "~/Areas/E/Views/Shared/_Layout.cshtml";

    var sepetBilgileri = ViewBag.SepetBilgileri as List<YKPortal.Areas.E.Models.Dto.ETicaretSepetDto.ETicaretSepetListeSonucDto>;
    if (sepetBilgileri == null)
    {
        sepetBilgileri = new List<YKPortal.Areas.E.Models.Dto.ETicaretSepetDto.ETicaretSepetListeSonucDto>();
    }

    decimal araToplam = 0;

    foreach (var sepetUrunu in sepetBilgileri)
    {
        araToplam = araToplam + (sepetUrunu.Miktar * sepetUrunu.Fiyat);
    }

    var kullanici =new YKPortal.Areas.E.Models.Dto.ETicaretKullaniciDto.KullaniciEkleDto { };

    if (ViewBag.Kullanici != null) {
        kullanici = ViewBag.Kullanici as YKPortal.Areas.E.Models.Dto.ETicaretKullaniciDto.KullaniciEkleDto;
    }
}


<div class="page-wrapper">
    <main class="main">
        <div class="container">
            <div class="row mt-4">
                <div class="col-lg-8">
                    <div class="cart-table-container">
                        <table class="table table-cart">
                            <thead>
                                <tr>
                                    <th class="thumbnail-col">Resim</th>
                                    <th class="product-col">İsim</th>
                                    <th class="qty-col">Adet</th>
                                    <th class="text-right">Fiyat</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var stok in sepetBilgileri)
                                {
                                    <tr class="product-row">
                                        <td>
                                            <figure class="product-image-container">
                                                <a href="product.html" class="product-image">
                                                    <img src="/Uploads/Dosya/@stok.Resim1" alt="product">
                                                </a>
                                                <a href="#" class="btn-remove icon-cancel" title="Remove Product"></a>
                                            </figure>
                                        </td>
                                        <td class="product-col">
                                            <h5 class="product-title">
                                                <a style="max-width:400px;" href="product.html">@stok.Isim</a>
                                            </h5>
                                        </td>
                                        <td>
                                            <div class="product-single-qty">
                                                <input class="horizontal-quantity form-control" type="text">
                                            </div><!-- End .product-single-qty -->
                                        </td>
                                        <td class="text-right"><span class="subtotal-price">@stok.Fiyat</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div><!-- End .cart-table-container -->
                </div><!-- End .col-lg-8 -->

                <div class="col-lg-4">
                    <div class="cart-summary">
                        <h3>Sepet Toplamı</h3>

                        <table class="table table-totals">
                            <tbody>
                                <tr>
                                    <td>Ara toplam</td>
                                    <td>@(araToplam.ToString("C", new CultureInfo("tr-TR")))</td>
                                </tr>

                                <tr>
                                    <td colspan="2" class="text-left">
                                        <h4>Kargo</h4>

                                        <form class="mt-2" action="KullaniciAdresi">


                                            <div class="form-group form-group-sm">
                                                <label for="Ulke" class="text-dark form-label m-0">Ülke</label>
                                                <div class="select-custom">
                                                    <select class="form-control form-control-sm" data-control="select2" name="Ulke" id="Ulke" required
                                                            aria-label="Floating label select example">
                                                        <option value="">Lütfen Seçim Yapınız</option>
                                                        @foreach (GrupKoduDto ulke in ViewBag.Ulkeler)
                                                        {
                                                            <option value="@ulke.ID" @(kullanici.Ulke == ulke.ID ? "selected" : "")>@ulke.Deger</option>
                                                        }
                                                    </select>
                                                </div><!-- End .select-custom -->
                                            </div><!-- End .form-group -->

                                            <div class="form-group form-group-sm">
                                                <label for="Il" class="text-dark form-label  m-0 p-1">İl</label>
                                                <div class="select-custom">
                                                    <select class="form-control form-control-sm" name="Il" data-control="select2" id="Il" required
                                                            aria-label="Floating label select example">
                                                        <option value="">Lütfen Seçim Yapınız</option>
                                                        @foreach (GrupKoduDto il in ViewBag.Iller)
                                                        {
                                                            <option value="@il.ID" @(kullanici.Il == il.ID ? "selected" : "")>@il.Deger</option>
                                                        }
                                                    </select>
                                                </div><!-- End .select-custom -->
                                            </div><!-- End .form-group -->
                                            <div class="row">
                                                <div class="col-lg-12">
                                                    <label class="text-dark form-label m-0 py-1" for="Adres">
                                                        Adres
                                                    </label>
                                                    <textarea class="form-control form-control-sm" name="Adres" id="Adres" rows="4" placeholder="Adresinizi girin...">@(kullanici.Adres)</textarea>
                                                </div>
                                            </div>
                                            <div class="form-group form-group-sm">
                                                <input type="text" class="form-control form-control-sm"
                                                       placeholder="M">
                                            </div><!-- End .form-group -->

                                            <div class="form-group form-group-sm">
                                                <input type="text" class="form-control form-control-sm"
                                                       placeholder="ZIP">
                                            </div><!-- End .form-group -->

                                            <button type="submit" class="btn btn-shop btn-update-total">
                                                Toplamı Güncelle
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            </tbody>

                            <tfoot>
                                <tr>
                                    <td>Ödemeye Geç</td>
                                    <td>$17.90</td>
                                </tr>
                            </tfoot>
                        </table>

                        <div class="checkout-methods">
                            <a href="cart.html" class="btn btn-block btn-dark">
                                Proceed to Checkout
                                <i class="fa fa-arrow-right"></i>
                            </a>
                        </div>
                    </div><!-- End .cart-summary -->
                </div><!-- End .col-lg-4 -->
            </div><!-- End .row -->
        </div><!-- End .container -->

        <div class="mb-6"></div><!-- margin -->
    </main><!-- End .main -->

</div><!-- End .page-wrapper -->


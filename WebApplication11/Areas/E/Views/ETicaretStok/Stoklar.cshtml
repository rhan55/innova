@section Scripts {
    <script>
        $(function () {
            const sepeteEkleButon = $('#SepeteEkle');
            const urunSayisiInput = $('#UrunSayisi');

            sepeteEkleButon.on('click', function () {
                var data = {
                    Miktar: parseInt(urunSayisiInput.val()),
                    StokId: $('[data-stokId]').attr('data-stokId')
                }

                $.ajax({
                    type: "POST",
                    url: '/E/ETicaretSepet/SepeteEkle',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify(data),
                    success: function (data) {
                        console.log(data);
                    },
                    error: function (msg) {
                        console.log("HATA! ", msg);
                    }
                });
            });
        })
        $(document).ready(function () {
            $("#price-slider").slider({
                range: true,
                min: 0,
                max: 1000,
                values: [0, 1000],
                slide: function (event, ui) {
                    $("#filter-price-range").text(ui.values[0] + " - " + ui.values[1] + " TL");
                    $("#price-min").val(ui.values[0]);
                    $("#price-max").val(ui.values[1]);
                }
            });
            $("#filter-price-range").text($("#price-slider").slider("values", 0) + " - " + $("#price-slider").slider("values", 1) + " TL");
        });

        $(function () {
            $(document).on('click', '[data-click]', function () {
                if (!!$(this).data('click')) {
                    window.open($(this).data('click'), '_self');
                }
               
            });
        });
    </script>
    <div id="price-slider"></div>
}
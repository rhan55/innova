
@{
    ViewBag.Title = "Stoklar";
    Layout = "~/Areas/E/Views/Shared/_Layout.cshtml";

    var Slaytlar = new List<YKPortal.Areas.E.Models.Dto.ETicaretSlaytDto>();

    if (ViewBag.Slaytlar != null)
    {
        Slaytlar = ViewBag.Slaytlar as List<YKPortal.Areas.E.Models.Dto.ETicaretSlaytDto>;
    }
}


<main class="main">

    <div class="home-slider slide-animate owl-carousel owl-theme show-nav-hover nav-big mb-2 text-uppercase" data-owl-options="{
	'loop': false
}">

        @foreach (var slayt in Slaytlar)
        {
            <div class="home-slide home-slide1 banner" data-click="@slayt.Link">

                <img class="slide-bg" src="@slayt.ResimYolu" alt="slider image" style="width:100%; height:400px; object-fit:cover;">
                <div class="container d-flex align-items-center">
                    <div class="banner-layer appear-animate" data-animation-name="fadeInUpShorter">
                        <h4 class="text-transform-none m-b-3">@Html.Raw(HttpUtility.HtmlDecode(slayt.Text))</h4>
                        <h2 class="text-transform-none mb-0">Summer Sale</h2>
                        <h3 class="m-b-3">70% Off</h3>
                        <h5 class="d-inline-block mb-0">
                            <span>Starting At</span>
                            <b class="coupon-sale-text text-white bg-secondary align-middle">
                                <sup>$</sup><em class="align-text-top">199</em><sup>99</sup>
                            </b>
                        </h5>
                        <a href="category.html" class="btn btn-dark btn-lg">Shop Now!</a>
                    </div>
                    <!-- End .banner-layer -->
                </div>
            </div>
            <!-- End .home-slide -->
        }
    </div>
    <!-- End .home-slider -->

    <div class="container-fluid">


        <div class="row">
            <div class="col-lg-10 main-content">
                <nav class="toolbox sticky-header" data-sticky-options="{'mobile': true}">
                    <div class="toolbox-right">
                        <div class="toolbox-item toolbox-show">
                            <label>Show:</label>

                            <div class="select-custom">
                                <select name="count" class="form-control">
                                    <option value="12">12</option>
                                    <option value="24">24</option>
                                    <option value="36">36</option>
                                </select>
                            </div>
                            <!-- End .select-custom -->
                        </div>
                        <!-- End .toolbox-item -->

                        <div class="toolbox-item layout-modes">
                            <a href="category.html" class="layout-btn btn-grid active" title="Grid">
                                <i class="icon-mode-grid"></i>
                            </a>
                            <a href="category-list.html" class="layout-btn btn-list" title="List">
                                <i class="icon-mode-list"></i>
                            </a>
                        </div>
                        <!-- End .layout-modes -->
                    </div>
                    <!-- End .toolbox-right -->
                </nav>

                <div class="row">

                    @foreach (YKPortal.Areas.E.Models.Dto.ETicaretStokDto.ETicaretStokSonucDto stokSonucDto in ViewBag.Stoklar)
                    {
                        <div class="col-12 col-sm-3" style="">
                            <div class="product-default">
                                <figure>
                                    <a href="/E/ETicaretStok/StokDetay?StokID=@stokSonucDto.StokID">
                                        <img src="/Uploads/Dosyalar/@stokSonucDto.Resim1" class="ov-brand-image" alt="@stokSonucDto.Isim" />
                                        <img class="ov-brand-image" src="/Uploads/Dosyalar/@stokSonucDto.Resim1" data-zoom-image="/Uploads/Dosyalar/@stokSonucDto.Resim1" alt="@stokSonucDto.Isim" />
                                    </a>
                                </figure>

                                <div class="product-details">
                                    <div class="category-wrap">
                                        <div class="category-list">
                                            <div>
                                                @(
                                                   string.IsNullOrEmpty(stokSonucDto.Kategoriler.Kategori1)
                                                   ? "Kategori 1 Bulunamadı"
                                                   : stokSonucDto.Kategoriler.Kategori1
                                                )
                                            </div>
                                        </div>
                                    </div>

                                    <h3 class="product-title">
                                        <a href="/E/ETicaretStok/StokDetay?StokID=@stokSonucDto.StokID">
                                            @stokSonucDto.Isim
                                        </a>
                                    </h3>

                                    <div class="ratings-container">
                                        <div class="product-ratings">
                                            <span class="ratings" style="width:100%"></span>
                                            <!-- End .ratings -->
                                            <span class="tooltiptext tooltip-top"></span>
                                        </div>
                                        <!-- End .product-ratings -->
                                    </div>
                                    <!-- End .product-container -->

                                    <div class="price-box">
                                        <span class="product-price">@stokSonucDto.Fiyat</span>
                                    </div>
                                    <!-- End .price-box -->

                                    <div class="product-action">
                                        <a href="wishlist.html" class="btn-icon-wish" title="wishlist">
                                            <i class="icon-heart"></i>
                                        </a>
                                        <div class="product-single-qty">
                                            <input class="horizontal-quantity form-control" type="text" id="UrunSayisi" value="1" data-input="quantity">
                                        </div><!-- End .product-single-qty -->
                                        <button id="SepeteEkle" href="javascript:;" class="btn-icon btn-add-cart" data-click="SepeteEkle" data-id="@stokSonucDto.StokID">
                                            <span>
                                                <i class="fa fa-arrow-right"></i>
                                                SEPETE EKLE
                                            </span>
                                        </button>

                                    </div>

                                </div>
                                <!-- End .product-details -->
                            </div>
                        </div>
                    }

                </div>
                <!-- End .row -->

                <nav class="toolbox toolbox-pagination">
                    <div class="toolbox-item toolbox-show">
                        <label>Show:</label>

                        <div class="select-custom">
                            <select name="count" class="form-control">
                                <option value="12">12</option>
                                <option value="24">24</option>
                                <option value="36">36</option>
                            </select>
                        </div>
                        <!-- End .select-custom -->
                    </div>
                    <!-- End .toolbox-item -->


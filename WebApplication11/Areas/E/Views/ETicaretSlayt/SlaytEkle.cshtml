
@{
    ViewBag.Title = "SlaytEkle";
    Layout = "~/Areas/E/Views/Shared/_Layout.cshtml";
}

<div class="container">
    <h1>Slayt Ekle</h1>
    <form action="/E/ETicaretSlayt/SlaytEkle" method="post">
        <input type="hidden" name="SlaytID" value="@Model?.SlaytID" />

        <div class="col-lg-12">
            <label for="ResimYolu">Resim Yolu:</label>
            <input type="text" id="ResimYolu" name="ResimYolu" value="@Model?.ResimYolu" class="form-control" />
        </div>

        <div class="col-lg-12">
            <label for="Link">Link:</label>
            <input type="text" id="Link" name="Link" value="@Model?.Link" class="form-control" />
        </div>
        <div class="col-lg-12">
            <label for="Text">Metin:</label>
            <input type="text" id="Text" name="Text" value="@Model?.Text" class="form-control" />
        </div>
        <div class="col-lg-12">
            <label for="Aktif">Aktif:</label>
            <input type="checkbox" id="Aktif" name="Aktif" @(Model != null && Model.Aktif ? "checked" : "") />
        </div>
            <button type="submit" class="form-button btn btn-dark btn-ellipse btn-sm mt-2">Kaydet</button>
    </form>
</div>
   
    <script>
        function sweetalert(message = "", type = "success") {
            Swal.fire({
                text: message,
                icon: type,
                buttonsStyling: false,
                confirmButtonText: "Anladım!",
                customClass: {
                    confirmButton: "btn btn-primary"
                }
            });
        }

        $(function () {


            const menuSearch = function () {
                const searchInput = document.getElementById('MobileNavsearchInput');
                const menuItems = document.querySelectorAll('#menuContainer a'); // Tüm menü bağlantılarını seç

                var menuTemplate = (links) => `
                                    <ul class="mobile-menu">
                                        ${links.map(link => '<li><a href="' + link.href + '">' + link.content + '</a></li>')}
                                    </ul>
                                `;

                searchInput.addEventListener('keyup', function () {
                    const searchTerm = searchInput.value.toLowerCase();
                    const links = [];
                    if (searchTerm.length > 0) {
                        menuItems.forEach(item => {
                            const text = item.textContent.toLowerCase(); // Menüdeki metni küçük harfe çevir

                            if ($(item).attr('href') != "#") {
                                if (text.includes(searchTerm)) {
                                    links.push({
                                        href: $(item).attr('href'),
                                        content: item.textContent
                                    });
                                }
                            }
                        });

                        if (links.length > 0) {
                            var template = menuTemplate(links);
                            $('.search-area').html(template);

                            $('#menuContainer > .mobile-menu').css('display', 'none');
                        }
                    } else {
                        $('.search-area').html('');
                        $('#menuContainer > .mobile-menu').css('display', 'block');
                    }
                });
                return {}
            }

            menuSearch();

            var searchQuery = $('input#searchQuery');
            var searchCategory = $('select#cat');
            var uriParse = window.location.href.split("?");

            if (uriParse.length > 1) {
                var parameters = Object.fromEntries((new URLSearchParams(uriParse[1])).entries());

                if (Object.keys(parameters).filter(e => e == "aranacakKelime").length > 0) {
                    searchQuery.val(parameters["aranacakKelime"]);
                }

                if (Object.keys(parameters).filter(e => e == "cat").length > 0) {
                    searchCategory.find('option').each(function () {
                        if ($(this).val() == parameters["cat"]) {
                            $(this).attr("selected", true);
                        }
                    })
                }
            }

        });


        const sepeteEkleButonlar = $('[data-click="SepeteEkle"]').each(function () {
            console.log(this);
            $(this).on('click', function (e) {
                e.preventDefault();
                var data = {
                    Miktar: parseInt($(this).parent().find('[data-input="quantity"]').val()),
                    StokId: $(this).attr('data-id')
                }

                $.ajax({
                    type: "POST",
                    url: '/E/ETicaretSepet/SepeteEkle',
                    contentType: "application/json; charset=utf-8",
                    data: JSON.stringify(data),
                    success: function (data) {
                        console.log(data);
                    },
                    error: function (msg) {
                        console.log("HATA! ", msg);
                    }
                });
            })
        });


  //SIGNAL R-START

        function bildirimHubBaglantisi() {
            console.log($.connection.eTicaretBildirimHub);
            const bildirimHub = $.connection.eTicaretBildirimHub;

            bildirimHub.client.receiveNotification = function (count) {
                let counter = parseInt($('[data-id="SepetBildirimi"]').html());

                counter = counter + parseInt(count);
                $('[data-id="SepetBildirimi"]').html(counter)
             };

             const hubOptions = [];

            @if (tarayici == Tarayici.Firefox)
            {
                @Html.Raw("hubOptions.push('webSockets', 'serverSentEvents');"); // Firefox için
            }
            else
            {
                @Html.Raw("hubOptions.push('webSockets','serverSentEvents', 'longPolling');"); // Diğer tarayıcılar için
            }



            $.connection.hub.start({ transport: hubOptions, connectionTimeout: 20000 }).done(function () {
                $('[data-click="SepeteEkle"]').on("click", function () {
                    const count = $(this).parent().find('#UrunSayisi').val();
                    $.connection.eTicaretBildirimHub.server.bildirimGonder(count).done(function () {

                    })
                });
            }).fail(function (error) {
                console.log('Could not connect: ' + error);
            });

        }

        $(function () {
            bildirimHubBaglantisi();
        });

        //SIGNAL R-END
    </script>

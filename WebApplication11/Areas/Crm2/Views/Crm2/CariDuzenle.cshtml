@using System.Data
@model System.Data.DataTable
@{
    Layout = "~/Views/Shared/_LayoutSade.cshtml";
    string KullaniciAdi = HttpUtility.UrlDecode(Request.Cookies["KullaniciAdi"].Value);

    DataTable dtProjeTipi = ViewBag.dtProjeTipi as DataTable;
    DataTable dtGorevler = ViewBag.dtGorevler as DataTable;
    DataTable dtUlasimSekli = ViewBag.dtUlasimSekli as DataTable;
    DataTable dtIl = ViewBag.dtIl as DataTable;



}

<div style="width:100%;font-size:15px;">
    <input type="hidden" name="ID" id="ID" value="@Model.Rows[0]["ID"]" class="form-control" required />
    <table style="width:100%;">
        <tr>
            <td><strong>Bayi Adı</strong></td>
        </tr>
        <tr>
            <td><input type="text" name="Bayi" id="Bayi" value="@Model.Rows[0]["Bayi"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Tarih</td>
        </tr>
        <tr>
            <td><input type="date" name="Tarih" id="Tarih" value="@Convert.ToDateTime(Model.Rows[0]["Tarih"]).ToString("yyyy-MM-dd")" required class="form-control" /></td>
        </tr>
        <tr>
            <td>Proje Tipi</td>
        </tr>
        <tr>
            <td>
                <select class="form-control" name="ProjeTipi" id="ProjeTipi" required>
                    <option value="">Seçim yapınız...</option>
                    @foreach (DataRow satir in dtProjeTipi.Rows)
                    {
                        <option value="@satir["ID"]" @(Convert.ToString(Model.Rows[0]["ProjeTipi"]) == Convert.ToString(satir["ID"]) ? "selected" : "")>@satir["Deger"]</option>
                    }
                </select>
            </td>
        </tr>
        <tr>
            <td>Blok Sayısı</td>
        </tr>
        <tr>
            <td><input type="text" name="BlokSayisi" id="BlokSayisi" value="@Model.Rows[0]["BlokSayisi"]" class="form-control" /></td>
        </tr>
        <tr>
            <td>Miktar</td>
        </tr>
        <tr>
            <td><input type="number" name="Miktar" id="Miktar" value="@Model.Rows[0]["Miktar"]" class="form-control" /></td>
        </tr>
        <tr>
            <td>Ünvan</td>
        </tr>
        <tr>
            <td><input type="text" name="Unvan" id="Unvan" value="@Model.Rows[0]["Unvan"]" class="form-control" /></td>
        </tr>
        <tr>
            <td>Adı</td>
        </tr>
        <tr>
            <td><input type="text" name="Ad" id="Ad" value="@Model.Rows[0]["Ad"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Soyadı</td>
        </tr>
        <tr>
            <td><input type="text" name="Soyad" id="Soyad" value="@Model.Rows[0]["Soyad"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Telefonu 1</td>
        </tr>
        <tr>
            <td><input type="text" name="Telefon1" id="Telefon1" value="@Model.Rows[0]["Telefon1"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Telefonu 2</td>
        </tr>
        <tr>
            <td><input type="text" name="Telefon2" id="Telefon2" value="@Model.Rows[0]["Telefon2"]" class="form-control" /></td>
        </tr>
        <tr>
            <td>Görevi</td>
        </tr>
        <tr>
            <td>
                <select class="form-control" name="Gorev" id="Gorev" required>
                    <option value="">Seçim yapınız...</option>
                    @foreach (DataRow satir in dtGorevler.Rows)
                    {
                        <option value="@satir["ID"]" @(Convert.ToString(Model.Rows[0]["Gorev"]) == Convert.ToString(satir["ID"]) ? "selected" : "")>@satir["Deger"]</option>
                    }
                </select>
            </td>
        </tr>
        <tr>
            <td>Ulaşma Şekli</td>
        </tr>
        <tr>
            <td>
                <select class="form-control" name="UlasimSekli" id="UlasimSekli" required>
                    <option value="">Seçim yapınız...</option>
                    @foreach (DataRow satir in dtUlasimSekli.Rows)
                    {
                        <option value="@satir["ID"]" @(Convert.ToString(Model.Rows[0]["UlasimSekli"]) == Convert.ToString(satir["ID"]) ? "selected" : "")>@satir["Deger"]</option>
                    }
                </select>
            </td>
        </tr>
        <tr>
            <td>Projenin Adı</td>
        </tr>
        <tr>
            <td><input type="text" name="ProjeAdi" id="ProjeAdi" value="@Model.Rows[0]["ProjeAdi"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>İl</td>
        </tr>
        <tr>
            <td>
                <select class="form-control" name="Il" id="Il" required>
                    @foreach (DataRow satir in dtIl.Rows)
                    {
                        <option value="@satir["ID"]" @( (Convert.ToString(Model.Rows[0]["Il"]) == Convert.ToString(satir["ID"])) ? "selected" : "")>@satir["Deger"]</option>
                    }
                </select>
            </td>
        </tr>
        <tr>
            <td>İlçe</td>
        </tr>
        <tr>
            <td><input type="text" name="Ilce" id="Ilce" value="@Model.Rows[0]["Ilce"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Mahallesi</td>
        </tr>
        <tr>
            <td><input type="text" name="Muhalle" id="Mahalle" value="@Model.Rows[0]["Mahalle"]" class="form-control" /></td>
        </tr>
        <tr>
            <td>Ada</td>
        </tr>
        <tr>
            <td><input type="text" name="Ada" id="Ada" value="@Model.Rows[0]["Ada"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Parsel</td>
        </tr>
        <tr>
            <td><input type="text" name="Parsel" id="Parsel" value="@Model.Rows[0]["Parsel"]" class="form-control" required /></td>
        </tr>
        <tr>
            <td>Portal Numarası</td>
        </tr>
        <tr>
            <td><input type="text" name="PortalNumarasi" id="PortalNumarasi" value="@Model.Rows[0]["PortalNumarasi"]" class="form-control" /></td>
        </tr>
        <tr>
            <td>Fotoğraf</td>
        </tr>
        <tr>
            <td><input type="file" name="Resim" id="Resim" value="" class="form-control" /></td>
        </tr>
        <tr>
            <td>Sonuç Tarihi</td>
        </tr>
        <tr>
            <td>
                @if (Model.Rows[0]["SonucTarihi"] == DBNull.Value)
                {
                    <input type="date" name="SonucTarihi" id="SonucTarihi" value="" class="form-control" />
                }
                else
                {
                    <input type="date" name="SonucTarihi" id="SonucTarihi" value="@Convert.ToDateTime(Model.Rows[0]["SonucTarihi"]).ToString("yyyy-MM-dd")" class="form-control" />
                }

            </td>
        </tr>
        <tr>
            <td>
                <a href="@Url.Action("AnaSayfa","Crm2", new { Area = "Crm2" })" class="btn btn-danger">Ana Sayfa</a>
                <input type="button" name="name" value="Güncelle" class="btn btn-success" onclick="Kaydet();" />
            </td>
        </tr>
    </table>

</div>


@section Styles {




}
@section scripts {

    <script>
        function Kaydet() {

            if ($("#ProjeTipi").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Proje tipi seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            if ($("#Gorev").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Görev seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            if ($("#UlasimSekli").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Ulaşım şekli seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            if ($("#Il").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "İl seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }

            if ($("#Ada").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Ada bilgisi girilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            if ($("#Parsel").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Parsel bilgisi seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }

            if ($("#Bayi").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Bayi bilgisi seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }

            if ($("#Ad").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Ad bilgisi seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            if ($("#Soyad").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Soyad bilgisi seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            if ($("#Telefon1").val() == "") {
                Swal.fire({
                    position: "center",
                    icon: "error",
                    title: "Telefon1 bilgisi seçilmelidir.",
                    showConfirmButton: true,
                    //timer: 3000
                });
                return;
            }
            var formData = new FormData();
            formData.append('ID', $("#ID").val());
            formData.append('Bayi', $("#Bayi").val());
            formData.append('Tarih', $("#Tarih").val());
            formData.append('ProjeTipi', $("#ProjeTipi").val());
            formData.append('BlokSayisi', $("#BlokSayisi").val());
            formData.append('Miktar', $("#Miktar").val());
            formData.append('Unvan', $("#Unvan").val());
            formData.append('Ad', $("#Ad").val());
            formData.append('Soyad', $("#Soyad").val());
            formData.append('Telefon1', $("#Telefon1").val());
            formData.append('Telefon2', $("#Telefon2").val());
            formData.append('Gorev', $("#Gorev").val());
            formData.append('UlasimSekli', $("#UlasimSekli").val());
            formData.append('ProjeAdi', $("#ProjeAdi").val());
            formData.append('Il', $("#Il").val());
            formData.append('Ilce', $("#Ilce").val());
            formData.append('Mahalle', $("#Mahalle").val());
            formData.append('Ada', $("#Ada").val());
            formData.append('Parsel', $("#Parsel").val());
            formData.append('PortalNumarasi', $("#PortalNumarasi").val());
            formData.append('Resim', $('#Resim')[0].files[0]);
            formData.append('SonucTarihi', $("#SonucTarihi").val());

            $.ajax({
                type: "POST",
                url: '/Crm2/Crm2/CariDuzenle',
                data: formData,
                dataType: "json",
                enctype: 'multipart/form-data',
                async: false,
                contentType: false,
                processData: false,
                //contentType: "application/json; charset=utf-8",
                //dataFilter: function (data) { return data; },
                success: function (data) {
                    if (data.SonucKodu == "1") {

                        Swal.fire({
                            position: "center",
                            icon: "success",
                            title: data.Aciklama,
                            showConfirmButton: true,
                            //timer: 3000
                        });
                        setTimeout(() => window.location.href = '@Url.Action("Cariler", "Crm2", new { Area = "Crm2", Tur = "Havuzum" })', 2000);


                    } else {
                        Swal.fire({
                            position: "center",
                            icon: "error",
                            title: data.Aciklama,
                            showConfirmButton: true,
                            //timer: 3000
                        });
                        return;
                    }
                },
                error: function (msg) {

                    Swal.fire({
                        position: "center",
                        icon: "error",
                        title: msg,
                        showConfirmButton: false,
                        timer: 1500
                    });
                    return;
                }
            });
        }
    </script>

}


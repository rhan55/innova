@using System.Data
@model System.Data.DataTable
@{
    ViewBag.Title = "Ana Sayfa";
    Layout = "~/Views/Shared/_LayoutSade.cshtml";
    string KullaniciAdi = HttpUtility.UrlDecode(Request.Cookies["KullaniciAdi"].Value);

}

<div style="margin-left:auto;margin-right:auto;text-align:center;">

    <a href="/Crm2/Crm2/AnaSayfa" style="color: white;float:left;margin:0px;">
        <div class="tum-kenar-oval"
             style="width: 150px; height: 100px; text-align: center; background-color: #9F1D20; color: white; padding: 0px; font-size: 20px; padding-top: 10px; ">
            <img src="@Url.Content("~/Tema/media/flags/AnaSayfa.png")" style="height:50px;" />

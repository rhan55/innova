            <img src="@Url.Content("~/Tema/media/flags/Iptal.png")" style="height:50px;" />
            <br />Çıkış
        </div>
    </a>
</div>


@section Styles {

    <style>
        .tum-kenar-oval {
            border: 2px solid #a1a1a1;
            padding: 10px 40px;
            background: green;
            width: 200px;
            height: 100px;
            border-radius: 15px;
            color: white;
            margin: 20px;
            float: left;
        }
    </style>
}

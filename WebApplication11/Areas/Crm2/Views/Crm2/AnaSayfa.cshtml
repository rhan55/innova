    <a href="/Crm2/Crm2/YeniCari" style="color: white;float:left;margin:0px;">
        <div class="tum-kenar-oval"
             style="width: 150px; height: 100px; text-align: center; background-color: #9F1D20; color: white; padding: 0px; font-size: 20px; padding-top: 10px;">
